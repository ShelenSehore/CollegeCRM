@section Scripts {
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";

        window.onload = function () {
            $("#ddlClass, #ddlCourse, #ddlYear, #ddlSession").change(function () {
                $("#tblStudentList tbody").empty();
                SearchStudent();
            });

            // Enter key triggers search
            $("#txtSearch").on('keypress', function (e) {
                if (e.which === 13) {
                    SearchStudent();
                }
            });

            SearchStudent();
        };

        function Reset() {
            $("#txtSearch").val('');
            $('#ddlSession option:first').prop("selected", true);
            $('#ddlClass option:first').prop("selected", true);
            $('#ddlCourse option:first').prop("selected", true);
            $('#ddlYear option:first').prop("selected", true);
            SearchStudent();
        }

        function SearchStudent() {
            var name = $("#txtSearch").val();
            var varClass = $('#ddlClass option:selected').text();
            var varCourse = $('#ddlCourse option:selected').text();
            var varYear = $('#ddlYear option:selected').text();
            var varSession = $('#ddlSession option:selected').text();

            $.post(BASE_URL + "/Payment/SearchList", {
                name: name,
                classes: varClass,
                course: varCourse,
                year: varYear,
                session: varSession
            },
                function (res) {
                    TableData(res);
                }
            );
        }

        function getCourseBadgeClass(course) {
            var c = (course || '').toLowerCase();
            if (c.includes('sci')) return 'science';
            if (c.includes('art')) return 'arts';
            if (c.includes('com') || c.includes('comm')) return 'commerce';
            return 'default';
        }

        function TableData(tableData) {
            $("#tblStudentList tbody").empty();

            var data = tableData.data || [];
            var count = data.length;

            // Update counts
            $('#totalCount').text(count);
            $('#statTotal').text(count);
            $('#showingCount').text(count);

            if (count === 0) {
                $("#tblStudentList tbody").append(
                    '<tr><td colspan="9" style="text-align:center;padding:60px 20px;">' +
                    '<div class="empty-state">' +
                    '<i class="fas fa-search"></i>' +
                    '<h4>No students found</h4>' +
                    '<p>Try adjusting your filters or search criteria</p>' +
                    '</div></td></tr>'
                );
                return;
            }

            $.each(data, function (index, element) {
                var badgeClass = getCourseBadgeClass(element.course);
                var rowNum = index + 1;

                $("#tblStudentList tbody").append(
                    '<tr style="animation:fadeInUp 0.3s ease forwards;animation-delay:' + (index * 0.03) + 's;opacity:0;">' +
                    '<td><span class="row-index">' + rowNum + '</span></td>' +
                    '<td><span class="form-no"><i class="fas fa-hashtag" style="font-size:0.65rem;"></i> ' + (element.admissionFormNo || '-') + '</span></td>' +
                    '<td><span class="student-name">' + (element.studentName || '-') + '</span></td>' +
                    '<td><span class="father-name">' + (element.fatherName || '-') + '</span></td>' +
                    '<td>' + (element.year || '-') + '</td>' +
                    '<td>' + (element.subject || '-') + '</td>' +
                    '<td><span class="course-badge ' + badgeClass + '">' + (element.course || '-') + '</span></td>' +
                    '<td><span class="mobile-no"><i class="fas fa-phone" style="font-size:0.65rem;margin-right:4px;color:var(--text-muted);"></i>' + (element.mobileNoOne || '-') + '</span></td>' +
                    '<td>' +
                        '<div class="action-group">' +
                            '<a class="action-btn pay" href="../Payment/PaymentDetail?id=' + element.id + '" title="Pay"><i class="fas fa-credit-card"></i></a>' +
                            '<a class="action-btn view" data-toggle="modal" data-target="#modal-View" onclick="PaymentDetail(' + element.id + ')" title="View"><i class="fas fa-eye"></i></a>' +
                            '<a class="action-btn edit" href="../Student/index?id=' + element.id + '" title="Edit"><i class="fas fa-pen"></i></a>' +
                        '</div>' +
                    '</td></tr>'
                );
            });
        }

        // Payment Detail Modal
        function PaymentDetail(id) {
            $.post(BASE_URL + "/Payment/StudentPaymentDetail", {
                id: id
            },
                function (res) {
                    var detail = res.data.studentDetail;
                    $('#imgStudentPhoto').attr('src', detail.photo);
                    $('#achStudentName').text(detail.studentName + " / " + detail.fatherName);
                    $('#achYear').text(detail.year);
                    $('#achClass').text(detail.class);
                    $('#achCourse').text(detail.course);
                    $('#achSession').text(detail.session + " / FormNo. " + detail.admissionFormNo);

                    var feedetail = res.data.studentFeeDetail;
                    var totalFee = parseFloat(feedetail.totalFeeAfterDiscount) || 0;
                    var paidAmount = parseFloat(feedetail.paidAmount) || 0;
                    var scholarship = parseFloat(feedetail.scholership) || 0;
                    var balance = totalFee - paidAmount - scholarship;
                    var percent = totalFee > 0 ? Math.round(((paidAmount + scholarship) / totalFee) * 100) : 0;
                    if (percent > 100) percent = 100;

                    $('#achTotalFee').text(formatCurrency(totalFee));
                    $('#achPaid').text(formatCurrency(paidAmount));
                    $('#achScholer').text(formatCurrency(scholarship));
                    $('#achBalance').text(formatCurrency(balance));

                    // Animate progress bar
                    setTimeout(function () {
                        $('#feeProgressBar').css('width', percent + '%');
                        $('#feePercent').text(percent + '%');
                    }, 200);

                    $("#modal-Promod").modal("show");
                }
            );
        }

        function formatCurrency(num) {
            return num.toLocaleString('en-IN', { style: 'currency', currency: 'INR', minimumFractionDigits: 0 });
        }

        // Reset progress bar when modal closes
        $('#modal-Promod').on('hidden.bs.modal', function () {
            $('#feeProgressBar').css('width', '0%');
            $('#feePercent').text('0%');
        });
    </script>
}