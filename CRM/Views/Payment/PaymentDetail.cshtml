                                                <td>
                                                    <input id="txtRecBookNo" class="text-black" type="number" />
                                                </td>
                                            </tr>
                                            <tr>

                                                <td>
                                                    Recept No.
                                                </td>
                                                <td>
                                                    <input id="txtReceptNo" class="text-black" type="number" />
                                                </td>
                                            </tr>
                                            <tr><td colspan="2"><strong>Head</strong></td></tr>
                                            <tr id="row1">

                                                <td>
                                                    <select id="ddlHead1" class="form-control">
                                                        <option>Select</option>
                                                        <option>Head 1</option>
                                                        <option>Head 2</option>
                                                        <option>Head 3</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input id="txtAmount1" class="text-black" type="number" /><i class="fas fa-plus"></i>
                                                </td>
                                            </tr>
                                            <tr >

                                                <td>
                                                    <select id="ddlHead2" class="form-control">
                                                        <option>Select</option>
                                                        <option>Head 1</option>
                                                        <option>Head 2</option>
                                                        <option>Head 3</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input id="txtAmount2" class="text-black" type="number" /><i class="fas fa-plus"></i>
                                                </td>
                                            </tr>
                                            <tr >

                                                <td>
                                                    <select id="ddlHead3" class="form-control">
                                                        <option>Select</option>
                                                        <option>Head 1</option>
                                                        <option>Head 2</option>
                                                        <option>Head 3</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input id="txtAmount3" class="text-black" type="number" /><i class="fas fa-plus"></i>
                                                </td>
                                            </tr>
                                            <tr >

                                                <td>
                                                    <select id="ddlHead4" class="form-control">
                                                        <option>Select</option>
                                                    </select>
                                                </td>
                                                <td>
                                                    <input id="txtAmount4" class="text-black" type="number" /><i class="fas fa-plus"></i>
                                                </td>
                                            </tr>
                                            <tr>

                                                <td>
                                                    <strong> Total Pay</strong>
                                                </td>
                                                <td>
                                                    <strong> <input id="txtTotalPay" readonly="readonly" class="text-black" type="number" /> </strong>
                                                </td>
                                            </tr>

                                            <tr>
                                                <td colspan="2">
                                                    <button type="button" onclick="payNow();" class="btn btn-success btn-block"  /><i class="fa fa-bell"></i> Process for Pay </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="tab-pane" id="History">
                                    pay now333
                                </div>
                                <!-- /.tab-pane -->
                            </div>
                            <!-- /.tab-content -->
                        </div><!-- /.card-body -->
                    </div>
                    <!-- /.card -->
                </div>
                <!-- /.col -->
            </div>
            <!-- /.row -->
        </div><!-- /.container-fluid -->
    </section>
    <!-- /.content -->



</div>

