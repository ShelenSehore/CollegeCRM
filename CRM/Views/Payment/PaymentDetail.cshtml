                <h4 class="modal-title">Payment Recipt</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            Recipt Book No :
                            <strong><label id="lblReciptBookNo"></label></strong>
                        </div>
                    </div>
                    <div class="col-md-3 float-right"></div>
                    <div class="col-md-3 float-right"></div>

                    <div class="col-md-3 float-right">
                        <div class="form-group">
                            College :
                            <strong><label>College</label></strong>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            Name :
                            <strong><label>College</label></strong>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="form-group">
                            Father Name :
                            <strong><label>College</label></strong>
                        </div>
                    </div>

                </div>
                <hr />
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            Class :
                            <strong><label>College</label></strong>
                        </div>
                    </div>
                    <div class="col-md-3 float-right">
                        <div class="form-group">
                            Course :
                            <strong><label>College</label></strong>
                        </div>
                    </div>
                    <div class="col-md-3 float-right">
                        <div class="form-group">
                            Year :
                            <strong><label>College</label></strong>
                        </div>
                    </div>

                    <div class="col-md-3 float-right">
                        <div class="form-group">
                            Session :
                            <strong><label>College</label></strong>
                        </div>
                    </div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            Head :
                            <strong><label>454</label></strong>
                        </div>
                    </div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            Total Pay :
                            <strong><label>1000</label></strong>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success"><i class="fas fa-save"></i>Pay</button>
            </div>
        </div>
    </div>
</div>

