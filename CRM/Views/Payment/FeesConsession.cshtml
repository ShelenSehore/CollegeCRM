@section Scripts {
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var Toast;

        // ═══════════════════════════════════════════════════
        // Pagination State
        // ═══════════════════════════════════════════════════
        var allStudentData = [];
        var currentPage = 1;
        var pageSize = 50;
        var totalRecords = 0;

        // ═══════════════════════════════════════════════════
        // Initialization
        // ═══════════════════════════════════════════════════
        window.onload = function () {

            $("#ddlClass, #ddlCourse, #ddlYear, #ddlSession").change(function () {
                currentPage = 1;
                SearchStudent();
            });

            // Quick search filters visible rows on current page
            $("#txtQuickSearch").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#tblStudentList tbody tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            // Enter key triggers search
            $("#txtSearch").on('keypress', function (e) {
                if (e.which === 13) {
                    e.preventDefault();
                    currentPage = 1;
                    SearchStudent();
                }
            });

            SearchStudent();

            // Scholarship calculation in modal
            $("#txtScholership").change(function () {
                var varScholership = this.value;
                if (varScholership != "" && varScholership != "0") {
                    var varScholershipAmount = parseFloat(varScholership) || 0;
                    var varTotalFeeAmount = parseFloat($('#hdnTotalFeeCurrently').val()) || 0;
                    $("#txtAfterDiscountTotalFee").val(varTotalFeeAmount - varScholershipAmount);
                }
            });
        };

        function Alert(icon, title, className) {
            Toast.fire({ icon: icon, title: title, class: className });
        }

        // ═══════════════════════════════════════════════════
        // Reset Filters
        // ═══════════════════════════════════════════════════
        function Reset() {
            $("#txtSearch").val('');
            $('#ddlSession option:first').prop("selected", true);
            $('#ddlClass option:first').prop("selected", true);
            $('#ddlCourse option:first').prop("selected", true);
            $('#ddlYear option:first').prop("selected", true);
            currentPage = 1;
            SearchStudent();
        }

        // ═══════════════════════════════════════════════════
        // Search Students
        // ═══════════════════════════════════════════════════
        function SearchStudent() {
            var name = $("#txtSearch").val();
            var varClass = $('#ddlClass option:selected').text();
            var varCourse = $('#ddlCourse option:selected').text();
            var varYear = $('#ddlYear option:selected').text();
            var varSession = $('#ddlSession option:selected').text();

            $.post(BASE_URL + "/Payment/SearchList", {
                name: name,
                classes: varClass,
                course: varCourse,
                year: varYear,
                session: varSession
            }, function (res) {
                allStudentData = res.data || [];
                totalRecords = allStudentData.length;
                updateStats();
                var totalPages = Math.ceil(totalRecords / pageSize);
                if (currentPage > totalPages) currentPage = 1;
                if (currentPage < 1) currentPage = 1;
                renderPage();
            });
        }

        // ═══════════════════════════════════════════════════
        // Update Stat Cards
        // ═══════════════════════════════════════════════════
        function updateStats() {
            $("#statTotalStudents").text(totalRecords);
            $("#spnTotalStudents").text(totalRecords);

            var concessionCount = 0;
            var totalDiscountAmt = 0;
            var totalNetFee = 0;

            $.each(allStudentData, function (i, el) {
                if (el.scholership && parseFloat(el.scholership) > 0) {
                    concessionCount++;
                    totalDiscountAmt += parseFloat(el.scholership) || 0;
                }
                totalNetFee += parseFloat(el.totalFeeAfterDiscount) || parseFloat(el.totalFee) || 0;
            });

            $("#statConcessions").text(concessionCount);
            $("#statTotalDiscount").text('\u20B9' + totalDiscountAmt.toLocaleString('en-IN'));
            $("#statNetFee").text('\u20B9' + totalNetFee.toLocaleString('en-IN'));
        }

        // ═══════════════════════════════════════════════════
        // Render Current Page
        // ═══════════════════════════════════════════════════
        function renderPage() {
            var startIndex = (currentPage - 1) * pageSize;
            var endIndex = Math.min(startIndex + pageSize, totalRecords);
            var pageData = allStudentData.slice(startIndex, endIndex);

            var fromNum = totalRecords === 0 ? 0 : startIndex + 1;
            var toNum = endIndex;

            $('#pgFrom').text(fromNum);
            $('#pgTo').text(toNum);
            $('#pgTotal').text(totalRecords);

            renderTable(pageData, startIndex);
            renderPagination();
        }

        // ═══════════════════════════════════════════════════
        // Render Table
        // ═══════════════════════════════════════════════════
        function renderTable(data, startIndex) {
            $("#tblStudentList tbody").empty();

            if (data.length === 0) {
                $("#tblStudentList tbody").append(
                    '<tr><td colspan="9">' +
                    '<div class="empty-state">' +
                    '<i class="fas fa-search"></i>' +
                    '<h4>No students found</h4>' +
                    '<p>Try adjusting your filters or search criteria</p>' +
                    '</div></td></tr>'
                );
                return;
            }

            $.each(data, function (index, element) {
                var rowNum = startIndex + index + 1;

                $("#tblStudentList tbody").append(
                    "<tr>" +
                    "<td><span class='row-index'>" + rowNum + "</span></td>" +
                    "<td><span class='form-no-badge'>" + (element.admissionFormNo || '-') + "</span></td>" +
                    "<td class='student-name-cell'>" + (element.studentName || '-') + "</td>" +
                    "<td>" + (element.fatherName || '-') + "</td>" +
                    "<td>" + (element.year || element.class || '-') + "</td>" +
                    "<td>" + (element.subject || '-') + "</td>" +
                    "<td>" + (element.course || '-') + "</td>" +
                    "<td class='mobile-cell'>" + (element.mobileNoOne || '-') + "</td>" +
                    "<td class='no-print-col'>" +
                        "<div class='action-btn-group' style='display:flex;gap:2px;'>" +
                            "<button type='button' class='btn btn-action'><i class='fas fa-ellipsis-h'></i></button>" +
                            "<button type='button' class='btn dropdown-toggle' data-toggle='dropdown' style='background:var(--primary);color:#fff;border:none;border-radius:8px;padding:5px 8px;font-size:12px;'>" +
                                "<span class='sr-only'>Toggle</span>" +
                            "</button>" +
                            "<div class='dropdown-menu' role='menu'>" +
                                "<a class='dropdown-item' onclick='ConcessionPopUp(" + element.id + ")'><i class='fas fa-university'></i> Concession</a>" +
                            "</div>" +
                        "</div>" +
                    "</td>" +
                    "</tr>"
                );
            });
        }

        // ═══════════════════════════════════════════════════
        // Render Pagination Controls
        // ═══════════════════════════════════════════════════
        function renderPagination() {
            var totalPages = Math.ceil(totalRecords / pageSize);
            if (totalPages <= 0) totalPages = 1;
            var container = $('#paginationControls');
            container.empty();

            if (totalRecords === 0) {
                $('#paginationWrapper').hide();
                return;
            }
            $('#paginationWrapper').show();

            // Previous
            container.append(
                '<button class="page-btn nav-btn ' + (currentPage === 1 ? 'disabled' : '') + '" ' +
                'onclick="goToPage(' + (currentPage - 1) + ')" ' +
                (currentPage === 1 ? 'disabled' : '') + '>' +
                '<i class="fas fa-chevron-left"></i> Prev</button>'
            );

            // Page numbers with ellipsis
            var pages = generatePageNumbers(currentPage, totalPages);
            $.each(pages, function (i, p) {
                if (p === '...') {
                    container.append('<span class="page-ellipsis">...</span>');
                } else {
                    container.append(
                        '<button class="page-btn ' + (p === currentPage ? 'active' : '') + '" ' +
                        'onclick="goToPage(' + p + ')">' + p + '</button>'
                    );
                }
            });

            // Next
            container.append(
                '<button class="page-btn nav-btn ' + (currentPage === totalPages ? 'disabled' : '') + '" ' +
                'onclick="goToPage(' + (currentPage + 1) + ')" ' +
                (currentPage === totalPages ? 'disabled' : '') + '>' +
                'Next <i class="fas fa-chevron-right"></i></button>'
            );
        }

        // Smart page number generation with ellipsis
        function generatePageNumbers(current, total) {
            var pages = [];
            if (total <= 7) {
                for (var i = 1; i <= total; i++) pages.push(i);
            } else {
                pages.push(1);
                if (current > 4) pages.push('...');
                var start = Math.max(2, current - 1);
                var end = Math.min(total - 1, current + 1);
                if (current <= 4) end = Math.min(5, total - 1);
                if (current >= total - 3) start = Math.max(2, total - 4);
                for (var j = start; j <= end; j++) pages.push(j);
                if (current < total - 3) pages.push('...');
                pages.push(total);
            }
            return pages;
        }

        // Navigate to page
        function goToPage(page) {
            var totalPages = Math.ceil(totalRecords / pageSize);
            if (page < 1 || page > totalPages) return;
            currentPage = page;
            renderPage();
            // Clear quick search on page change
            $('#txtQuickSearch').val('');
            $('html, body').animate({
                scrollTop: $('.table-card').offset().top - 80
            }, 300);
        }

        // Change page size
        function changePageSize() {
            pageSize = parseInt($('#ddlPageSize').val()) || 50;
            currentPage = 1;
            renderPage();
        }

        // ═══════════════════════════════════════════════════
        // PRINT FUNCTIONALITY
        // ═══════════════════════════════════════════════════
        function printStudentList() {
            // Build filter info for print header
            var session = $('#ddlSession option:selected').text();
            var year = $('#ddlYear option:selected').text();
            var cls = $('#ddlClass option:selected').text();
            var course = $('#ddlCourse option:selected').text();
            var search = $("#txtSearch").val();

            var filterParts = [];
            if (session && session !== 'Select') filterParts.push('Session: ' + session);
            if (year && year !== 'Select') filterParts.push('Year: ' + year);
            if (cls && cls !== 'Select') filterParts.push('Class: ' + cls);
            if (course && course !== 'Select') filterParts.push('Course: ' + course);
            if (search) filterParts.push('Name: ' + search);

            var filterInfo = filterParts.length > 0 ? filterParts.join(' | ') : 'All Students';
            $('#printFilterInfo').text(filterInfo);

            // Set print date/time
            var now = new Date();
            $('#printDate').text(now.toLocaleDateString('en-IN', {
                day: '2-digit', month: 'short', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            }));

            // Swap table to show ALL data for printing
            var savedHtml = $("#tblStudentList tbody").html();
            $("#tblStudentList tbody").empty();

            if (allStudentData.length === 0) {
                $("#tblStudentList tbody").append(
                    '<tr><td colspan="9" style="text-align:center;padding:40px;">No data to print</td></tr>'
                );
            } else {
                $.each(allStudentData, function (index, element) {
                    var rowNum = index + 1;
                    $("#tblStudentList tbody").append(
                        "<tr>" +
                        "<td><span class='row-index'>" + rowNum + "</span></td>" +
                        "<td><span class='form-no-badge'>" + (element.admissionFormNo || '-') + "</span></td>" +
                        "<td class='student-name-cell'>" + (element.studentName || '-') + "</td>" +
                        "<td>" + (element.fatherName || '-') + "</td>" +
                        "<td>" + (element.year || element.class || '-') + "</td>" +
                        "<td>" + (element.subject || '-') + "</td>" +
                        "<td>" + (element.course || '-') + "</td>" +
                        "<td class='mobile-cell'>" + (element.mobileNoOne || '-') + "</td>" +
                        "</tr>"
                    );
                });
            }

            // Trigger browser print dialog
            window.print();

            // Restore paginated view
            setTimeout(function () {
                renderPage();
            }, 500);
        }

        // ═══════════════════════════════════════════════════
        // Concession Modal
        // ═══════════════════════════════════════════════════
        function ConcessionPopUp(studentId) {
            $.post(BASE_URL + "/Payment/GetFeeDetail", { id: studentId }, function (res) {
                var photoUrl = BASE_URL + "/StudentData/Photo/" + res.studentData.photo + ".jpg";
                $('#imgPhoto').attr('src', photoUrl);

                $('#hdnStudentFeeId').val(res.concessionDetail.id);
                $('#hdnTotalFeeCurrently').val(res.concessionDetail.totalFeeAfterDiscount);
                $('#hdnCurrentlyDiscount').val(res.concessionDetail.scholership);

                $('#spnName').text(res.studentData.studentName + " / " + res.studentData.fatherName);
                $('#spnClass').text(res.studentData.class + " / " + res.studentData.course + " / " + res.studentData.year + " / " + res.studentData.session);
                $('#spnTotalFee').text('\u20B9' + Number(res.concessionDetail.totalFee).toLocaleString('en-IN'));
                $('#spnDiscount').text('\u20B9' + Number(res.concessionDetail.scholership).toLocaleString('en-IN'));
                $('#spnDiscountBy').text(res.concessionDetail.disBy + (res.concessionDetail.disResion ? " / " + res.concessionDetail.disResion : ""));
                $('#spnFeeAfterDiscount').text('\u20B9' + Number(res.concessionDetail.totalFeeAfterDiscount).toLocaleString('en-IN'));

                // Pre-fill form
                $('#txtScholership').val(0);
                $('#txtDiscountBy').val('');
                $('#txtDiscountReasion').val('');
                $('#txtAfterDiscountTotalFee').val(res.concessionDetail.totalFeeAfterDiscount);

                $("#modal-ConcessionPopUp").modal("show");
            });
        }

        function SaveConcession() {
            $.post(BASE_URL + "/Payment/SaveConcession", {
                studentFeeId: $('#hdnStudentFeeId').val(),
                scholership: $('#txtScholership').val(),
                discountBy: $('#txtDiscountBy').val(),
                discountRession: $('#txtDiscountReasion').val(),
                afterDiscountTotalFee: $('#txtAfterDiscountTotalFee').val()
            }, function (res) {
                Alert('success', 'Successfully Saved', 'bg-success');
                $("#modal-ConcessionPopUp").modal("hide");
                SearchStudent();
            });
        }

        function DownloadExcel() {
            $("#hdnExcelSession").val($('#ddlSession option:selected').text());
            $("#hdnExcelClass").val($('#ddlClass option:selected').text());
            $("#hdnExcelCourse").val($('#ddlCourse option:selected').text());
            $("#hdnExcelYear").val($('#ddlYear option:selected').text());
            $("#hdnExcelName").val($("#txtSearch").val());
            $("#frmDownloadExcel").submit();
        }

        function validateField(selector, message, type) {
            var value = $(selector).val();
            var errorId = selector.replace('#', '') + "Error";

            if (type === "dropdown") {
                if (value === "" || value === "0" || value === null || value === "Select") {
                    $(selector).addClass("is-invalid");
                    if ($("#" + errorId).length == 0) {
                        $(selector).after('<span id="' + errorId + '" class="error invalid-feedback">' + message + '</span>');
                    }
                    return false;
                } else {
                    $(selector).removeClass("is-invalid");
                    $("#" + errorId).remove();
                    return true;
                }
            }

            if (value === "") {
                $(selector).addClass("is-invalid");
                if ($("#" + errorId).length == 0) {
                    $(selector).after('<span id="' + errorId + '" class="error invalid-feedback">' + message + '</span>');
                }
                return false;
            }

            if (type === "mobile") {
                var mobilePattern = /^[0-9]{10}$/;
                if (!mobilePattern.test(value)) {
                    $(selector).addClass("is-invalid");
                    if ($("#" + errorId).length == 0) {
                        $(selector).after('<span id="' + errorId + '" class="error invalid-feedback">Enter valid 10 digit mobile number</span>');
                    }
                    return false;
                }
            }

            $(selector).removeClass("is-invalid");
            $("#" + errorId).remove();
            return true;
        }
    </script>
}