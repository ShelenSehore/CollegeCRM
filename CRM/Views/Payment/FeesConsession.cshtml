@model CRM.ModelsForView.StudentListView
@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    ViewData["Title"] = "Concession";
    var baseUrl = ViewBag.BaseUrl;
}

<style>
    :root {
        --primary: #6366f1;
        --primary-light: #818cf8;
        --primary-dark: #4f46e5;
        --accent: #f59e0b;
        --accent-light: #fbbf24;
        --success: #10b981;
        --danger: #ef4444;
        --info: #06b6d4;
        --purple: #a855f7;
        --pink: #ec4899;
        --gradient-1: linear-gradient(135deg, #6366f1, #a855f7, #ec4899);
        --gradient-2: linear-gradient(135deg, #06b6d4, #6366f1);
        --gradient-3: linear-gradient(135deg, #f59e0b, #ef4444);
        --gradient-card: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4338ca 100%);
        --bg-body: #f0f2ff;
        --card-bg: #ffffff;
        --text-dark: #1e1b4b;
        --text-muted: #6b7280;
        --border-light: #e0e7ff;
    }

    .content-wrapper {
        background: var(--bg-body) !important;
    }

    /* ── Page Hero ── */
    .page-hero {
        background: var(--gradient-1);
        border-radius: 20px;
        padding: 32px 36px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(99,102,241,.35);
    }

        .page-hero::before {
            content: '';
            position: absolute;
            width: 320px;
            height: 320px;
            background: rgba(255,255,255,.08);
            border-radius: 50%;
            top: -100px;
            right: -60px;
        }

        .page-hero::after {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,.06);
            border-radius: 50%;
            bottom: -60px;
            left: 30%;
        }

        .page-hero h1 {
            color: #fff;
            font-weight: 800;
            font-size: 28px;
            margin: 0 0 4px;
            letter-spacing: -.3px;
        }

        .page-hero p {
            color: rgba(255,255,255,.78);
            margin: 0;
            font-size: 14px;
        }

    /* ── Stats Row ── */
    .stat-card {
        border-radius: 16px;
        padding: 22px 24px;
        color: #fff;
        position: relative;
        overflow: hidden;
        transition: transform .25s, box-shadow .25s;
        cursor: default;
    }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0,0,0,.18);
        }

        .stat-card .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: rgba(255,255,255,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }

        .stat-card .stat-value {
            font-size: 30px;
            font-weight: 800;
            line-height: 1.1;
            margin-top: 10px;
        }

        .stat-card .stat-label {
            font-size: 13px;
            opacity: .85;
            margin-top: 2px;
        }

        .stat-card::after {
            content: '';
            position: absolute;
            width: 120px;
            height: 120px;
            background: rgba(255,255,255,.07);
            border-radius: 50%;
            bottom: -40px;
            right: -20px;
        }

    .stat-purple {
        background: linear-gradient(135deg, #7c3aed, #a855f7);
    }

    .stat-cyan {
        background: linear-gradient(135deg, #0891b2, #06b6d4);
    }

    .stat-amber {
        background: linear-gradient(135deg, #d97706, #f59e0b);
    }

    .stat-rose {
        background: linear-gradient(135deg, #e11d48, #f43f5e);
    }

    /* ── Filter Card ── */
    .filter-card {
        background: var(--card-bg);
        border-radius: 20px;
        border: 1px solid var(--border-light);
        box-shadow: 0 4px 20px rgba(99,102,241,.06);
        padding: 0;
        overflow: hidden;
    }

        .filter-card .filter-header {
            background: linear-gradient(135deg, #eef2ff, #e0e7ff);
            padding: 16px 28px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid var(--border-light);
        }

            .filter-card .filter-header i {
                color: var(--primary);
                font-size: 18px;
            }

            .filter-card .filter-header h3 {
                font-size: 16px;
                font-weight: 700;
                color: var(--text-dark);
                margin: 0;
            }

        .filter-card .filter-body {
            padding: 24px 28px 12px;
        }

        /* ── Form Controls ── */
        .filter-card label {
            font-size: 12px;
            font-weight: 600;
            color: var(--primary-dark);
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 6px;
        }

        .filter-card .form-control {
            border-radius: 10px;
            border: 2px solid var(--border-light);
            font-size: 13px;
            padding: 8px 14px;
            transition: border-color .2s, box-shadow .2s;
        }

            .filter-card .form-control:focus {
                border-color: var(--primary-light);
                box-shadow: 0 0 0 3px rgba(99,102,241,.15);
            }

    /* ── Buttons ── */
    .btn-search {
        background: var(--gradient-2);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 9px 22px;
        font-weight: 600;
        font-size: 13px;
        transition: transform .2s, box-shadow .2s;
    }

        .btn-search:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(6,182,212,.35);
            color: #fff;
        }

    .btn-reset {
        background: #fff;
        color: var(--text-muted);
        border: 2px solid var(--border-light);
        border-radius: 10px;
        padding: 9px 22px;
        font-weight: 600;
        font-size: 13px;
        transition: border-color .2s, color .2s;
    }

        .btn-reset:hover {
            border-color: var(--danger);
            color: var(--danger);
        }

    .btn-excel {
        background: linear-gradient(135deg, #059669, #10b981);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 9px 18px;
        font-weight: 600;
        font-size: 13px;
        transition: transform .2s, box-shadow .2s;
    }

        .btn-excel:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16,185,129,.35);
            color: #fff;
        }

    .btn-print {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 9px 18px;
        font-weight: 600;
        font-size: 13px;
        transition: transform .2s, box-shadow .2s;
    }

        .btn-print:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(99,102,241,.35);
            color: #fff;
        }

    /* ── Table Card ── */
    .table-card {
        background: var(--card-bg);
        border-radius: 20px;
        border: 1px solid var(--border-light);
        box-shadow: 0 4px 20px rgba(99,102,241,.06);
        overflow: hidden;
    }

        .table-card .table-header {
            background: linear-gradient(135deg, #eef2ff, #e0e7ff);
            padding: 16px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--border-light);
            flex-wrap: wrap;
            gap: 12px;
        }

            .table-card .table-header h3 {
                font-size: 16px;
                font-weight: 700;
                color: var(--text-dark);
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .table-card .table-header h3 i {
                    color: var(--primary);
                }

    .student-count-badge {
        background: var(--gradient-1);
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        padding: 5px 16px;
        border-radius: 30px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 4px 14px rgba(99,102,241,.3);
    }

        .student-count-badge i {
            font-size: 12px;
        }

    /* ── Table ── */
    #tblStudentList {
        margin: 0;
    }

        #tblStudentList thead th {
            background: var(--gradient-card);
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            padding: 14px 16px;
            border: none !important;
            white-space: nowrap;
        }

        #tblStudentList tbody td {
            padding: 12px 16px;
            font-size: 13px;
            color: var(--text-dark);
            border-bottom: 1px solid var(--border-light) !important;
            vertical-align: middle;
        }

        #tblStudentList tbody tr {
            transition: background .2s;
        }

            #tblStudentList tbody tr:hover {
                background: #f5f3ff;
            }

            #tblStudentList tbody tr:nth-child(even) {
                background: #fafaff;
            }

                #tblStudentList tbody tr:nth-child(even):hover {
                    background: #f5f3ff;
                }

    .row-index {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: linear-gradient(135deg, #6366f1, #818cf8);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
    }

    .form-no-badge {
        background: #eef2ff;
        color: var(--primary-dark);
        padding: 3px 10px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 12px;
    }

    .student-name-cell {
        font-weight: 600;
        color: var(--text-dark);
    }

    .mobile-cell {
        font-family: 'Courier New', monospace;
        font-weight: 600;
        color: var(--info);
    }

    /* ── Action Dropdown ── */
    .action-btn-group .btn-action {
        background: var(--gradient-2);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
    }

        .action-btn-group .btn-action:hover {
            opacity: .9;
        }

    .action-btn-group .dropdown-toggle {
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 5px 8px;
        font-size: 12px;
    }

    .action-btn-group .dropdown-menu {
        border-radius: 12px;
        border: 1px solid var(--border-light);
        box-shadow: 0 10px 30px rgba(0,0,0,.12);
        padding: 8px;
        min-width: 180px;
    }

    .action-btn-group .dropdown-item {
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 500;
        color: var(--text-dark);
        transition: background .15s;
    }

        .action-btn-group .dropdown-item:hover {
            background: #eef2ff;
            color: var(--primary);
        }

        .action-btn-group .dropdown-item i {
            margin-right: 8px;
            color: var(--primary);
        }

    /* ═══════════════════════════════════════════════════ */
    /* PAGINATION                                         */
    /* ═══════════════════════════════════════════════════ */
    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 28px;
        border-top: 1px solid var(--border-light);
        background: linear-gradient(135deg, #fafaff, #f5f3ff);
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-size: 13px;
        color: var(--text-muted);
        font-weight: 500;
    }

        .pagination-info strong {
            color: var(--primary);
            font-weight: 700;
        }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
    }

    .page-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        border-radius: 10px;
        border: 2px solid var(--border-light);
        background: #fff;
        font-weight: 600;
        font-size: 13px;
        color: var(--text-muted);
        cursor: pointer;
        transition: all .2s;
        padding: 0 6px;
        text-decoration: none !important;
    }

        .page-btn:hover:not(.disabled):not(.active) {
            border-color: var(--primary-light);
            color: var(--primary);
            background: #eef2ff;
            transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(99,102,241,.12);
        }

        .page-btn.active {
            background: var(--gradient-1);
            color: #fff;
            border-color: transparent;
            box-shadow: 0 4px 14px rgba(99,102,241,.3);
        }

        .page-btn.disabled {
            opacity: .35;
            cursor: not-allowed;
            pointer-events: none;
        }

        .page-btn.nav-btn {
            padding: 0 12px;
            gap: 4px;
            font-size: 12px;
            letter-spacing: .3px;
        }

    .page-ellipsis {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        font-weight: 700;
        color: var(--text-muted);
        font-size: 14px;
    }

    .page-size-selector {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .page-size-selector label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-muted);
            white-space: nowrap;
            text-transform: uppercase;
            letter-spacing: .5px;
            margin: 0;
        }

        .page-size-selector select {
            border-radius: 10px;
            border: 2px solid var(--border-light);
            font-size: 13px;
            padding: 6px 10px;
            color: var(--text-dark);
            background: #fff;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            cursor: pointer;
        }

            .page-size-selector select:focus {
                border-color: var(--primary-light);
                box-shadow: 0 0 0 3px rgba(99,102,241,.15);
            }

    /* ── Modal ── */
    .modal-content {
        border-radius: 20px;
        border: none;
        overflow: hidden;
        box-shadow: 0 25px 60px rgba(0,0,0,.2);
    }

    .modal-header-concession {
        background: var(--gradient-1);
        color: #fff;
        border: none;
        padding: 20px 28px;
    }

        .modal-header-concession h4 {
            font-weight: 700;
            font-size: 18px;
        }

        .modal-header-concession .close {
            color: #fff;
            opacity: .8;
            font-size: 28px;
        }

            .modal-header-concession .close:hover {
                opacity: 1;
            }

    .widget-user-header-custom {
        background: linear-gradient(135deg, #f59e0b, #f97316) !important;
        border-radius: 16px;
        padding: 22px 24px;
        position: relative;
        overflow: hidden;
    }

        .widget-user-header-custom::before {
            content: '';
            position: absolute;
            width: 140px;
            height: 140px;
            background: rgba(255,255,255,.1);
            border-radius: 50%;
            top: -40px;
            right: -20px;
        }

        .widget-user-header-custom .widget-user-image img {
            width: 60px;
            height: 60px;
            border: 3px solid #fff;
            border-radius: 14px;
            object-fit: cover;
        }

        .widget-user-header-custom h3 {
            color: #fff;
            font-weight: 700;
            font-size: 18px;
            margin: 6px 0 2px;
        }

        .widget-user-header-custom h5 {
            color: rgba(255,255,255,.85);
            font-size: 13px;
            margin: 0;
        }

    .fee-list {
        list-style: none;
        padding: 0;
        margin: 16px 0 0;
    }

        .fee-list li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 20px;
            border-radius: 12px;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 500;
            transition: transform .15s;
        }

            .fee-list li:hover {
                transform: translateX(4px);
            }

            .fee-list li.fee-total {
                background: linear-gradient(135deg, #eef2ff, #e0e7ff);
                color: var(--primary-dark);
            }

            .fee-list li.fee-discount {
                background: linear-gradient(135deg, #fef3c7, #fde68a);
                color: #92400e;
            }

            .fee-list li.fee-discount-by {
                background: linear-gradient(135deg, #fce7f3, #fbcfe8);
                color: #9d174d;
            }

            .fee-list li.fee-after {
                background: linear-gradient(135deg, #d1fae5, #a7f3d0);
                color: #065f46;
                font-weight: 700;
                font-size: 16px;
            }

            .fee-list li span.fee-label {
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .fee-list li span.fee-label i {
                    font-size: 14px;
                }

            .fee-list li span.fee-value {
                font-weight: 700;
            }

    /* ── Concession Form ── */
    .concession-form {
        background: #fafaff;
        border-radius: 16px;
        padding: 20px 24px;
        margin-top: 12px;
        border: 1px solid var(--border-light);
    }

        .concession-form label {
            font-size: 11px;
            font-weight: 700;
            color: var(--primary-dark);
            text-transform: uppercase;
            letter-spacing: .5px;
            margin-bottom: 4px;
        }

        .concession-form .form-control {
            border-radius: 10px;
            border: 2px solid var(--border-light);
            font-size: 13px;
            padding: 8px 14px;
            transition: border-color .2s, box-shadow .2s;
        }

            .concession-form .form-control:focus {
                border-color: var(--primary-light);
                box-shadow: 0 0 0 3px rgba(99,102,241,.15);
            }

    /* ── Modal Footer ── */
    .modal-footer-concession {
        border-top: 1px solid var(--border-light);
        padding: 16px 28px;
    }

    .btn-close-modal {
        border-radius: 10px;
        font-weight: 600;
        padding: 9px 24px;
    }

    .btn-save-modal {
        background: var(--gradient-1);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        padding: 9px 28px;
        font-size: 14px;
        transition: transform .2s, box-shadow .2s;
    }

        .btn-save-modal:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(99,102,241,.35);
            color: #fff;
        }

    /* ── Pulse dot ── */
    .pulse-dot {
        width: 8px;
        height: 8px;
        background: var(--success);
        border-radius: 50%;
        display: inline-block;
        animation: pulse-anim 1.5s infinite;
    }

    @@keyframes pulse-anim {
        0% {
            box-shadow: 0 0 0 0 rgba(16,185,129,.5);
        }

        70% {
            box-shadow: 0 0 0 8px rgba(16,185,129,0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(16,185,129,0);
        }
    }

    /* ── Breadcrumb ── */
    .breadcrumb-custom {
        display: flex;
        align-items: center;
        gap: 6px;
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .breadcrumb-custom li {
            font-size: 13px;
        }

            .breadcrumb-custom li a {
                color: rgba(255,255,255,.7);
                text-decoration: none;
                transition: color .2s;
            }

                .breadcrumb-custom li a:hover {
                    color: #fff;
                }

            .breadcrumb-custom li.active {
                color: #fff;
                font-weight: 600;
            }

            .breadcrumb-custom li + li::before {
                content: '/';
                color: rgba(255,255,255,.4);
                margin-right: 6px;
            }

    /* ── Inline search ── */
    .table-search-input {
        border-radius: 10px;
        border: 2px solid var(--border-light);
        padding: 6px 14px;
        font-size: 13px;
        width: 220px;
        transition: border-color .2s, box-shadow .2s;
    }

        .table-search-input:focus {
            border-color: var(--primary-light);
            box-shadow: 0 0 0 3px rgba(99,102,241,.15);
            outline: none;
        }

    /* ── Scrollbar ── */
    .table-responsive::-webkit-scrollbar {
        height: 6px;
    }

    .table-responsive::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 3px;
    }

    .table-responsive::-webkit-scrollbar-thumb {
        background: var(--primary-light);
        border-radius: 3px;
    }

    /* ── Empty State ── */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

        .empty-state i {
            font-size: 3rem;
            color: var(--primary-light);
            margin-bottom: 16px;
        }

        .empty-state h4 {
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 4px;
        }

        .empty-state p {
            color: var(--text-muted);
            font-size: 14px;
        }

    /* ═══════════════════════════════════════════════════ */
    /* PRINT STYLES                                       */
    /* ═══════════════════════════════════════════════════ */
    .print-header, .print-footer {
        display: none;
    }

    @@media print {
        body {
            background: #fff !important;
            margin: 0 !important;
            padding: 0 !important;
            font-size: 11px !important;
        }

        .content-wrapper {
            background: #fff !important;
            min-height: auto !important;
            overflow: visible !important;
        }
        /* Hide non-print elements */
        .page-hero,
        .stat-card,
        .filter-card,
        .pagination-wrapper,
        .action-btn-group,
        .btn-print,
        .btn-excel,
        .sidebar,
        .main-sidebar,
        .main-footer,
        .nav,
        .breadcrumb,
        .table-card .table-header,
        .content-header,
        #txtQuickSearch,
        div[style*="position:fixed"] {
            display: none !important;
        }

        .content {
            padding: 0 !important;
        }

        .table-card {
            border: none !important;
            box-shadow: none !important;
            border-radius: 0 !important;
            overflow: visible !important;
        }
        /* Print header */
        .print-header {
            display: block !important;
            text-align: center;
            padding: 16px 0 12px;
            border-bottom: 3px double var(--text-dark);
            margin-bottom: 12px;
        }

            .print-header h2 {
                font-weight: 800 !important;
                font-size: 18pt !important;
                color: var(--text-dark) !important;
                margin: 0 0 4px !important;
            }

