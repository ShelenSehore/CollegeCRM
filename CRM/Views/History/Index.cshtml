@section Scripts {
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var currentData = [];
        var currentPage = 1;
        var pageSize = 50;
        var checkedIds = {};
        var currentPrintMode = 'all';
        var isLoading = false;

        /* ═══ Result type classification helper ═══ */
        function classifyResult(val) {
            var r = (val || '').toUpperCase().trim();
            if (r === 'PASS')    return 'pass';
            if (r === 'FAIL')    return 'fail';
            if (r === 'ATKT')    return 'atkt';
            if (r === 'SUPPLE')  return 'supple';
            if (r === 'AWAITED') return 'awaited';
            return 'nores';
        }

        window.onload = function () {
            $("#ddlClass, #ddlYear, #ddlCourse, #ddlSession, #ddlSearchResult").change(function () {
                currentPage = 1;
                SearchStudent();
            });
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#printDdWrap').length) $('#printDdMenu').removeClass('show');
            });
            $(document).on('keydown', function (e) {
                if (e.key === 'Escape') closePrintPreview();
            });
            SearchStudent();
        };

        function showToast(message, type) {
            type = type || 'error';
            var icon = type === 'success' ? 'fa-circle-check' : 'fa-circle-exclamation';
            var container = document.getElementById('toastWrap');
            var el = document.createElement('div');
            el.className = 'toast-item' + (type === 'success' ? ' success' : '');
            el.innerHTML = '<i class="fas ' + icon + '"></i> ' + message;
            container.appendChild(el);
            setTimeout(function () { if (el.parentNode) el.remove(); }, 3200);
        }

        function animateNum(el, to, dur) {
            var from = parseInt(el.textContent) || 0;
            if (from === to) { el.textContent = to; return; }
            var start = null;
            var range = to - from;
            function step(ts) {
                if (!start) start = ts;
                var p = Math.min((ts - start) / dur, 1);
                var ease = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.round(ease * range + from);
                if (p < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
        }

        function resTag(val) {
            var cls = classifyResult(val);
            var r = (val || '').toUpperCase().trim();
            var label = r || 'N/A';
            var icons = { pass: 'fa-check', fail: 'fa-xmark', atkt: 'fa-exclamation', supple: 'fa-rotate', awaited: 'fa-hourglass-half', nores: 'fa-minus' };
            return '<span class="res-tag ' + cls + '"><i class="fas ' + (icons[cls] || 'fa-minus') + ' res-icon"></i>' + label + '</span>';
        }

        function courseBadge(course) {
            var c = (course || '').toLowerCase();
            var cls = 'def';
            if (c.includes('sci')) cls = 'sci';
            else if (c.includes('art')) cls = 'art';
            else if (c.includes('com') || c.includes('comm')) cls = 'com';
            return '<span class="c-course ' + cls + '">' + (course || '-') + '</span>';
        }

        function yearBadge(year) {
            var y = (year || '').toString().toLowerCase();
            var cls = 'def';
            if (y.includes('1') || y === 'i' || y === 'first') cls = 'y1';
            else if (y.includes('2') || y === 'ii' || y === 'second') cls = 'y2';
            else if (y.includes('3') || y === 'iii' || y === 'third') cls = 'y3';
            return '<span class="c-year ' + cls + '">' + (year || '-') + '</span>';
        }

        function resultRowClass(val) {
            return 'row-' + classifyResult(val);
        }

        function esc(str) {
            if (!str) return '';
            var div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        function DownloadExcel() {
            $("#hdnExcelName").val($("#txtSearch").val());
            $("#hdnExcelClass").val($('#ddlClass option:selected').text());
            $("#hdnExcelYear").val($('#ddlYear option:selected').text());
            $("#hdnExcelCourse").val($('#ddlCourse option:selected').text());
            $("#hdnExcelSession").val($('#ddlSession option:selected').text());
            $('#frmDownloadExcel').submit();
        }

        function Reset() {
            $("#txtSearch").val(''); $("#txtRollNumberSearch").val('');
            $('#ddlSession').val(''); $('#ddlClass').val(''); $('#ddlCourse').val('');
            $('#ddlYear').val(''); $('#ddlSearchResult').val('');
            checkedIds = {}; currentPage = 1;
            SearchStudent();
        }

        function SearchStudent() {
            if (isLoading) return;
            isLoading = true;
            $('#tableLoading').show();
            $('#emptyState').hide();

            $.post(BASE_URL + "/History/SearchOldStudentList", {
                name: $("#txtSearch").val(),
                classes: $('#ddlClass option:selected').text(),
                course: $('#ddlCourse option:selected').text(),
                year: $('#ddlYear option:selected').text(),
                session: $('#ddlSession option:selected').text(),
                rollNum: $("#txtRollNumberSearch").val(),
                result: $('#ddlSearchResult option:selected').text()
            }).done(function (res) {
                currentData = res.data || [];
                currentPage = 1;
                renderPage();
            }).fail(function () {
                showToast('Failed to load student data. Please try again.');
                currentData = [];
                renderPage();
            }).always(function () {
                isLoading = false;
                $('#tableLoading').hide();
            });
        }

        /* ═══ Compute stats for all 6 result types ═══ */
        function computeStats(data) {
            var counts = { pass: 0, fail: 0, atkt: 0, supple: 0, awaited: 0, nores: 0 };
            $.each(data, function (i, e) {
                counts[classifyResult(e.result)]++;
            });
            return counts;
        }

        function renderPage() {
            var total = currentData.length;
            var stats = computeStats(currentData);

            /* Animate stat numbers */
            animateNum(document.getElementById('statTotal'), total, 400);
            animateNum(document.getElementById('statPass'), stats.pass, 400);
            animateNum(document.getElementById('statFail'), stats.fail, 400);
            animateNum(document.getElementById('statAtkt'), stats.atkt, 400);
            animateNum(document.getElementById('statSupple'), stats.supple, 400);
            animateNum(document.getElementById('statAwaited'), stats.awaited, 400);
            animateNum(document.getElementById('statNull'), stats.nores, 400);

            /* Update bar segments */
            if (total > 0) {
                document.getElementById('barPass').style.width    = (stats.pass    / total * 100) + '%';
                document.getElementById('barFail').style.width    = (stats.fail    / total * 100) + '%';
                document.getElementById('barAtkt').style.width    = (stats.atkt    / total * 100) + '%';
                document.getElementById('barSupple').style.width  = (stats.supple  / total * 100) + '%';
                document.getElementById('barAwaited').style.width = (stats.awaited / total * 100) + '%';
                document.getElementById('barNores').style.width   = (stats.nores   / total * 100) + '%';
            } else {
                ['barPass','barFail','barAtkt','barSupple','barAwaited','barNores'].forEach(function(id) {
                    document.getElementById(id).style.width = '0%';
                });
            }

            var totalPages = Math.ceil(total / pageSize);
            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            var startIdx = (currentPage - 1) * pageSize;
            var endIdx = Math.min(startIdx + pageSize, total);
            var pageData = currentData.slice(startIdx, endIdx);

            var tbody = $("#tblStudentList tbody");
            tbody.empty();

            if (total === 0) { $("#emptyState").show(); $("#paginationFooter").hide(); }
            else { $("#emptyState").hide(); $("#paginationFooter").show(); }

            $.each(pageData, function (i, e) {
                var globalIdx = startIdx + i + 1;
                var isChecked = checkedIds[e.studentHistoryId] ? 'checked' : '';
                var rcls = resultRowClass(e.result);
                tbody.append(
                    '<tr class="' + rcls + '">' +
                    '<td class="c-idx">' + globalIdx + '</td>' +
                    '<td class="c-form">' + (e.admissionForm || '-') + '</td>' +
                    '<td><span class="c-session">' + (e.session || '-') + '</span></td>' +
                    '<td class="c-name">' + (e.studentName || '-') + '</td>' +
                    '<td class="c-father">' + (e.fatherName || '-') + '</td>' +
                    '<td>' + yearBadge(e.year) + '</td>' +
                    '<td class="c-meta">' + (e.classs || '-') + '</td>' +
                    '<td>' + courseBadge(e.course) + '</td>' +
                    '<td class="c-mobile">' + (e.mobileNo || '-') + '</td>' +
                    '<td>' + resTag(e.result) + '</td>' +
                    '<td><a class="btn-table-view" href="../History/View?id=' + e.studentHistoryId + '"><i class="fas fa-eye"></i> View</a></td>' +
                    '<td><label class="chk-wrap"><input type="checkbox" id="' + e.studentHistoryId + '" name="chkStudent" ' + isChecked + ' onchange="toggleCheck(\'' + e.studentHistoryId + '\', this.checked)"><span class="chk-box"></span></label></td>' +
                    '</tr>'
                );
            });

            updateSelectAllState();
            $('#tableCount').text(total + ' record' + (total !== 1 ? 's' : ''));
            var showStart = total > 0 ? startIdx + 1 : 0;
            $('#paginationInfo').html('Showing <strong>' + showStart + '</strong> - <strong>' + endIdx + '</strong> of <strong>' + total + '</strong>');
            renderPagination(totalPages);
        }

        function renderPagination(totalPages) {
            var container = $('#paginationControls'); container.empty();
            if (totalPages <= 1) { if (currentData.length === 0) $('#paginationFooter').hide(); return; }
            container.append('<button class="pg-btn nav-btn' + (currentPage === 1 ? ' disabled' : '') + '" onclick="goToPage(' + (currentPage - 1) + ')"><i class="fas fa-chevron-left"></i> Prev</button>');
            var pages = generatePageNumbers(currentPage, totalPages);
            for (var p = 0; p < pages.length; p++) {
                if (pages[p] === '...') container.append('<span class="pg-ellipsis">...</span>');
                else container.append('<button class="pg-btn' + (pages[p] === currentPage ? ' active' : '') + '" onclick="goToPage(' + pages[p] + ')">' + pages[p] + '</button>');
            }
            container.append('<button class="pg-btn nav-btn' + (currentPage === totalPages ? ' disabled' : '') + '" onclick="goToPage(' + (currentPage + 1) + ')">Next <i class="fas fa-chevron-right"></i></button>');
        }

        function generatePageNumbers(current, total) {
            var pages = [];
            if (total <= 7) { for (var i = 1; i <= total; i++) pages.push(i); }
            else {
                pages.push(1);
                if (current > 4) pages.push('...');
                var rs = Math.max(2, current - 1), re = Math.min(total - 1, current + 1);
                if (current <= 4) { rs = 2; re = 5; }
                if (current >= total - 3) { rs = total - 4; re = total - 1; }
                for (var j = rs; j <= re; j++) pages.push(j);
                if (current < total - 3) pages.push('...');
                pages.push(total);
            }
            return pages;
        }

        function goToPage(page) {
            var tp = Math.ceil(currentData.length / pageSize);
            if (page < 1 || page > tp) return;
            currentPage = page; renderPage();
            document.querySelector('.table-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function changePageSize(size) { pageSize = parseInt(size) || 50; currentPage = 1; renderPage(); }

        function toggleCheck(id, checked) { if (checked) checkedIds[id] = true; else delete checkedIds[id]; updateSelectAllState(); }

        function toggleSelectAll(el) {
            var si = (currentPage - 1) * pageSize;
            var ei = Math.min(si + pageSize, currentData.length);
            var pd = currentData.slice(si, ei);
            var ic = el.checked;
            $.each(pd, function (i, e) {
                var cb = document.getElementById(e.studentHistoryId);
                if (cb) cb.checked = ic;
                if (ic) checkedIds[e.studentHistoryId] = true; else delete checkedIds[e.studentHistoryId];
            });
        }

        function updateSelectAllState() {
            var si = (currentPage - 1) * pageSize;
            var ei = Math.min(si + pageSize, currentData.length);
            var pd = currentData.slice(si, ei);
            var all = pd.length > 0, some = false;
            $.each(pd, function (i, e) { if (checkedIds[e.studentHistoryId]) some = true; else all = false; });
            var sa = document.getElementById('chkSelectAll');
            if (sa) { sa.checked = all; sa.indeterminate = some && !all; }
        }

        function ResultDetailPotUp() {
            var ids = Object.keys(checkedIds);
            if (ids.length > 0) {
                $("#spnExamSession").text($('#ddlSession option:selected').text() || '-');
                $("#spnExamYear").text($('#ddlYear option:selected').text() || '-');
                $("#spnExamClass").text($('#ddlClass option:selected').text() || '-');
                $("#spnSelectedStudent").text(ids.length);
                $('#hdnSelected').val(ids.join(', ')); $('#ddlResult').val('');
                $("#modal-FillExamForm").modal("show");
            } else showToast('Please select at least one student.');
        }

        function SaveResultDetail() {
            var rv = $('#ddlResult option:selected').text();
            if (!rv || rv === 'Choose result') { showToast('Please select a result status.'); return; }
            var ids = $('#hdnSelected').val();
            if (!ids) { showToast('No students selected.'); return; }

            var $btn = $('.btn-m-save');
            $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Saving…');

            $.post(BASE_URL + "/History/SaveResult", { ids: ids, result: rv })
            .done(function () {
                $("#modal-FillExamForm").modal("hide");
                showToast('Result updated successfully for ' + ids.split(',').length + ' student(s)!', 'success');
                checkedIds = {};
                SearchStudent();
            })
            .fail(function () {
                showToast('Failed to save result. Please try again.');
            })
            .always(function () {
                $btn.prop('disabled', false).html('<i class="fas fa-check"></i> Save Result');
            });
        }

        /* ═══════════════════════════════════════════════════ */
        /* PRINT FUNCTIONALITY                                 */
        /* ═══════════════════════════════════════════════════ */

        function togglePrintDd(e) { e.stopPropagation(); $('#printDdMenu').toggleClass('show'); }

        function openPrintPreview(mode) {
            currentPrintMode = mode; $('#printDdMenu').removeClass('show');
            var printData = [];
            if (mode === 'all') {
                printData = currentData;
                $('#pohSub').text('All Records (' + printData.length + ')');
            } else if (mode === 'page') {
                var si = (currentPage - 1) * pageSize, ei = Math.min(si + pageSize, currentData.length);
                printData = currentData.slice(si, ei);
                $('#pohSub').text('Current Page (' + printData.length + ')');
            } else if (mode === 'selected') {
                var ids = Object.keys(checkedIds);
                if (ids.length === 0) { showToast('No students selected. Please select at least one.'); return; }
                printData = currentData.filter(function (e) { return checkedIds[e.studentHistoryId]; });
                $('#pohSub').text('Selected (' + printData.length + ')');
            }
            if (printData.length === 0) { showToast('No data available to print.'); return; }
            $('#printPreviewBody').html(buildPrintDoc(printData));
            $('#printOverlay').addClass('active');
            document.body.style.overflow = 'hidden';
        }

        function buildPrintDoc(data) {
            var now = new Date();
            var dateStr = now.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
            var timeStr = now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });

            var stats = computeStats(data);

            var filterParts = [];
            var sv = $('#ddlSession option:selected').text(), yv = $('#ddlYear option:selected').text();
            var cv = $('#ddlClass option:selected').text(), cov = $('#ddlCourse option:selected').text();
            var rv = $('#ddlSearchResult option:selected').text(), nv = $('#txtSearch').val();
            var rollv = $('#txtRollNumberSearch').val();
            if (sv && sv !== 'Select') filterParts.push({ key: 'Session', val: sv });
            if (yv && yv !== 'Select') filterParts.push({ key: 'Year', val: yv });
            if (cv && cv !== 'Select') filterParts.push({ key: 'Class', val: cv });
            if (cov && cov !== 'Select') filterParts.push({ key: 'Course', val: cov });
            if (rv && rv !== 'Select') filterParts.push({ key: 'Result', val: rv });
            if (nv) filterParts.push({ key: 'Name', val: nv });
            if (rollv) filterParts.push({ key: 'Roll No', val: rollv });

            var filterHtml = '';
            if (filterParts.length > 0) {
                filterHtml += '<div class="pd-filters"><span class="pf-label"><i class="fas fa-filter" style="margin-right:4px"></i>Filters:</span>';
                $.each(filterParts, function (i, f) { filterHtml += '<div class="pf-item"><span class="pf-key">' + f.key + ':</span> <span class="pf-val">' + esc(f.val) + '</span></div>'; });
                filterHtml += '</div>';
            }

            /* Stats row — 6 types */
            var statsHtml = '<div class="pd-stats-row">' +
                '<div class="pd-stat-chip"><span class="psc-dot pass"></span><span class="psc-num">' + stats.pass + '</span><span class="psc-lbl">Pass</span></div>' +
                '<div class="pd-stat-chip"><span class="psc-dot fail"></span><span class="psc-num">' + stats.fail + '</span><span class="psc-lbl">Fail</span></div>' +
                '<div class="pd-stat-chip"><span class="psc-dot atkt"></span><span class="psc-num">' + stats.atkt + '</span><span class="psc-lbl">ATKT</span></div>' +
                '<div class="pd-stat-chip"><span class="psc-dot supple"></span><span class="psc-num">' + stats.supple + '</span><span class="psc-lbl">Supple</span></div>' +
                '<div class="pd-stat-chip"><span class="psc-dot awaited"></span><span class="psc-num">' + stats.awaited + '</span><span class="psc-lbl">Awaited</span></div>' +
                '<div class="pd-stat-chip"><span class="psc-dot nores"></span><span class="psc-num">' + stats.nores + '</span><span class="psc-lbl">No Result</span></div></div>';

            var rowsHtml = '';
            $.each(data, function (index, el) {
                var cls = classifyResult(el.result);
                var rLabel = (el.result || '').toUpperCase().trim() || 'N/A';
                rowsHtml += '<tr>' +
                    '<td class="pd-idx">' + (index + 1) + '</td>' +
                    '<td class="pd-form">' + esc(el.admissionForm || '-') + '</td>' +
                    '<td><span class="pd-tag session">' + esc(el.session || '-') + '</span></td>' +
                    '<td class="pd-name">' + esc(el.studentName || '-') + '</td>' +
                    '<td>' + esc(el.fatherName || '-') + '</td>' +
                    '<td><span class="pd-tag year">' + esc(el.year || '-') + '</span></td>' +
                    '<td><span class="pd-tag class">' + esc(el.classs || '-') + '</span></td>' +
                    '<td><span class="pd-tag course">' + esc(el.course || '-') + '</span></td>' +
                    '<td class="pd-muted">' + esc(el.mobileNo || '-') + '</td>' +
                    '<td><span class="pd-res ' + cls + '">' + rLabel + '</span></td>' +
                    '</tr>';
            });

            return '<div class="pd-header"><div class="pdh-icon"><i class="fas fa-graduation-cap"></i></div>' +
                '<h2 class="pdh-title">Student History Report</h2>' +
                '<p class="pdh-sub">Generated on ' + dateStr + ' at ' + timeStr + '</p></div>' +
                filterHtml + statsHtml +
                '<table class="pd-table"><thead><tr><th>#</th><th>Form No</th><th>Session</th><th>Student</th><th>Father</th><th>Year</th><th>Subject</th><th>Course</th><th>Mobile</th><th>Result</th></tr></thead><tbody>' + rowsHtml + '</tbody></table>' +
                '<div class="pd-footer"><div class="pf-total">Total: ' + data.length + ' student' + (data.length !== 1 ? 's' : '') + '</div><div>Printed from CRM System &bull; ' + dateStr + '</div></div>';
        }

        function closePrintPreview() {
            $('#printOverlay').removeClass('active');
            document.body.style.overflow = '';
        }

        function executePrint() {
            var printContent = document.getElementById('printPreviewBody').innerHTML;
            var pw = window.open('', '_blank', 'width=1000,height=700');
            pw.document.write('<!DOCTYPE html><html><head><title>Print - Student History</title>');
            pw.document.write('<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">');
            pw.document.write('<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">');
            pw.document.write('<style>' + getPrintCSS() + '</style></head><body>');
            pw.document.write(printContent);
            pw.document.write('</body></html>');
            pw.document.close();
            pw.onload = function () { setTimeout(function () { pw.focus(); pw.print(); }, 400); };
        }

        function getPrintCSS() {
            return `
                @@page { size: A4 landscape; margin: 12mm 10mm; }
                * { margin: 0; padding: 0; box-sizing: border-box; }
                body { font-family: 'DM Sans','Segoe UI',Tahoma,sans-serif; color: #1a1612; font-size: 11px; line-height: 1.4; -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
                .pd-header { text-align: center; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 3px double #e8e2da; }
                .pdh-icon { font-size: 1.6rem; color: #059669; margin-bottom: 4px; }
                .pdh-title { font-family: 'Space Grotesk',sans-serif; font-size: 16px; font-weight: 700; color: #1a1612; margin: 0 0 2px; }
                .pdh-sub { font-size: 10px; color: #8c8279; }
                .pd-filters { display: flex; flex-wrap: wrap; gap: 6px 16px; margin-bottom: 10px; padding: 8px 12px; background: #f5f0eb; border-radius: 6px; border: 1px solid #e8e2da; font-size: 10px; align-items: center; }
                .pf-label { font-weight: 700; color: #0d9488; font-size: 10px; margin-right: 6px; }
                .pf-item .pf-key { font-weight: 700; text-transform: uppercase; letter-spacing: .3px; color: #b5ada5; font-size: 8px; }
                .pf-item .pf-val { font-weight: 600; color: #1a1612; font-size: 10px; }
                .pd-stats-row { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
                .pd-stat-chip { display: flex; align-items: center; gap: 5px; padding: 5px 10px; border-radius: 6px; border: 1px solid #e8e2da; background: #faf8f5; }
                .psc-dot { width: 7px; height: 7px; border-radius: 2px; }
                .psc-dot.pass { background: #059669; } .psc-dot.fail { background: #e85d4a; }
                .psc-dot.atkt { background: #d97706; } .psc-dot.supple { background: #0d9488; }
                .psc-dot.awaited { background: #e11d48; } .psc-dot.nores { background: #4f46e5; }
                .psc-num { font-family: 'Space Grotesk',sans-serif; font-weight: 700; font-size: 11px; color: #1a1612; }
                .psc-lbl { font-size: 7px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #8c8279; }
                .pd-table { width: 100%; border-collapse: collapse; font-size: 10px; }
                .pd-table thead th { background: #059669 !important; color: #fff !important; font-size: 8.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; padding: 7px 6px; border: 1px solid #047857; white-space: nowrap; }
                .pd-table tbody td { padding: 5px 6px; border: 1px solid #e8e2da; color: #3d3530; vertical-align: middle; }
                .pd-table tbody tr:nth-child(even) { background: #faf8f5; }
                .pd-table tbody tr:nth-child(odd) { background: #fff; }
                .pd-idx { text-align: center; font-weight: 700; color: #8c8279; font-size: 9px; }
                .pd-form { font-weight: 700; color: #0d9488; font-family: 'Space Grotesk',sans-serif; }
                .pd-name { font-weight: 700; color: #1a1612; }
                .pd-muted { color: #8c8279; }
                .pd-tag { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 8px; font-weight: 600; }
                .pd-tag.session { background: #e0e7ff; color: #4f46e5; }
                .pd-tag.year { background: #f5f3ff; color: #6d28d9; }
                .pd-tag.class { background: #fce7f3; color: #e11d48; }
                .pd-tag.course { background: #d1fae5; color: #047857; }
                .pd-res { display: inline-flex; align-items: center; gap: 3px; padding: 2px 8px; border-radius: 10px; font-size: 8px; font-weight: 800; letter-spacing: .3px; }
                .pd-res.pass { background: #d1fae5; color: #059669; }
                .pd-res.fail { background: #fee2e2; color: #e85d4a; }
                .pd-res.atkt { background: #fef3c7; color: #d97706; }
                .pd-res.supple { background: #ccfbf1; color: #0d9488; }
                .pd-res.awaited { background: #fce7f3; color: #e11d48; }
                .pd-res.nores { background: #e0e7ff; color: #4f46e5; }
                .pd-footer { margin-top: 14px; padding-top: 10px; border-top: 1px solid #e8e2da; display: flex; justify-content: space-between; align-items: center; font-size: 9px; color: #b5ada5; }
                .pf-total { font-weight: 700; color: #047857; font-size: 11px; font-family: 'Space Grotesk',sans-serif; }
            `;
        }
    </script>
}