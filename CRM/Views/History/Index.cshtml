<!-- Toast 容器 -->
<div class="toast-wrap" id="toastWrap"></div>

<!-- Modal -->
<div class="modal fade" id="modal-FillExamForm">
    <div class="modal-dialog" style="max-width:580px;">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title"><i class="fas fa-clipboard-check"></i> Result Detail</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="modal-grid">
                    <div class="modal-cell">
                        <div class="mc-label">Selected</div>
                        <div class="mc-value accent" id="spnSelectedStudent">0</div>
                        <input type="hidden" id="hdnSelected" />
                    </div>
                    <div class="modal-cell">
                        <div class="mc-label">Session</div>
                        <div class="mc-value" id="spnExamSession">-</div>
                    </div>
                    <div class="modal-cell">
                        <div class="mc-label">Year</div>
                        <div class="mc-value" id="spnExamYear">-</div>
                    </div>
                    <div class="modal-cell">
                        <div class="mc-label">Class</div>
                        <div class="mc-value" id="spnExamClass">-</div>
                    </div>
                    <div class="modal-cell" style="grid-column: span 2;">
                        <div class="mc-label">Assign Result</div>
                        <select id="ddlResult" class="form-control">
                            <option value="">Choose result</option>
