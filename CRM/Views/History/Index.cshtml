@section Scripts {
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var currentData = [];

        window.onload = function () {
            $("#ddlClass, #ddlYear, #ddlCourse, #ddlSession, #ddlSearchResult").change(function () {
                SearchStudent();
            });
            SearchStudent();
        };

        /* ── Toast ── */
        function showToast(message, type) {
            type = type || 'error';
            var icon = type === 'success' ? 'fa-circle-check' : 'fa-circle-exclamation';
            var container = document.getElementById('toastWrap');
            var el = document.createElement('div');
            el.className = 'toast-item' + (type === 'success' ? ' success' : '');
            el.innerHTML = '<i class="fas ' + icon + '"></i> ' + message;
            container.appendChild(el);
            setTimeout(function () { el.remove(); }, 3200);
        }

        /* ── 数字动画 ── */
        function animateNum(el, to, dur) {
            var from = parseInt(el.textContent) || 0;
            if (from === to) { el.textContent = to; return; }
            var start = null;
            var range = to - from;
            function step(ts) {
                if (!start) start = ts;
                var p = Math.min((ts - start) / dur, 1);
                var ease = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.round(ease * range + from);
                if (p < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
        }

        /* ── 结果标签 ── */
        function resTag(val) {
            var r = (val || '').toUpperCase().trim();
            var cls = 'nores', icon = 'fa-minus', label = r || 'N/A';
            if (r === 'PASS') { cls = 'pass'; icon = 'fa-check'; }
            else if (r === 'FAIL') { cls = 'fail'; icon = 'fa-xmark'; }
            else if (r === 'ATKT') { cls = 'atkt'; icon = 'fa-exclamation'; }
            return '<span class="res-tag ' + cls + '"><i class="fas ' + icon + ' res-icon"></i>' + label + '</span>';
        }

        /* ── 下载 ── */
        function DownloadExcel() {
            $("#hdnExcelName").val($("#txtSearch").val());
            $("#hdnExcelClass").val($('#ddlClass option:selected').text());
            $("#hdnExcelYear").val($('#ddlYear option:selected').text());
            $("#hdnExcelCourse").val($('#ddlCourse option:selected').text());
            $("#hdnExcelSession").val($('#ddlSession option:selected').text());
            $('#frmDownloadExcel').submit();
        }

        /* ── 重置 ── */
        function Reset() {
            $("#txtSearch").val('');
            $("#txtRollNumberSearch").val('');
            $('#ddlSession').val('');
            $('#ddlClass').val('');
            $('#ddlCourse').val('');
            $('#ddlYear').val('');
            $('#ddlSearchResult').val('');
            SearchStudent();
        }

        /* ── 搜索 ── */
        function SearchStudent() {
            $.post(BASE_URL + "/History/SearchOldStudentList", {
                name: $("#txtSearch").val(),
                classes: $('#ddlClass option:selected').text(),
                course: $('#ddlCourse option:selected').text(),
                year: $('#ddlYear option:selected').text(),
                session: $('#ddlSession option:selected').text(),
                rollNum: $("#txtRollNumberSearch").val(),
                result: $('#ddlSearchResult option:selected').text()
            }, function (res) {
                TableData(res);
            });
        }

        /* ── 渲染表格 ── */
        function TableData(tableData) {
            var tbody = $("#tblStudentList tbody");
            tbody.empty();
            currentData = tableData.data || [];
            var total = currentData.length;
            var pc = 0, fc = 0, ac = 0, nc = 0;

            if (total === 0) {
                $("#emptyState").show();
            } else {
                $("#emptyState").hide();
            }

            $.each(currentData, function (i, e) {
                var r = (e.result || '').toUpperCase().trim();
                if (r === 'PASS') pc++;
                else if (r === 'FAIL') fc++;
                else if (r === 'ATKT') ac++;
                else nc++;

                tbody.append(
                    '<tr>' +
                    '<td class="c-idx">' + (i + 1) + '</td>' +
                    '<td class="c-form">' + (e.admissionForm || '-') + '</td>' +
                    '<td><span class="c-session">' + (e.session || '-') + '</span></td>' +
                    '<td class="c-name">' + (e.studentName || '-') + '</td>' +
                    '<td class="c-father">' + (e.fatherName || '-') + '</td>' +
                    '<td class="c-meta">' + (e.year || '-') + '</td>' +
                    '<td class="c-meta">' + (e.classs || '-') + '</td>' +
                    '<td class="c-meta">' + (e.course || '-') + '</td>' +
                    '<td class="c-mobile">' + (e.mobileNo || '-') + '</td>' +
                    '<td>' + resTag(e.result) + '</td>' +
                    '<td><a class="btn-table-view" href="../History/View?id=' + e.studentHistoryId + '"><i class="fas fa-eye"></i> View</a></td>' +
                    '<td><label class="chk-wrap"><input type="checkbox" id="' + e.studentHistoryId + '" name="chkStudent"><span class="chk-box"></span></label></td>' +
                    '</tr>'
                );
            });

            // 统计动画
            animateNum(document.getElementById('statTotal'), total, 400);
            animateNum(document.getElementById('statPass'), pc, 400);
            animateNum(document.getElementById('statFail'), fc, 400);
            animateNum(document.getElementById('statAtkt'), ac, 400);
            animateNum(document.getElementById('statNull'), nc, 400);

            // 比例条
            if (total > 0) {
                document.getElementById('barPass').style.width = (pc / total * 100) + '%';
                document.getElementById('barFail').style.width = (fc / total * 100) + '%';
                document.getElementById('barAtkt').style.width = (ac / total * 100) + '%';
                document.getElementById('barNores').style.width = (nc / total * 100) + '%';
            } else {
                document.getElementById('barPass').style.width = '0%';
                document.getElementById('barFail').style.width = '0%';
                document.getElementById('barAtkt').style.width = '0%';
                document.getElementById('barNores').style.width = '0%';
            }

            $('#tableCount').text(total + ' record' + (total !== 1 ? 's' : ''));
        }

        /* ── 结果弹窗 ── */
        function ResultDetailPotUp() {
            var ids = $('input[name="chkStudent"]:checked').map(function () { return this.id; }).get();
            if (ids.length > 0) {
                $("#spnExamSession").text($('#ddlSession option:selected').text() || '-');
                $("#spnExamYear").text($('#ddlYear option:selected').text() || '-');
                $("#spnExamClass").text($('#ddlClass option:selected').text() || '-');
                $("#spnSelectedStudent").text(ids.length);
                $('#hdnSelected').val(ids.join(', '));
                $('#ddlResult').val('');
                $("#modal-FillExamForm").modal("show");
            } else {
                showToast('Please select at least one student.');
            }
        }

        function SaveResultDetail() {
            var rv = $('#ddlResult option:selected').text();
            if (!rv || rv === 'Choose result') {
                showToast('Please select a result status.');
                return;
            }
            $.post(BASE_URL + "/History/SaveResult", {
                ids: $("#hdnSelected").val(),
                result: rv
            }, function () {
                $("#modal-FillExamForm").modal("hide");
                showToast('Result saved successfully!', 'success');
                SearchStudent();
            });
        }

        /* 保留原有函数 */
        function FillExamForm() {
            var ids = $('input[name="chkStudent"]:checked').map(function () { return this.id; }).get();
            if (ids.length > 0) {
                $("#spnExamSession").text($('#ddlSession option:selected').text());
                $("#spnExamYear").text($('#ddlYear option:selected').text());
                $("#spnExamClass").text($('#ddlClass option:selected').text());
                $("#spnSelectedStudent").text(ids.length);
                $('#hdnSelected').val(ids.join(', '));
                $("#modal-FillExamForm").modal("show");
            } else {
                showToast('Please select at least one student.');
            }
        }

        function SaveExamForm() {
            $.post(BASE_URL + "/Student/SaveExamFormFilled", { ids: $("#hdnSelected").val() }, function () {
                $("#modal-FillExamForm").modal("hide");
            });
        }
    </script>
}