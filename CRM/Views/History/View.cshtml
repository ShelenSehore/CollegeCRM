@section Scripts {
    <script type="text/javascript">
        // INSERT
        var BASE_URL = "@baseUrl";
        var Toast;

        window.onload = function () {
            Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 50000
            });
        };

        function Alert(icon, title, className) {
            Toast.fire({
                icon: icon,
                title: title,
                class: className,
            });
        }

        function SavePersonalDetail() {
            var IsValidate = true;

            if (!validateField("#txtStudentName", "Student name required")) IsValidate = false;
            if (!validateField("#txtFatherName", "Father name required")) IsValidate = false;
            if (!validateField("#txtMotherName", "Mother name required")) IsValidate = false;
            if (!validateField("#txtMobileNo", "Mobile number required", "mobile")) IsValidate = false;
            if (!validateField("#txtFatherMobileNo", "Father mobile required", "mobile")) IsValidate = false;
            if (!validateField("#txtDOB", "Date of birth required")) IsValidate = false;
            if (!validateField("#txtAadhaarNo", "Aadhaar number required")) IsValidate = false;
            if (!validateField("#txtAddress", "Address required")) IsValidate = false;
            if (!validateField("#ddlGender", "Select gender", "dropdown")) IsValidate = false;
            if (!validateField("#ddlMinority", "Select minority", "dropdown")) IsValidate = false;
            if (!validateField("#ddlCaset", "Select caste", "dropdown")) IsValidate = false;
            if (!validateField("#ddlTC", "Select TC", "dropdown")) IsValidate = false;
            if (!validateField("#ddlPH", "Select PH", "dropdown")) IsValidate = false;

            if (!IsValidate) return;

            var varid = $("#hdnStudentID").val();
            var varStudentName = $("#txtStudentName").val();
            var varFatherName = $("#txtFatherName").val();
            var varMotherName = $("#txtMotherName").val();
            var varMobileNo = $("#txtMobileNo").val();
            var varDOB = $("#txtDOB").val();
            var varFatherMobileNo = $("#txtFatherMobileNo").val();
            var varGender = $('#ddlGender option:selected').text();
            var varMinority = $('#ddlMinority option:selected').text();
            var varCaset = $('#ddlCaset option:selected').text();
            var varAdhaarNo = $('#txtAadhaarNo').val();
            var varAbcNo = $('#txtAbcNo').val();
            var varSamagraID = $("#txtSamagraID").val();
            var varAddress = $("#txtAddress").val();
            var varTC = $('#ddlTC option:selected').text();
            var varPH = $('#ddlPH option:selected').text();

            if (IsValidate) {
                $.post(BASE_URL + "/History/SaveStudentHistory", {
                    id: varid,
                    varStudentName: varStudentName,
                    varFatherName: varFatherName,
                    varMotherName: varMotherName,
                    varMobileNo: varMobileNo,
                    varDOB: varDOB,
                    varFatherMobileNo: varFatherMobileNo,
                    varGender: varGender,
                    varMinority: varMinority,
                    varCaset: varCaset,
                    varAbcNo: varAbcNo,
                    varSamagraID: varSamagraID,
                    varAddress: varAddress,
                    varTC: varTC,
                    varPH: varPH,
                    varAdhaarNo: varAdhaarNo
                },
                function (res) {
                    $("#modal-Personal").modal("hide");
                    Alert('success', 'Personal Detail Saved Successfully', 'bg-success');
                    location.reload(true);
                });
            }
        }

        function validateField(selector, message, type = "") {
            var value = $(selector).val();
            var errorId = selector.replace('#', '') + "Error";

            if (type === "dropdown") {
                if (value === "" || value === "0" || value === null || value === "Select") {
                    $(selector).addClass("is-invalid");
                    if ($("#" + errorId).length == 0) {
                        $(selector).after('<span id="' + errorId + '" class="error invalid-feedback">' + message + '</span>');
                    }
                    return false;
                } else {
                    $(selector).removeClass("is-invalid");
                    $("#" + errorId).remove();
                    return true;
                }
            }

            if (value === "") {
                $(selector).addClass("is-invalid");
                if ($("#" + errorId).length == 0) {
                    $(selector).after('<span id="' + errorId + '" class="error invalid-feedback">' + message + '</span>');
                }
                return false;
            }

            if (type === "mobile") {
                var mobilePattern = /^[0-9]{10}$/;
                if (!mobilePattern.test(value)) {
                    $(selector).addClass("is-invalid");
                    if ($("#" + errorId).length == 0) {
                        $(selector).after('<span id="' + errorId + '" class="error invalid-feedback">Enter valid 10 digit mobile number</span>');
                    }
                    return false;
                }
            }

            $(selector).removeClass("is-invalid");
            $("#" + errorId).remove();
            return true;
        }

        function SaveCollegeDetail() {
            var IsValidate = true;
            if (!validateField("#txtAdmissionFormNo", "AdmissionFormNo required")) IsValidate = false;
            if (!validateField("#txtEnRollNo", "EnRollNo required")) IsValidate = false;
            if (!validateField("#txtAdmissionDate", "AdmissionDate required")) IsValidate = false;
            if (!validateField("#txtRollNo", "RollNo required")) IsValidate = false;
            if (!validateField("#txtSchoolarNo", "SchoolarNo required")) IsValidate = false;
            if (!validateField("#txtSubCode", "SubCode required")) IsValidate = false;
            if (!validateField("#ddlNewOld", "Select NewOld", "dropdown")) IsValidate = false;
            if (!validateField("#ddlMedium", "Select Medium", "dropdown")) IsValidate = false;
            if (!validateField("#ddlRegEx", "Select RegEx", "dropdown")) IsValidate = false;

            if (!IsValidate) return;

            var varid = $("#hdnStudentID").val();
