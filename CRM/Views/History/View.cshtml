        function SaveAcadmicDetail() {
            var IsValidate = true;
            if (!validateField("#txtAcademicYear", "Academic Year required")) IsValidate = false;
            if (!validateField("#txtSchoolName", "School Name required")) IsValidate = false;
            if (!validateField("#txtBoard", "Board required")) IsValidate = false;
            if (!validateField("#txtMaxMark", "Max Mark required")) IsValidate = false;
            if (!validateField("#txtObtMark", "ObtMark required")) IsValidate = false;
            if (!validateField("#txtParcent", "Percent required")) IsValidate = false;
            if (!validateField("#txtAcademicAdmissionFormNo", "Admission FormNo required")) IsValidate = false;
            if (!validateField("#ddlAcadmicSession", "Select Academic Session", "dropdown")) IsValidate = false;
            if (!validateField("#ddlAcadmicClass", "Select Academic Class", "dropdown")) IsValidate = false;
            if (!validateField("#ddlAcadmicCourse", "Select Academic Course", "dropdown")) IsValidate = false;
            if (!validateField("#ddlResult", "Select Result", "dropdown")) IsValidate = false;

            if (!IsValidate) return;

            var varid = $("#hdnStudentID").val();
            var varAcademicYear = $('#txtAcademicYear').val();
            var varAcadmicSession = $('#ddlAcadmicSession option:selected').text();
            var varAcadmicClass = $('#ddlAcadmicClass option:selected').text();
            var varAcadmicCourse = $('#ddlAcadmicCourse option:selected').text();
            var varSchoolName = $('#txtSchoolName').val();
            var varBoard = $('#txtBoard').val();
            var varMaxMark = $('#txtMaxMark').val();
            var varObtMark = $('#txtObtMark').val();
            var varResult = $('#ddlResult option:selected').text();
            var varParcent = $('#txtParcent').val();
            var varAdmissionFormNo = $('#txtAcademicAdmissionFormNo').val();

            if (IsValidate) {
                $.post(BASE_URL + "/Student/UpdateCollegeDetail", {
                    id: varid,
                    varAcademicYear: varAcademicYear,
                    varAcadmicSession: varAcadmicSession,
                    varAcadmicClass: varAcadmicClass,
                    varAcadmicCourse: varAcadmicCourse,
                    varSchoolName: varSchoolName,
                    varBoard: varBoard,
                    varMaxMark: varMaxMark,
                    varObtMark: varObtMark,
                    varResult: varResult,
                    varParcent: varParcent,
                    varAdmissionFormNo: varAdmissionFormNo
                },
                function (res) {
                    $("#modal-Academic").modal("hide");
                    Alert('success', 'Academic Detail Saved Successfully', 'bg-success');
                    location.reload(true);
                });
            }
        }

        // DELETE
        function deleteAcadmicDetail(id) {
            Swal.fire({
                title: 'Delete Record?',
                text: 'This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e11d48',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, delete it',
                background: '#1e1b4b',
                color: '#e2e8f0'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post(BASE_URL + "/Student/Delete", { id: id },
                        function (res) {
                            Alert('success', 'Deleted Successfully', 'bg-success');
                            location.reload(true);
                        }
                    );
                }
            });
        }
    </script>
