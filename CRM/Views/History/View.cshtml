@model CRM.ModelsForView.StudentViewModel

@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    ViewData["Title"] = "Registration";
    var baseUrl = ViewBag.BaseUrl;

    <style type="text/css">
        /* ── Base Reset & Fonts ── */
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

        .content-wrapper {
            background: linear-gradient(135deg, #0f0c29 0%, #1a1a3e 40%, #24243e 100%) !important;
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
        }

        .content-header {
            background: transparent !important;
        }

        /* ── Breadcrumb ── */
        .breadcrumb {
            background: rgba(255,255,255,0.08) !important;
            backdrop-filter: blur(12px);
            border-radius: 12px !important;
            padding: 10px 20px !important;
        }
        .breadcrumb-item a {
            color: #a78bfa !important;
            font-weight: 600;
            text-decoration: none;
        }
        .breadcrumb-item a:hover { color: #c4b5fd !important; }
        .breadcrumb-item.active a {
            color: #f9a8d4 !important;
        }
        .breadcrumb-item + .breadcrumb-item::before {
            color: rgba(255,255,255,0.3) !important;
        }

        /* ── Profile Card ── */
        .profile-card {
            background: linear-gradient(160deg, #6366f1, #8b5cf6, #a855f7) !important;
            border: none !important;
            border-radius: 20px !important;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(99,102,241,0.35), 0 0 0 1px rgba(255,255,255,0.08);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .profile-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 48px rgba(99,102,241,0.5), 0 0 0 1px rgba(255,255,255,0.12);
        }
        .profile-card .card-body {
            background: transparent !important;
        }
        .profile-card .profile-username {
            color: #fff !important;
            font-weight: 800;
            font-size: 1.3rem;
            letter-spacing: -0.3px;
        }
        .profile-card .text-muted {
            color: rgba(255,255,255,0.75) !important;
            font-weight: 500;
        }
        .profile-card .tc-badge {
            background: linear-gradient(135deg, #f43f5e, #e11d48);
            color: #fff;
            padding: 6px 16px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            animation: pulse-glow 2s ease-in-out infinite;
        }
        @@keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 8px rgba(244,63,94,0.4); }
            50% { box-shadow: 0 0 20px rgba(244,63,94,0.7); }
        }
        .img-circle {
            border-radius: 50% !important;
            border: 4px solid rgba(255,255,255,0.3) !important;
            width: 120px !important;
            height: 120px !important;
            object-fit: cover;
            box-shadow: 0 4px 24px rgba(0,0,0,0.3);
            transition: transform 0.4s;
        }
        .img-circle:hover { transform: scale(1.08); }
        .exam-badge {
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            padding: 6px 14px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
            margin-top: 6px;
        }

        /* ── Education Card ── */
        .education-card {
            background: linear-gradient(160deg, #0ea5e9, #06b6d4, #14b8a6) !important;
            border: none !important;
            border-radius: 20px !important;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(14,165,233,0.3), 0 0 0 1px rgba(255,255,255,0.08);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .education-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 48px rgba(14,165,233,0.45), 0 0 0 1px rgba(255,255,255,0.12);
        }
        .education-card .card-header {
            background: rgba(255,255,255,0.12) !important;
            border-bottom: 1px solid rgba(255,255,255,0.15) !important;
            color: #fff !important;
            font-weight: 700;
            font-size: 1rem;
        }
        .education-card .card-title {
            color: #fff !important;
            font-weight: 700;
        }
        .education-card .list-group-item {
            background: transparent !important;
            border-color: rgba(255,255,255,0.1) !important;
            color: #fff !important;
            padding: 10px 16px;
        }
        .education-card .list-group-item b {
            color: rgba(255,255,255,0.7) !important;
            font-weight: 600;
            font-size: 13px;
        }
        .education-card .list-group-item a {
            color: #fef08a !important;
            font-weight: 700;
        }

        /* ── Main Tab Card ── */
        .main-card {
            background: rgba(255,255,255,0.05) !important;
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.08) !important;
            border-radius: 20px !important;
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            overflow: hidden;
        }
        .main-card .card-header {
            background: rgba(255,255,255,0.04) !important;
            border-bottom: 1px solid rgba(255,255,255,0.08) !important;
            padding: 16px 24px !important;
        }

        /* ── Colorful Nav Pills ── */
        .main-card .nav-pills .nav-link {
            border-radius: 12px !important;
            padding: 10px 22px !important;
            font-weight: 600;
            font-size: 14px;
            color: rgba(255,255,255,0.5) !important;
            transition: all 0.3s ease;
            margin-right: 6px;
            background: transparent !important;
            border: 1px solid transparent;
        }
        .main-card .nav-pills .nav-link:hover {
            color: #fff !important;
            background: rgba(255,255,255,0.08) !important;
        }
        .main-card .nav-pills .nav-link.active {
            background: linear-gradient(135deg, #f97316, #ef4444) !important;
            color: #fff !important;
            box-shadow: 0 4px 16px rgba(249,115,22,0.4);
            border: none;
        }
        .main-card .nav-pills .nav-link[href="#College"] {
            /* No special - just active/hover */
        }
        .main-card .nav-pills .nav-link[href="#College"].active {
            background: linear-gradient(135deg, #06b6d4, #3b82f6) !important;
            box-shadow: 0 4px 16px rgba(6,182,212,0.4);
        }
        .main-card .nav-pills .nav-link[href="#Academic"].active {
            background: linear-gradient(135deg, #10b981, #059669) !important;
            box-shadow: 0 4px 16px rgba(16,185,129,0.4);
        }
        .main-card .nav-pills .nav-link[href="#Document"].active {
            background: linear-gradient(135deg, #a855f7, #7c3aed) !important;
            box-shadow: 0 4px 16px rgba(168,85,247,0.4);
        }

        /* ── Form Fields ── */
        .PersonalDetailLable {
            font-weight: 600;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: rgba(255,255,255,0.45) !important;
            margin-bottom: 4px;
            display: block;
        }
        .PersonalDetailText {
            background: rgba(255,255,255,0.06) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 10px !important;
            color: #e0e7ff !important;
            font-weight: 500 !important;
            font-size: 14px !important;
            padding: 10px 14px !important;
            transition: all 0.3s;
        }
        .PersonalDetailText:focus {
            border-color: #818cf8 !important;
            box-shadow: 0 0 0 3px rgba(129,140,248,0.2) !important;
            background: rgba(255,255,255,0.1) !important;
        }
        textarea.PersonalDetailText {
            min-height: 60px !important;
            resize: none;
        }

        /* ── Tables ── */
        .custom-table {
            background: rgba(255,255,255,0.03) !important;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.06);
        }
        .custom-table thead th {
            background: linear-gradient(135deg, rgba(249,115,22,0.15), rgba(239,68,68,0.1)) !important;
            color: #fdba74 !important;
            font-weight: 700;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            border-bottom: 1px solid rgba(255,255,255,0.08) !important;
            padding: 14px 16px;
        }
        .custom-table tbody td {
            color: #cbd5e1 !important;
            border-bottom: 1px solid rgba(255,255,255,0.04) !important;
            padding: 12px 16px;
            font-weight: 500;
            vertical-align: middle;
        }
        .custom-table tbody tr:hover {
            background: rgba(255,255,255,0.04) !important;
        }
        .custom-table tbody tr:last-child td {
            border-bottom: none !important;
        }

        /* ── Action Buttons ── */
        .btn-edit {
            background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
            border: none !important;
            color: #fff !important;
            font-weight: 600;
            font-size: 13px;
            border-radius: 10px !important;
            padding: 8px 20px !important;
            transition: all 0.3s;
            box-shadow: 0 4px 14px rgba(99,102,241,0.3);
        }
        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(99,102,241,0.5);
            color: #fff !important;
        }
        .btn-add {
            background: linear-gradient(135deg, #10b981, #059669) !important;
            border: none !important;
            color: #fff !important;
            font-weight: 600;
            font-size: 13px;
            border-radius: 10px !important;
            padding: 8px 20px !important;
            transition: all 0.3s;
            box-shadow: 0 4px 14px rgba(16,185,129,0.3);
        }
        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16,185,129,0.5);
            color: #fff !important;
        }
        .btn-delete {
            background: linear-gradient(135deg, #f43f5e, #e11d48) !important;
            border: none !important;
            color: #fff !important;
            border-radius: 8px !important;
            padding: 5px 12px !important;
            font-size: 12px;
            transition: all 0.3s;
        }
        .btn-delete:hover {
            transform: scale(1.08);
            box-shadow: 0 4px 16px rgba(244,63,94,0.4);
        }

        /* ── Document Images ── */
        .doc-thumb {
            width: 60px;
            height: 60px;
            border-radius: 10px;
            object-fit: cover;
            border: 2px solid rgba(168,85,247,0.3);
            transition: transform 0.3s;
        }
        .doc-thumb:hover {
            transform: scale(1.15);
            border-color: #a855f7;
        }

        /* ── Modals ── */
        .modal-content {
            background: linear-gradient(160deg, #1e1b4b, #1e1e3f, #1a1a3e) !important;
            border: 1px solid rgba(255,255,255,0.08) !important;
            border-radius: 20px !important;
            color: #e2e8f0;
            box-shadow: 0 24px 80px rgba(0,0,0,0.6);
        }
        .modal-header {
            border-bottom: 1px solid rgba(255,255,255,0.08) !important;
            padding: 20px 28px !important;
        }
        .modal-title {
            color: #fff !important;
            font-weight: 800;
            font-size: 1.2rem;
            background: linear-gradient(135deg, #6366f1, #a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .modal-header .close {
            color: rgba(255,255,255,0.4) !important;
            font-size: 28px;
            text-shadow: none;
            transition: color 0.2s;
        }
        .modal-header .close:hover { color: #f43f5e !important; }
        .modal-body { padding: 24px 28px !important; }
        .modal-body label {
            color: rgba(255,255,255,0.55) !important;
            font-weight: 600;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .modal-body .form-control {
            background: rgba(255,255,255,0.06) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 10px !important;
            color: #e0e7ff !important;
            font-weight: 500;
            padding: 10px 14px !important;
            transition: all 0.3s;
        }
        .modal-body .form-control:focus {
            border-color: #818cf8 !important;
            box-shadow: 0 0 0 3px rgba(129,140,248,0.2) !important;
            background: rgba(255,255,255,0.1) !important;
            color: #fff !important;
        }
        .modal-body select.form-control option {
            background: #1e1b4b !important;
            color: #e2e8f0 !important;
        }
        .modal-footer {
            border-top: 1px solid rgba(255,255,255,0.08) !important;
            padding: 16px 28px !important;
        }
        .modal-footer .btn-default {
            background: rgba(255,255,255,0.06) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            color: #94a3b8 !important;
            border-radius: 10px;
            font-weight: 600;
        }
        .modal-footer .btn-default:hover {
            background: rgba(255,255,255,0.12) !important;
            color: #fff !important;
        }
        .modal-footer .btn-success {
            background: linear-gradient(135deg, #10b981, #059669) !important;
            border: none !important;
            border-radius: 10px;
            font-weight: 700;
            padding: 8px 24px;
            box-shadow: 0 4px 14px rgba(16,185,129,0.3);
        }
        .modal-footer .btn-success:hover {
            box-shadow: 0 6px 24px rgba(16,185,129,0.5);
            transform: translateY(-1px);
        }
        .modal-footer .btn-primary {
            background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
            border: none !important;
            border-radius: 10px;
            font-weight: 700;
            padding: 8px 24px;
            box-shadow: 0 4px 14px rgba(99,102,241,0.3);
        }
        .modal-footer .btn-primary:hover {
            box-shadow: 0 6px 24px rgba(99,102,241,0.5);
            transform: translateY(-1px);
        }

        /* ── Decorative blobs ── */
        .blob-1 {
            position: fixed;
            top: -150px;
            right: -150px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(99,102,241,0.15), transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
            animation: float-blob 8s ease-in-out infinite;
        }
        .blob-2 {
            position: fixed;
            bottom: -200px;
            left: -100px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(14,165,233,0.1), transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
            animation: float-blob 10s ease-in-out infinite reverse;
        }
        .blob-3 {
            position: fixed;
            top: 40%;
            left: 30%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(168,85,247,0.08), transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
            animation: float-blob 12s ease-in-out infinite;
        }
        @@keyframes float-blob {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(30px, -20px) scale(1.05); }
            66% { transform: translate(-20px, 15px) scale(0.95); }
        }

        /* ── Section label chips ── */
        .section-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            padding: 4px 14px;
            font-size: 12px;
            font-weight: 600;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 16px;
        }

        /* ── Validation ── */
        .is-invalid {
            border-color: #f43f5e !important;
            box-shadow: 0 0 0 3px rgba(244,63,94,0.15) !important;
        }
        .invalid-feedback {
            color: #fb7185 !important;
            font-size: 12px;
            font-weight: 500;
        }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb {
            background: rgba(99,102,241,0.3);
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(99,102,241,0.5);
        }

        /* ── Back link ── */
        .back-link {
            color: rgba(255,255,255,0.4);
            font-weight: 600;
            font-size: 13px;
            text-decoration: none;
            transition: color 0.2s;
        }
        .back-link:hover { color: #a78bfa; }

        /* ── Row spacing inside tabs ── */
        .tab-pane .row > [class*="col-md"] {
            margin-bottom: 12px;
        }
    </style>
}

<!-- Decorative background blobs -->
<div class="blob-1"></div>
<div class="blob-2"></div>
<div class="blob-3"></div>

<div class="content-wrapper" style="position:relative; z-index:1;">
    <!-- Content Header -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item"><a href="~/Student/List"><i class="fas fa-arrow-left mr-1"></i> List</a></li>
                        <li class="breadcrumb-item active"><a href="#">Student Detail</a></li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">

                <!-- ═══════════ LEFT COLUMN ═══════════ -->
                <div class="col-md-3">

                    <!-- Profile Card -->
                    <div class="card card-primary card-outline profile-card mb-4">
                        <div class="card-body box-profile text-center">
                            @if (Model.TC == "ISSUE")
                            {
                                <div class="mb-3">
                                    <span class="tc-badge">
                                        <i class="fas fa-star"></i> TC Issued
                                    </span>
                                </div>
                            }
                            <div class="text-center mb-3">
                                <img class="profile-user-img img-fluid img-circle"
                                     src="@Model.Photo"
                                     alt="User profile picture">
                            </div>
                            <input type="hidden" value="@Model.Id" id="hdnStudentID" />
                            <h3 class="profile-username">@Model.StudentName</h3>
                            <p class="text-muted mb-1"><i class="fas fa-user-tie mr-1"></i> @Model.FatherName</p>
                            <p class="text-muted mb-1"><i class="fas fa-phone mr-1"></i> @Model.MobileNoOne</p>
                            <span class="exam-badge"><i class="fas fa-file-alt mr-1"></i> Exam Form: @Model.ExamFormSubmited</span>
                        </div>
                    </div>

                    <!-- Education Card -->
                    <div class="card card-primary education-card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fas fa-graduation-cap mr-1"></i> Education</h3>
                        </div>
                        <div class="card-body">
                            <ul class="list-group list-group-unbordered mb-3">
                                <li class="list-group-item">
                                    <b>Session</b> <a class="float-right">@Model.Session</a>
                                </li>
                                <li class="list-group-item">
                                    <b>Class</b> <a class="float-right">@Model.Class</a>
                                </li>
                                <li class="list-group-item">
                                    <b>Course</b> <a class="float-right">@Model.Course</a>
                                </li>
                                <li class="list-group-item">
                                    <b>Year</b> <a class="float-right">@Model.Year</a>
                                </li>
                            </ul>
                        </div>
                    </div>

                </div>

                <!-- ═══════════ RIGHT COLUMN ═══════════ -->
                <div class="col-md-9">
                    <div class="card main-card">
                        <div class="card-header p-2">
                            <ul class="nav nav-pills" id="detailTabs">
                                <li class="nav-item"><a class="nav-link active" href="#Personal" data-toggle="tab"><i class="fas fa-user mr-1"></i> Personal</a></li>
                                <li class="nav-item"><a class="nav-link" href="#College" data-toggle="tab"><i class="fas fa-university mr-1"></i> College</a></li>
                                <li class="nav-item"><a class="nav-link" href="#Academic" data-toggle="tab"><i class="fas fa-book-open mr-1"></i> Academic</a></li>
                                <li class="nav-item"><a class="nav-link" href="#Document" data-toggle="tab"><i class="fas fa-folder-open mr-1"></i> Document</a></li>
                            </ul>
                        </div>
                        <div class="card-body">
                            <div class="tab-content">

                                <!-- ──── PERSONAL TAB ──── -->
                                <div class="active tab-pane" id="Personal">
                                    <div class="section-chip"><i class="fas fa-id-card"></i> Personal Information</div>
                                    <div class="row">

                                        <div class="col-md-3">
                                            <label class="PersonalDetailLable">Name</label>
                                            <input asp-for="StudentName" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="PersonalDetailLable">Father Name</label>
                                            <input asp-for="FatherName" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="PersonalDetailLable">Mother Name</label>
                                            <input asp-for="MotherName" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="PersonalDetailLable">Mobile No</label>
                                            <input asp-for="MobileNoOne" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="PersonalDetailLable">DOB</label>
                                            <input asp-for="DOB" type="date" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="PersonalDetailLable">Father Mobile</label>
                                            <input asp-for="FatherMobileNo" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="PersonalDetailLable">Gender</label>
                                            <input asp-for="Gender" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="PersonalDetailLable">Minority</label>
                                            <input asp-for="Minority" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="PersonalDetailLable">Caste</label>
                                            <input asp-for="Caste" readonly="readonly" class="form-control PersonalDetailText" />
                                        </div>
                                        <div class="col-md-2">
