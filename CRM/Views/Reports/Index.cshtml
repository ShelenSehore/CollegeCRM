@model CRM.ModelsForView.StudentListView
@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    ViewData["Title"] = "List";
    var baseUrl = ViewBag.BaseUrl;
}

<style>
    :root {
        --gradient-primary: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a855f7 100%);
        --gradient-emerald: linear-gradient(135deg, #059669 0%, #10b981 50%, #34d399 100%);
        --gradient-amber: linear-gradient(135deg, #d97706 0%, #f59e0b 50%, #fbbf24 100%);
        --gradient-rose: linear-gradient(135deg, #e11d48 0%, #f43f5e 50%, #fb7185 100%);
        --gradient-cyan: linear-gradient(135deg, #0891b2 0%, #06b6d4 50%, #22d3ee 100%);
        --gradient-orange: linear-gradient(135deg, #ea580c 0%, #f97316 50%, #fb923c 100%);
        --bg-deep: #0f0f1a;
        --bg-card: #1a1a2e;
        --bg-card-alt: #16213e;
        --bg-input: #1e1e36;
        --border-glow: rgba(139, 92, 246, 0.25);
        --text-primary: #f1f5f9;
        --text-muted: #94a3b8;
        --accent-purple: #8b5cf6;
        --accent-cyan: #22d3ee;
    }

    .content-wrapper {
        background: var(--bg-deep) !important;
        min-height: 100vh;
    }

    .content-header {
        background: transparent !important;
    }

    /* ── Breadcrumb ── */
    .breadcrumb {
        background: rgba(139, 92, 246, 0.1) !important;
        border: 1px solid var(--border-glow);
        border-radius: 10px;
        padding: 10px 18px !important;
    }
    .breadcrumb-item a {
        color: var(--accent-cyan) !important;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
    }
    .breadcrumb-item.active a {
        color: var(--accent-purple) !important;
    }
    .breadcrumb-item + .breadcrumb-item::before {
        color: var(--text-muted) !important;
    }

    /* ── Main Card ── */
    .main-card {
        background: var(--bg-card) !important;
        border: 1px solid var(--border-glow);
        border-radius: 20px !important;
        box-shadow: 0 0 60px rgba(139, 92, 246, 0.08), 0 8px 32px rgba(0,0,0,0.4) !important;
        overflow: hidden;
    }
    .main-card .card-body {
        padding: 2rem !important;
    }

    /* ── Filter Fieldset ── */
    .scheduler-border {
        border: 1px solid var(--border-glow) !important;
        border-radius: 16px !important;
        padding: 1.5rem 1.5rem 1rem !important;
        background: linear-gradient(145deg, rgba(99, 102, 241, 0.06), rgba(139, 92, 246, 0.03));
        position: relative;
    }
    .scheduler-border legend {
        background: var(--bg-card) !important;
        color: var(--accent-cyan) !important;
        font-size: 0.95rem !important;
        font-weight: 700 !important;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0 16px !important;
        width: auto !important;
        border: none !important;
        margin-bottom: 0.8rem !important;
    }
    .scheduler-border legend::before {
        content: '▼ ';
        font-size: 0.6rem;
        vertical-align: middle;
    }

    /* ── Form Controls ── */
    .scheduler-border label {
        color: var(--text-muted) !important;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        margin-bottom: 4px;
    }
    .scheduler-border .form-control {
        background: var(--bg-input) !important;
        border: 1px solid rgba(139, 92, 246, 0.2) !important;
        color: var(--text-primary) !important;
        border-radius: 10px !important;
        padding: 8px 14px;
        font-size: 0.88rem;
        transition: all 0.3s ease;
    }
    .scheduler-border .form-control:focus {
        border-color: var(--accent-purple) !important;
        box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.15), 0 0 20px rgba(139, 92, 246, 0.1) !important;
        outline: none;
    }
    .scheduler-border .form-control::placeholder {
        color: #4a5568 !important;
    }
    .scheduler-border select.form-control option {
        background: var(--bg-input);
        color: var(--text-primary);
    }

    /* ── Date Picker Append ── */
    .input-group-append .input-group-text {
        background: var(--accent-purple) !important;
        border: 1px solid var(--accent-purple) !important;
        color: #fff !important;
        border-radius: 0 10px 10px 0 !important;
        cursor: pointer;
    }
    .input-group.date .form-control {
        border-radius: 10px 0 0 10px !important;
    }

    /* ── Buttons ── */
    .btn-glow-search {
        background: var(--gradient-primary) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 700;
        letter-spacing: 0.5px;
        border-radius: 12px !important;
        padding: 9px 28px !important;
        box-shadow: 0 4px 20px rgba(139, 92, 246, 0.35);
        transition: all 0.3s ease;
    }
    .btn-glow-search:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 30px rgba(139, 92, 246, 0.5);
    }
    .btn-glow-reset {
        background: rgba(139, 92, 246, 0.12) !important;
        border: 1px solid rgba(139, 92, 246, 0.3) !important;
        color: var(--accent-purple) !important;
        font-weight: 700;
        letter-spacing: 0.5px;
        border-radius: 12px !important;
        padding: 9px 28px !important;
        transition: all 0.3s ease;
    }
    .btn-glow-reset:hover {
        background: rgba(139, 92, 246, 0.22) !important;
        transform: translateY(-2px);
    }
    .btn-glow-excel {
        background: var(--gradient-emerald) !important;
        border: none !important;
        color: #fff !important;
        font-weight: 700;
        border-radius: 12px !important;
        padding: 9px 22px !important;
        box-shadow: 0 4px 20px rgba(16, 185, 129, 0.35);
        transition: all 0.3s ease;
        float: right;
    }
    .btn-glow-excel:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 30px rgba(16, 185, 129, 0.5);
    }

    /* ── Stat Cards ── */
    .stat-card {
        border-radius: 18px !important;
        padding: 1.2rem 1.4rem !important;
        position: relative;
        overflow: hidden;
        border: none !important;
        min-height: 105px;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-4px);
    }
    .stat-card::before {
        content: '';
        position: absolute;
        top: -30%;
        right: -20%;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: rgba(255,255,255,0.06);
    }
    .stat-card::after {
        content: '';
        position: absolute;
        bottom: -40%;
        left: -10%;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
    }
    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #fff;
        flex-shrink: 0;
        position: relative;
        z-index: 1;
    }
    .stat-body {
        position: relative;
        z-index: 1;
    }
    .stat-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.75);
        margin-bottom: 2px;
    }
    .stat-value {
        font-size: 1.55rem;
        font-weight: 800;
        color: #fff;
        line-height: 1.2;
    }

    .stat-card.card-students {
        background: var(--gradient-primary) !important;
        box-shadow: 0 8px 30px rgba(99, 102, 241, 0.3);
    }
    .stat-card.card-students .stat-icon { background: rgba(255,255,255,0.2); }

    .stat-card.card-amount {
        background: var(--gradient-emerald) !important;
        box-shadow: 0 8px 30px rgba(16, 185, 129, 0.3);
    }
    .stat-card.card-amount .stat-icon { background: rgba(255,255,255,0.2); }

    .stat-card.card-head {
        background: var(--gradient-amber) !important;
        box-shadow: 0 8px 30px rgba(245, 158, 11, 0.3);
    }
    .stat-card.card-head .stat-icon { background: rgba(255,255,255,0.2); }

    .stat-card.card-date {
        background: var(--gradient-rose) !important;
        box-shadow: 0 8px 30px rgba(244, 63, 94, 0.3);
    }
    .stat-card.card-date .stat-icon { background: rgba(255,255,255,0.2); }

    /* ── Table ── */
    .table-wrapper {
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border-glow);
    }
    #tblStudentList {
        width: 100% !important;
        background: var(--bg-card-alt) !important;
    }
    #tblStudentList thead tr {
        background: linear-gradient(135deg, #1e1b4b, #312e81) !important;
    }
    #tblStudentList thead th {
        background: transparent !important;
        color: var(--accent-cyan) !important;
        font-size: 0.76rem !important;
        font-weight: 700 !important;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 14px 12px !important;
        border-bottom: 2px solid var(--accent-purple) !important;
        white-space: nowrap;
    }
    #tblStudentList tbody tr {
        background: var(--bg-card) !important;
        transition: background 0.2s ease;
    }
    #tblStudentList tbody tr:nth-child(even) {
        background: rgba(139, 92, 246, 0.04) !important;
    }
    #tblStudentList tbody tr:hover {
        background: rgba(139, 92, 246, 0.1) !important;
    }
    #tblStudentList tbody td {
        color: var(--text-primary) !important;
        font-size: 0.84rem;
        padding: 10px 12px !important;
        border-color: rgba(139, 92, 246, 0.1) !important;
        white-space: nowrap;
    }
    #tblStudentList tbody td:first-child {
        color: var(--accent-purple) !important;
        font-weight: 700;
    }

    /* ── Loader ── */
    .overlay {
        background: rgba(15, 15, 26, 0.8) !important;
        border-radius: 16px;
        z-index: 10;
    }
    .overlay i {
        color: var(--accent-purple) !important;
    }

    /* ── Data Tables overrides ── */
    .dataTables_wrapper .dataTables_length select {
        background: var(--bg-input) !important;
        color: var(--text-primary) !important;
        border: 1px solid var(--border-glow) !important;
        border-radius: 8px;
    }
    .dataTables_wrapper .dataTables_filter input {
        background: var(--bg-input) !important;
        color: var(--text-primary) !important;
        border: 1px solid var(--border-glow) !important;
        border-radius: 8px;
        padding: 4px 12px;
    }
    .dataTables_wrapper .dataTables_info {
        color: var(--text-muted) !important;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button {
        color: var(--accent-cyan) !important;
        border: 1px solid var(--border-glow) !important;
        border-radius: 8px !important;
        background: var(--bg-input) !important;
        margin: 0 3px;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background: var(--gradient-primary) !important;
        color: #fff !important;
        border: none !important;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
        background: var(--accent-purple) !important;
        color: #fff !important;
        border: none !important;
    }

    /* ── Section Title ── */
    .section-title {
        font-size: 1.6rem;
        font-weight: 900;
        color: var(--text-primary);
        letter-spacing: -0.5px;
        margin-bottom: 1.5rem;
        position: relative;
        padding-left: 18px;
    }
    .section-title::before {
        content: '';
        position: absolute;
        left: 0;
        top: 4px;
        bottom: 4px;
        width: 5px;
        border-radius: 4px;
        background: var(--gradient-primary);
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg-deep); }
    ::-webkit-scrollbar-thumb {
        background: var(--accent-purple);
        border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
        background: var(--accent-cyan);
    }

    /* ── Dot separator ── */
    .dot-spacer {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        padding-top: 28px;
    }
    .dot-spacer span {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent-purple);
        opacity: 0.4;
    }

    /* ── Pulse animation for stat icons ── */
    @@keyframes pulse-glow {
        0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.2); }
        50% { box-shadow: 0 0 12px 4px rgba(255,255,255,0.15); }
    }
    .stat-icon {
        animation: pulse-glow 3s ease-in-out infinite;
    }

    /* ── Fade-in ── */
    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(18px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .stat-card { animation: fadeSlideUp 0.6s ease-out both; }
    .stat-card:nth-child(1) { animation-delay: 0.05s; }
    .stat-card:nth-child(2) { animation-delay: 0.12s; }
    .stat-card:nth-child(3) { animation-delay: 0.19s; }
    .stat-card:nth-child(4) { animation-delay: 0.26s; }

    @@media (prefers-reduced-motion: reduce) {
        .stat-card, .stat-icon { animation: none !important; }
        .btn-glow-search:hover, .btn-glow-reset:hover, .btn-glow-excel:hover,
        .stat-card:hover { transform: none !important; }
    }
</style>

<div class="content-wrapper">
    <!-- Content Header -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item"><a href="#">Reports</a></li>
                        <li class="breadcrumb-item active"><a href="#">Transaction</a></li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="card main-card">
            <div class="card-body">
                <div class="dataTables_wrapper dt-bootstrap4">

                    <h2 class="section-title">Transaction Report</h2>

                    <fieldset class="scheduler-border">
                        <legend class="scheduler-border">Filters</legend>

                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Head</label>
                                    <select id="ddlHead" class="form-control">
                                        <option>Select</option>
                                        <option>Admission fees</option>
                                        <option>Identity card fees</option>
                                        <option>Tuition fees</option>
                                        <option>Annual function fees</option>
                                        <option>College development fees</option>
                                        <option>Activity fees</option>
                                        <option>University Exam. fees</option>
                                        <option>Bravery activity fees</option>
                                        <option>Departmental library fees</option>
                                        <option>Late fees</option>
                                        <option>Maintenance fees</option>
                                        <option>Establishment & college development fees</option>
                                        <option>Subject transfer fees</option>
                                        <option>Caution money</option>
                                        <option>Laboratory fees</option>
                                        <option>Transfer certificate fees</option>
                                        <option>College exam fees</option>
                                        <option>Medical fees</option>
                                        <option>Poor student fund</option>
                                        <option>Forwarding fees</option>
                                        <option>Enrollment Fees</option>
                                        <option>Eligibility Fees</option>
                                        <option>On line portal Fees</option>
                                        <option>Other fees</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Payment Mode</label>
                                    <select id="ddlPaymentMode" class="form-control">
                                        <option>Select</option>
                                        <option>Cash</option>
                                        <option>Online</option>
                                        <option>Check</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Receipt No</label>
                                    <input id="txtReciptNo" class="form-control" type="search" placeholder="Search" aria-label="Search">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>From Date</label>
                                    <div class="input-group date" id="reservationdate" data-target-input="nearest">
                                        <input id="txtFromDate" type="text" class="form-control datetimepicker-input" data-target="#reservationdate" />
                                        <div class="input-group-append" data-target="#reservationdate" data-toggle="datetimepicker">
                                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>To Date</label>
                                    <div class="input-group date" id="reservationEnddate" data-target-input="nearest">
                                        <input id="txtToDate" type="text" class="form-control datetimepicker-input" data-target="#reservationEnddate" />
                                        <div class="input-group-append" data-target="#reservationEnddate" data-toggle="datetimepicker">
                                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Name</label>
                                    <input id="txtSearch" class="form-control" type="search" placeholder="Search" aria-label="Search">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Session</label>
                                    <select id="ddlSession" asp-items="Model.SessionList" class="form-control"><option>Select</option></select>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Year</label>
                                    <select id="ddlYear" asp-items="Model.YearList" class="form-control"><option>Select</option></select>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Class</label>
                                    <select id="ddlClass" asp-items="Model.ClassList" class="form-control"><option>Select</option></select>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Course</label>
                                    <select id="ddlCourse" asp-items="Model.SubjectList" class="form-control"><option>Select</option></select>
                                </div>
                            </div>
                        </div>

                        <div class="row" style="margin-bottom:5px !important">
                            <div class="col-md-3">
                                <div class="dot-spacer">
                                    <span></span><span></span><span></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button type="button" id="btnSearch" onclick="SearchStudent()" class="btn btn-glow-search"><i class="fas fa-search"></i> Search</button>
                            </div>
                            <div class="col-md-2">
                                <button type="reset" class="btn btn-glow-reset" onclick="Reset()"><i class="fas fa-rotate-right"></i> Reset</button>
                            </div>
                            <div class="col-md-3"></div>
                            <div class="col-md-2">
                                <form id="frmDownloadExcel"></form>
                                <button type="submit" id="btnDownloadExcel" onclick="DownloadExcel()" class="btn btn-glow-excel"><i class="fas fa-file-excel"></i> Export</button>
                            </div>
                        </div>
                    </fieldset>

                    <!-- Stat Cards -->
                    <div class="row" style="margin-top:1.5rem;">
                        <div class="col-md-3 col-sm-6 col-12">
                            <div class="stat-card card-students">
                                <div class="stat-icon">
                                    <i class="fas fa-user-graduate"></i>
                                </div>
                                <div class="stat-body">
                                    <div class="stat-label">Total Students</div>
                                    <div id="spnTotalStudent" class="stat-value">000</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6 col-12">
                            <div class="stat-card card-amount">
                                <div class="stat-icon">
                                    <i class="fas fa-indian-rupee-sign"></i>
                                </div>
                                <div class="stat-body">
                                    <div class="stat-label">Amount</div>
                                    <div id="spnAmount" class="stat-value">00</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6 col-12">
                            <div class="stat-card card-head">
                                <div class="stat-icon">
                                    <i class="fas fa-layer-group"></i>
                                </div>
                                <div class="stat-body">
                                    <div class="stat-label">Head</div>
                                    <div id="spnHead" class="stat-value" style="font-size:1.1rem;">No Select</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6 col-12">
                            <div class="stat-card card-date">
                                <div class="stat-icon">
                                    <i class="fas fa-calendar-days"></i>
                                </div>
                                <div class="stat-body">
                                    <div class="stat-label">From Date</div>
                                    <div id="spnFromTo" class="stat-value" style="font-size:1.1rem;">00</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="row" style="margin-top:1.5rem;">
                        <div class="col-sm-12">
                            <div id="Loader" class="overlay" style="display:none;"><i class="fas fa-2x fa-sync-alt fa-spin"></i></div>

                            <div class="table-wrapper">
                                <table id="tblStudentList" class="table table-bordered table-striped dataTable dtr-inline">
                                    <thead>
                                        <tr role="row">
                                            <th style="width:10px">#</th>
                                            <th>Head</th>
                                            <th>Student Name</th>
                                            <th>Father Name</th>
                                            <th>Mobile No</th>
                                            <th>New/Old</th>
                                            <th>RegEx</th>
                                            <th>Session</th>
                                            <th>Year</th>
                                            <th>Class</th>
                                            <th>Course</th>
                                            <th>Admission Form No</th>
                                            <th>Create Date</th>
                                            <th>Created By</th>
                                            <th>Transaction No</th>
                                            <th>Payment Mode</th>
                                            <th>Amount</th>
                                            <th>Receipt No</th>
                                            <th>Receipt Book No</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var studentTable;

        window.onload = function () {
            $('#reservationdate, #reservationEnddate').datetimepicker({
                format: 'DD/MM/YYYY'
            });
            SearchStudent();
        };

        function DownloadExcel() {
            $('form#frmDownloadExcel').submit();
        }

        function Reset() {
            $('#ddlHead option:selected').prop("selected", false);
            $('#ddlPaymentMode option:selected').prop("selected", false);
            $("#txtReciptNo").val('');
            $("#txtFromDate").val('');
            $("#txtToDate").val('');
            $("#txtSearch").val('');
            $('#ddlSession option:selected').prop("selected", false);
            $('#ddlYear option:selected').prop("selected", false);
            $('#ddlClass option:selected').prop("selected", false);
            $('#ddlCourse option:selected').prop("selected", false);
            SearchStudent();
        }

        function SearchStudent() {
            var varHad = $('#ddlHead option:selected').text();
            var varPaymentMode = $('#ddlPaymentMode option:selected').text();
            var varReciptNo = $("#txtReciptNo").val();
            var varFromDate = $("#txtFromDate").val();
            var varToDate = $("#txtToDate").val();
            var name = $("#txtSearch").val();
            var varSession = $('#ddlSession option:selected').text();
            var varYear = $('#ddlYear option:selected').text();
            var varClass = $('#ddlClass option:selected').text();
            var varCourse = $('#ddlCourse option:selected').text();
            $("#Loader").show();

            $.post(BASE_URL + "/Reports/GetStudentList", {
                had: varHad,
                paymentMode: varPaymentMode,
                reciptNo: varReciptNo,
                fromDate: varFromDate,
                toDate: varToDate,
                name: name,
                session: varSession,
                year: varYear,
                classes: varClass,
                course: varCourse
            },
            function (res) {
                TableData(res);
            });

            $("#spnHead").text(varHad);
            $("#spnFromTo").text(varFromDate);
        }

        function TableData(tableData) {
            $("#tblStudentList tbody").empty();
            var varTotalStudent = 0;
            var varAmount = 0;

            $.each(tableData.data, function (index, element) {
                $("#tblStudentList").append("<tr><td>" + index + "</td><td>" + element.head + "</td><td>" + element.studentName + "</td><td>" + element.fatherName +
                    "</td><td>" + element.mobileNoOne + "</td><td>" + element.newOld + "</td><td>" + element.regEx +
                    "</td><td>" + element.session + "</td><td>" + element.year +
                    "</td><td>" + element.class + "</td><td>" + element.course +
                    "</td><td>" + element.admissionFormNo + "</td><td>" + element.createDateTime +
                    "</td><td>" + element.CreatedBy + "</td><td>" + element.transactionNo +
                    "</td><td>" + element.paymentMode + "</td><td>" + element.amount +
                    "</td><td>" + element.recNumber + "</td><td>" + element.recBookNo +
                    "</td><td>" + element.studentId +
                    "</td></tr>");
                varTotalStudent = varTotalStudent + 1;
                varAmount = varAmount + element.amount;
            });

            $("#spnTotalStudent").text(varTotalStudent);
            $("#spnAmount").text(varAmount);
            $("#Loader").hide();
        }

        function ExcelDownload() {
            var name = $("#txtSearch").val();
            var varClass = $('#ddlClass option:selected').text();
            var varSubject = $('#ddlSubject option:selected').text();
            var varCourse = $('#ddlCourse option:selected').text();
            var varRegPvt = $('#ddlRegPvt option:selected').text();

            $.post(BASE_URL + "/Student/DownloadExcel", {
                name: name,
                classes: varClass,
                subject: varSubject,
                course: varCourse,
                regPvt: varRegPvt
            },
            function (res) {
                TableData(res);
            });
        }
    </script>
}