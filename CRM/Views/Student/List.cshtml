                                <label>Form No</label>
                                <div class="search-with-icon">
                                    <i class="fas fa-hashtag"></i>
                                    <input id="txtFormNumberSearch" class="form-control" type="number" placeholder="Enter form no" aria-label="Form No">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Enroll No</label>
                                <div class="search-with-icon">
                                    <i class="fas fa-hashtag"></i>
                                    <input id="txtEnrolloSearch" class="form-control" type="number" placeholder="Enter enroll no" aria-label="Enroll No">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Exam Form Submit </label>
                                <div class="search-with-icon">
                                    <select id="ddlExamFormSubmited" class="form-control">
                                        <option value="">Select</option>
                                        <option value="YES">YES</option>
                                        <option value="NO">NO</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>TC Submit </label>
                                <div class="search-with-icon">
                                    <select id="ddlTCSubmited" class="form-control">
                                        <option value="">Select</option>
                                        <option value="YES">YES</option>
                                        <option value="NO">NO</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Student Name</label>
                                <div class="search-with-icon">
                                    <i class="fas fa-search"></i>
                                    <input id="txtSearch" class="form-control" type="search" placeholder="Type name to search..." aria-label="Search">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="filter-actions">
                        <button type="button" id="btnSearch" onclick="SearchStudent()" class="btn-search">
                            <i class="fas fa-search"></i> Search
                        </button>
                        <button type="reset" class="btn-reset" onclick="Reset()">
                            <i class="fas fa-rotate-left"></i> Reset
                        </button>

                        <div class="action-sep"></div>

                        <div style="position:relative;display:inline-block">
                            <div class="btn-action-group">
                                <button type="button" class="btn-action-main" onclick="FillExamForm()">
                                    <i class="fas fa-clipboard-list"></i> Action
                                </button>
                                <button type="button" class="btn-action-toggle" data-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-chevron-down"></i>
                                </button>
                            </div>
                            <div class="dropdown-menu" role="menu">
                                <a class="btn btn-default" onclick="FillExamForm()">
                                    <i class="fas fa-file-alt"></i> Fill Exam Form
                                </a>
                            </div>
                        </div>

                        <div class="action-sep"></div>

                        <form id="frmDownloadExcel" method="post" action="DownloadExcel" style="display:inline">
                            <input type="hidden" name="hdnExcelSession" id="hdnExcelSession" />
                            <input type="hidden" name="hdnExcelClass" id="hdnExcelClass" />
                            <input type="hidden" name="hdnExcelCourse" id="hdnExcelCourse" />
                            <input type="hidden" name="hdnExcelYear" id="hdnExcelYear" />
                            <input type="hidden" name="hdnExcelName" id="hdnExcelName" />
                        </form>
                        <button type="button" id="btnDownloadExcel" onclick="DownloadExcel()" class="btn-excel">
                            <i class="fas fa-file-excel"></i> Excel
                        </button>

                        <div class="action-sep"></div>

                        <div class="print-dropdown-wrapper" id="printDropdownWrapper">
                            <button type="button" class="btn-print" onclick="togglePrintDropdown(event)">
                                <i class="fas fa-print"></i> Print
                            </button>
                            <div class="print-dropdown-menu" id="printDropdownMenu">
                                <button class="print-option" onclick="openPrintPreview('all')">
                                    <i class="fas fa-list"></i>
                                    <div>
                                        <div>All Records</div>
                                        <div class="po-desc">Print all filtered students</div>
                                    </div>
                                </button>
                                <button class="print-option" onclick="openPrintPreview('page')">
                                    <i class="fas fa-file-alt"></i>
                                    <div>
                                        <div>Current Page</div>
                                        <div class="po-desc">Print only the visible page</div>
                                    </div>
                                </button>
                                <button class="print-option" onclick="openPrintPreview('selected')">
                                    <i class="fas fa-check-square"></i>
                                    <div>
                                        <div>Selected Only</div>
                                        <div class="po-desc">Print checked students</div>
                                    </div>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== TABLE PANEL ===== -->
                <div class="table-panel">
                    <div class="table-top-strip"></div>
                    <div class="table-header-bar">
                        <div class="thb-left">
                            <i class="fas fa-table-list thb-icon"></i>
                            <h3 class="thb-title">Students</h3>
                            <span class="thb-count" id="tableCount">0 records</span>
                            <span class="select-all-page" id="selectAllPage" onclick="ToggleSelectAllOnPage()">
                                <i class="far fa-check-square"></i> Select all on this page
                            </span>
                        </div>
                        <div class="page-size-select">
                            <span>Per page</span>
                            <select id="pageSizeSelect" onchange="ChangePageSize(this.value)">
                                <option value="25">25</option>
                                <option value="50" selected>50</option>
                                <option value="100">100</option>
                                <option value="200">200</option>
                                <option value="300">300</option>
                                <option value="400">400</option>
                                <option value="500">500</option>
                            </select>
                        </div>
                    </div>

                    <div class="table-scroll">
                        <table class="custom-table" id="tblStudentList">
                            <thead>
                                <tr>
                                    <th style="width:50px;text-align:center">#</th>
                                    <th>Form No</th>
                                    <th>Roll No</th>
                                    <th>TC Submit</th>
                                    <th>Exam Form</th>
                                    <th>Session</th>
                                    <th>Student Name</th>
                                    <th>Father Name</th>
                                    <th>Year</th>
                                    <th>Class</th>
                                    <th>Course</th>
                                    <th>Mobile</th>
                                    <th style="width:90px;text-align:center">View</th>
                                    <th style="width:55px;text-align:center">Select</th>
                                </tr>
                            </thead>
                            <tbody id="tableBody"></tbody>
                        </table>
                    </div>
                    <div class="pagination-wrapper" id="paginationWrapper" style="display:none;">
                        <div class="pagination-info" id="paginationInfo"></div>
                        <div class="pagination-controls" id="paginationControls"></div>
                    </div>
                </div>

            </div>
    </section>
</div>

<!-- ===== PRINT PREVIEW OVERLAY ===== -->
<div class="print-preview-overlay" id="printPreviewOverlay">
    <div class="print-preview-container">
        <div class="print-preview-toolbar">
            <div class="ppt-left">
                <i class="fas fa-print ppt-icon"></i>
                <div>
                    <div class="ppt-title">Print Preview</div>
                    <div class="ppt-subtitle" id="pptSubtitle">All Records</div>
                </div>
            </div>
            <div class="ppt-actions">
                <button type="button" class="ppt-btn ppt-btn-print" onclick="executePrint()">
                    <i class="fas fa-print"></i> Print
                </button>
                <button type="button" class="ppt-btn ppt-btn-close" onclick="closePrintPreview()">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
        <div class="print-preview-body" id="printPreviewBody"></div>
    </div>
</div>

<!-- ===== EXAM FORM MODAL ===== -->
<div class="modal fade" id="modal-FillExamForm">
    <div class="modal-dialog" style="max-width:680px">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">
                    <i class="fas fa-file-signature"></i> Fill Exam Form
                </h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p style="font-size:.85rem;color:var(--clr-text-muted);margin-bottom:16px">
                    Confirm the details below before submitting the exam form for selected students.
                </p>
                <div class="modal-info-grid">
                    <div class="modal-info-card students">
                        <div class="mic-icon"><i class="fas fa-user-check"></i></div>
                        <div class="mic-label">Selected</div>
                        <div class="mic-value" id="spnSelectedStudent">0</div>
                        <input type="hidden" id="hdnSelected" />
                    </div>
                    <div class="modal-info-card session">
                        <div class="mic-icon"><i class="fas fa-calendar-alt"></i></div>
                        <div class="mic-label">Session</div>
                        <div class="mic-value" id="spnExamSession">—</div>
                    </div>
                    <div class="modal-info-card year">
                        <div class="mic-icon"><i class="fas fa-clock"></i></div>
                        <div class="mic-label">Year</div>
                        <div class="mic-value" id="spnExamYear">—</div>
                    </div>
                    <div class="modal-info-card class">
                        <div class="mic-icon"><i class="fas fa-chalkboard"></i></div>
                        <div class="mic-label">Class</div>
                        <div class="mic-value" id="spnExamClass">—</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    <i class="fas fa-times"></i> Close
                </button>
                <button type="button" onclick="SaveExamForm();" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save Exam Form
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var Toast;

        var allStudents = [];
        var currentPage = 1;
        var pageSize = 50;
        var selectedIds = new Set();
        var currentPrintMode = 'all';

        window.onload = function () {

            Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2000,
                timerProgressBar: true,
            });

            $("#ddlClass, #ddlYear, #ddlCourse, #ddlSession").change(function () {
                SearchStudent();
            });

            $(document).on('change', 'input[name="chkStudent"]', function () {
                var id = this.id;
                if (this.checked) {
                    selectedIds.add(id);
                } else {
                    selectedIds.delete(id);
                }
                $('#statSelected').text(selectedIds.size);
                UpdateSelectAllLabel();
            });

            $(document).on('click', function (e) {
                if (!$(e.target).closest('#printDropdownWrapper').length) {
                    $('#printDropdownMenu').removeClass('show');
                }
            });

            $(document).on('keydown', function (e) {
                if (e.key === 'Escape') {
                    closePrintPreview();
                }
            });

            SearchStudent();
        };

        function Alert(icon, title) {
            Toast.fire({ icon: icon, title: title });
        }

        function esc(str) {
            if (!str) return '';
            var div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        /* Helper: determine if exam form is considered "submitted" */
        function isExamSubmitted(val) {
            if (!val) return false;
            var v = String(val).trim().toUpperCase();
            return v === 'YES' || v === 'TRUE' || v === '1' || v === 'SUBMITTED' || v === 'SUBMIT';
        }

        function updateStats(data) {
            var sessions = new Set();
            var years = new Set();
            var courses = new Set();
            var examSubmitted = 0;
            var examNotSubmitted = 0;

            $.each(data, function (i, el) {
                if (el.session) sessions.add(el.session);
                if (el.year) years.add(el.year);
                if (el.course) courses.add(el.course);

                if (isExamSubmitted(el.examFormSubmited)) {
                    examSubmitted++;
                } else {
                    examNotSubmitted++;
                }
            });

            $('#statTotal').text(data.length);
            $('#tableCount').text(data.length + ' record' + (data.length !== 1 ? 's' : ''));
            $('#statExamSubmitted').text(examSubmitted);
            $('#statExamNotSubmitted').text(examNotSubmitted);
            $('#statSession').text(sessions.size || '—');
            $('#statYear').text(years.size || '—');
            $('#statCourse').text(courses.size || '—');
        }

        function SearchStudent() {
            var name = $("#txtSearch").val();
            var varClass = $('#ddlClass option:selected').text();
            var varYear = $('#ddlYear option:selected').text();
            var varCourse = $('#ddlCourse option:selected').text();
            var varSession = $('#ddlSession option:selected').text();
            var varRollNum = $("#txtRollNumberSearch").val();
            var varFormNum = $("#txtFormNumberSearch").val();
            var varEnrolNum = $("#txtEnrolloSearch").val();
            var varExamFormSubmited = $('#ddlExamFormSubmited option:selected').text();
            var varTcSubmited = $('#ddlTCSubmited option:selected').text();

            $.post(BASE_URL + "/Student/SearchList", {
                name: name,
                classes: varClass,
                course: varCourse,
                year: varYear,
                session: varSession,
                rollNum: varRollNum,
                formNum: varFormNum,
                enrolNum: varEnrolNum,
                examFormSubmited:varExamFormSubmited,
                tcSubmited: varTcSubmited

            }, function (res) {
                var tableData = res.data || [];
                allStudents = tableData;
                currentPage = 1;
                selectedIds.clear();
                $('#statSelected').text(0);
                updateStats(allStudents);
                RenderPage();
            });
        }

        function GetTotalPages() {
            if (allStudents.length === 0) return 1;
            return Math.ceil(allStudents.length / pageSize);
        }

        function GetPageData() {
            var start = (currentPage - 1) * pageSize;
            var end = start + pageSize;
            return allStudents.slice(start, end);
        }

        function GoToPage(page) {
            var total = GetTotalPages();
            if (page < 1 || page > total) return;
            currentPage = page;
            RenderPage();
            document.querySelector('.table-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function ChangePageSize(size) {
            pageSize = parseInt(size) || 50;
            currentPage = 1;
            RenderPage();
        }

        function RenderPage() {
            var pageData = GetPageData();
            RenderTable(pageData);
            RenderPagination();
        }

        function RenderTable(pageData) {
            $("#tblStudentList tbody").empty();

            if (allStudents.length === 0) {
                $("#tblStudentList tbody").append(
                    '<tr><td colspan="14">' +
                    '<div class="empty-state">' +
                    '<div class="empty-icon"><i class="fas fa-inbox"></i></div>' +
                    '<div class="empty-title">No students found</div>' +
                    '<div class="empty-desc">Try adjusting your filters or search term</div>' +
                    '</div></td></tr>'
                );
                return;
            }

            var startIndex = (currentPage - 1) * pageSize;

            $.each(pageData, function (index, element) {
                var globalIndex = startIndex + index;
                var delay = Math.min(index * 0.03, 0.8);

                /* TC column badge */
                var tcColHtml = '';
                var tcVal = String(element.tc || '').trim().toUpperCase();
                if (tcVal === 'YES' || tcVal === 'TRUE' || tcVal === '1' || tcVal === 'SUBMIT' || tcVal === 'SUBMITTED') {
                    tcColHtml = '<span class="status-badge submitted"><i class="fas fa-check-circle"></i> Yes</span>';
                } else {
                    tcColHtml = '<span class="status-badge not-submitted"><i class="fas fa-times-circle"></i> No</span>';
                }

                /* Exam Form column badge */
                var examColHtml = '';
                if (isExamSubmitted(element.examFormSubmited)) {
                    examColHtml = '<span class="status-badge submitted"><i class="fas fa-check-circle"></i> Submitted</span>';
                } else {
                    examColHtml = '<span class="status-badge not-submitted"><i class="fas fa-times-circle"></i> Pending</span>';
                }

                var isChecked = selectedIds.has(String(element.id));
                var checkedAttr = isChecked ? ' checked' : '';

                var row =
                    '<tr style="animation-delay:' + delay + 's">' +
                    '<td class="col-num">' + (globalIndex + 1) + '</td>' +
                    '<td><div class="formno-cell"><span class="formno-badge">' + esc(element.admissionFormNo) + '</span></div></td>' +
                    '<td class="col-num">' + esc(element.rollNo) + '</td>' +
                    '<td>' + tcColHtml + '</td>' +
                    '<td>' + examColHtml + '</td>' +
                    '<td><span class="info-tag session">' + esc(element.session) + '</span></td>' +
                    '<td><span class="student-name">' + esc(element.studentName) + '</span></td>' +
                    '<td><span class="father-name">' + esc(element.fatherName) + '</span></td>' +
                    '<td><span class="info-tag year">' + esc(element.year) + '</span></td>' +
                    '<td><span class="info-tag subject">' + esc(element.class) + '</span></td>' +
                    '<td><span class="info-tag course">' + esc(element.course) + '</span></td>' +
                    '<td><span class="mobile-pill"><i class="fas fa-phone"></i> ' + esc(element.mobileNoOne) + '</span></td>' +
                    '<td style="text-align:center"><a class="btn-view" href="../Student/PromodeStudent?id=' + esc(element.id) + '" title="View Details"><i class="fas fa-eye"></i> View</a></td>' +
                    '<td style="text-align:center"><label class="custom-check"><input id="' + esc(element.id) + '" name="chkStudent" type="checkbox"' + checkedAttr + '><span class="checkmark"></span></label></td>' +
                    '</tr>';

                $("#tblStudentList").append(row);
            });

            UpdateSelectAllLabel();
        }

        function RenderPagination() {
            var totalRecords = allStudents.length;
            var totalPages = GetTotalPages();

            if (totalRecords === 0) {
                $('#paginationWrapper').hide();
                return;
            }

            $('#paginationWrapper').show();

            var startRecord = (currentPage - 1) * pageSize + 1;
            var endRecord = Math.min(currentPage * pageSize, totalRecords);

            $('#paginationInfo').html(
                'Showing <strong>' + startRecord + '–' + endRecord + '</strong> of <strong>' + totalRecords + '</strong> records'
            );

            var html = '';

            html += '<button class="page-btn nav-btn' + (currentPage === 1 ? ' disabled' : '') + '" onclick="GoToPage(' + (currentPage - 1) + ')">' +
                    '<i class="fas fa-chevron-left"></i> Prev</button>';

            var pages = GeneratePageNumbers(currentPage, totalPages);

            for (var i = 0; i < pages.length; i++) {
                if (pages[i] === '...') {
                    html += '<span class="page-ellipsis">…</span>';
                } else {
                    html += '<button class="page-btn' + (pages[i] === currentPage ? ' active' : '') + '" onclick="GoToPage(' + pages[i] + ')">' + pages[i] + '</button>';
                }
            }

            html += '<button class="page-btn nav-btn' + (currentPage === totalPages ? ' disabled' : '') + '" onclick="GoToPage(' + (currentPage + 1) + ')">' +
                    'Next <i class="fas fa-chevron-right"></i></button>';

            $('#paginationControls').html(html);
            $('#pageSizeSelect').val(pageSize);
        }

        function GeneratePageNumbers(current, total) {
            var pages = [];
            if (total <= 7) {
                for (var i = 1; i <= total; i++) pages.push(i);
            } else {
                pages.push(1);
                if (current > 4) pages.push('...');
                var rangeStart = Math.max(2, current - 1);
                var rangeEnd = Math.min(total - 1, current + 1);
                if (current <= 4) { rangeStart = 2; rangeEnd = 5; }
                if (current >= total - 3) { rangeStart = total - 4; rangeEnd = total - 1; }
                for (var j = rangeStart; j <= rangeEnd; j++) pages.push(j);
                if (current < total - 3) pages.push('...');
                pages.push(total);
            }
            return pages;
        }

        function ToggleSelectAllOnPage() {
            var pageData = GetPageData();
            var allCheckedOnPage = true;

            for (var i = 0; i < pageData.length; i++) {
                if (!selectedIds.has(String(pageData[i].id))) {
                    allCheckedOnPage = false;
                    break;
                }
            }

            for (var j = 0; j < pageData.length; j++) {
                var id = String(pageData[j].id);
                if (allCheckedOnPage) {
                    selectedIds.delete(id);
                } else {
                    selectedIds.add(id);
                }
            }

            $('input[name="chkStudent"]').each(function () {
                this.checked = selectedIds.has(this.id);
            });

            $('#statSelected').text(selectedIds.size);
            UpdateSelectAllLabel();
        }

        function UpdateSelectAllLabel() {
            var pageData = GetPageData();
            if (pageData.length === 0) {
                $('#selectAllPage').html('<i class="far fa-check-square"></i> Select all on this page');
                return;
            }
            var allChecked = true;
            for (var i = 0; i < pageData.length; i++) {
                if (!selectedIds.has(String(pageData[i].id))) {
                    allChecked = false;
                    break;
                }
            }
            if (allChecked) {
                $('#selectAllPage').html('<i class="fas fa-check-square"></i> Deselect all on this page');
            } else {
                $('#selectAllPage').html('<i class="far fa-check-square"></i> Select all on this page');
            }
        }

        function Reset() {
            $("#txtSearch").val('');
            $("#txtRollNumberSearch").val('');
            $('#ddlSession').val('');
            $('#ddlClass').val('');
            $('#ddlCourse').val('');
            $('#ddlYear').val('');
            $("#txtFormNumberSearch").val('');
            $("#txtEnrolloSearch").val('');
            $('#ddlExamFormSubmited').val('');
            $('#ddlTCSubmited').val('');
            SearchStudent();
        }

        function DownloadExcel() {
            $("#hdnExcelName").val($("#txtSearch").val());
            $("#hdnExcelClass").val($('#ddlClass option:selected').text());
            $("#hdnExcelYear").val($('#ddlYear option:selected').text());
            $("#hdnExcelCourse").val($('#ddlCourse option:selected').text());
            $("#hdnExcelSession").val($('#ddlSession option:selected').text());
            $("#hdnExcelSession").val($('#ddlExamFormSubmited option:selected').text());
            $("#hdnExcelSession").val($('#ddlTCSubmited option:selected').text());
            $('#frmDownloadExcel').submit();
        }

        function FillExamForm() {
            var idsArray = Array.from(selectedIds);

            if (idsArray.length > 0) {
                $("#spnExamSession").text($('#ddlSession option:selected').text() || '—');
                $("#spnExamYear").text($('#ddlYear option:selected').text() || '—');
                $("#spnExamClass").text($('#ddlClass option:selected').text() || '—');
                $("#spnSelectedStudent").text(idsArray.length);
                $('#hdnSelected').val(idsArray.join(','));
                $("#modal-FillExamForm").modal("show");
            } else {
                Alert('warning', 'Please select at least one student.');
            }
        }

        function SaveExamForm() {
            $.post(BASE_URL + "/Student/SaveExamFormFilled", {
                ids: $("#hdnSelected").val()
            }, function (res) {
                $("#modal-FillExamForm").modal("hide");
                Alert('success', 'Exam form saved successfully!');
                SearchStudent();
            });
        }

        /* ==========================================================
           PRINT FUNCTIONALITY
           ========================================================== */

        function togglePrintDropdown(e) {
            e.stopPropagation();
            $('#printDropdownMenu').toggleClass('show');
        }

        function openPrintPreview(mode) {
            currentPrintMode = mode;
            $('#printDropdownMenu').removeClass('show');

            var printData = [];

            if (mode === 'all') {
                printData = allStudents;
                $('#pptSubtitle').text('All Records (' + printData.length + ')');
            } else if (mode === 'page') {
                printData = GetPageData();
                $('#pptSubtitle').text('Current Page (' + printData.length + ')');
            } else if (mode === 'selected') {
                if (selectedIds.size === 0) {
                    Alert('warning', 'No students selected. Please select at least one.');
                    return;
                }
                printData = allStudents.filter(function (el) {
                    return selectedIds.has(String(el.id));
                });
                $('#pptSubtitle').text('Selected (' + printData.length + ')');
            }

            if (printData.length === 0) {
                Alert('warning', 'No data available to print.');
                return;
            }

            var html = buildPrintDocument(printData);
            $('#printPreviewBody').html(html);
            $('#printPreviewOverlay').addClass('active');
            document.body.style.overflow = 'hidden';
        }

        function buildPrintDocument(data) {
            var now = new Date();
            var dateStr = now.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
            var timeStr = now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });

            var filterParts = [];
            var sessionVal = $('#ddlSession option:selected').text();
            var yearVal = $('#ddlYear option:selected').text();
            var classVal = $('#ddlClass option:selected').text();
            var courseVal = $('#ddlCourse option:selected').text();
            var nameVal = $('#txtSearch').val();
            var rollVal = $('#txtRollNumberSearch').val();
            var formVal = $('#txtFormNumberSearch').val();
            var enrolVal = $('#txtEnrolloSearch').val();

            if (sessionVal && sessionVal !== 'Select') filterParts.push({ key: 'Session', val: sessionVal });
            if (yearVal && yearVal !== 'Select') filterParts.push({ key: 'Year', val: yearVal });
            if (classVal && classVal !== 'Select') filterParts.push({ key: 'Class', val: classVal });
            if (courseVal && courseVal !== 'Select') filterParts.push({ key: 'Course', val: courseVal });
            if (nameVal) filterParts.push({ key: 'Name', val: nameVal });
            if (rollVal) filterParts.push({ key: 'Roll No', val: rollVal });
            if (formVal) filterParts.push({ key: 'Form No', val: formVal });
            if (enrolVal) filterParts.push({ key: 'Enroll No', val: enrolVal });

            var filterHtml = '';
            if (filterParts.length > 0) {
                filterHtml += '<div class="print-doc-filters">';
                filterHtml += '<span class="pdf-label-text"><i class="fas fa-filter" style="margin-right:4px"></i>Filters:</span>';
                $.each(filterParts, function (i, f) {
                    filterHtml += '<div class="pdf-item"><span class="pdf-key">' + f.key + ':</span> <span class="pdf-val">' + esc(f.val) + '</span></div>';
                });
                filterHtml += '</div>';
            }

            /* Count for print footer */
            var pExamSubmitted = 0;
            var pExamNotSubmitted = 0;

            var rowsHtml = '';
            $.each(data, function (index, el) {
                var tcIndicator = el.tc === 'ISSUE' ? ' <span style="color:#f43f5e;font-weight:700;font-size:.65rem">[TC]</span>' : '';

                var examStatusHtml = '';
                if (isExamSubmitted(el.examFormSubmited)) {
                    examStatusHtml = '<span style="display:inline-block;padding:1px 7px;border-radius:3px;font-size:8px;font-weight:700;background:#d1fae5;color:#047857">YES</span>';
                    pExamSubmitted++;
                } else {
                    examStatusHtml = '<span style="display:inline-block;padding:1px 7px;border-radius:3px;font-size:8px;font-weight:700;background:#fee2e2;color:#b91c1c">NO</span>';
                    pExamNotSubmitted++;
                }

                rowsHtml += '<tr>' +
                    '<td class="pd-num">' + (index + 1) + '</td>' +
                    '<td class="pd-formno">' + esc(el.admissionFormNo) + tcIndicator + '</td>' +
                    '<td style="text-align:center">' + esc(el.rollNo) + '</td>' +
                    '<td style="text-align:center">' + examStatusHtml + '</td>' +
                    '<td><span class="pd-tag session">' + esc(el.session) + '</span></td>' +
                    '<td class="pd-name">' + esc(el.studentName) + '</td>' +
                    '<td>' + esc(el.fatherName) + '</td>' +
                    '<td><span class="pd-tag year">' + esc(el.year) + '</span></td>' +
                    '<td><span class="pd-tag class">' + esc(el.class) + '</span></td>' +
                    '<td><span class="pd-tag course">' + esc(el.course) + '</span></td>' +
                    '<td>' + esc(el.mobileNoOne) + '</td>' +
                    '</tr>';
            });

            var html =
                '<div class="print-doc-header">' +
                    '<div class="pdh-icon"><i class="fas fa-user-graduate"></i></div>' +
                    '<h2 class="pdh-title">Student Directory</h2>' +
                    '<p class="pdh-subtitle">Generated on ' + dateStr + ' at ' + timeStr + '</p>' +
                '</div>' +
                filterHtml +
                '<table class="print-doc-table">' +
                    '<thead>' +
                        '<tr>' +
                            '<th>#</th>' +
                            '<th>Form No</th>' +
                            '<th>Roll No</th>' +
                            '<th>TC</th>' +
                            '<th>Exam Form</th>' +
                            '<th>Session</th>' +
                            '<th>Student Name</th>' +
                            '<th>Father Name</th>' +
                            '<th>Year</th>' +
                            '<th>Class</th>' +
                            '<th>Course</th>' +
                            '<th>Mobile</th>' +
                        '</tr>' +
                    '</thead>' +
                    '<tbody>' + rowsHtml + '</tbody>' +
                '</table>' +
                '<div class="print-doc-footer">' +
                    '<div class="pdf-total">Total: ' + data.length + ' &nbsp;|&nbsp; <span style="color:#047857">Submitted: ' + pExamSubmitted + '</span> &nbsp;|&nbsp; <span style="color:#b91c1c">Pending: ' + pExamNotSubmitted + '</span></div>' +
                    '<div>Printed from CRM System &bull; ' + dateStr + '</div>' +
                '</div>';

            return html;
        }

        function closePrintPreview() {
            $('#printPreviewOverlay').removeClass('active');
            document.body.style.overflow = '';
        }

        function executePrint() {
            var printContent = document.getElementById('printPreviewBody').innerHTML;

            var printWindow = window.open('', '_blank', 'width=1000,height=700');

            printWindow.document.write('<!DOCTYPE html><html><head><title>Print — Student Directory</title>');
            printWindow.document.write('<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">');
            printWindow.document.write('<style>');
            printWindow.document.write(getPrintCSS());
            printWindow.document.write('</style>');
            printWindow.document.write('</head><body>');
            printWindow.document.write(printContent);
            printWindow.document.write('</body></html>');
            printWindow.document.close();

            printWindow.onload = function () {
                setTimeout(function () {
                    printWindow.focus();
                    printWindow.print();
                }, 400);
            };
        }

        function getPrintCSS() {
            return `
                @@page {
                    size: A4 landscape;
                    margin: 12mm 10mm;
                }

                * {
                    margin: 0;
                    padding: 0;
                    box-sizing: border-box;
                }

                body {
                    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                    color: #0f172a;
                    font-size: 11px;
                    line-height: 1.4;
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }

                .print-doc-header {
                    text-align: center;
                    margin-bottom: 16px;
                    padding-bottom: 12px;
                    border-bottom: 3px double #e2e8f0;
                }

                .pdh-icon {
                    font-size: 1.6rem;
                    color: #3b82f6;
                    margin-bottom: 4px;
                }

                .pdh-title {
                    font-size: 16px;
                    font-weight: 800;
                    color: #0f172a;
                    margin: 0 0 2px;
                }

                .pdh-subtitle {
                    font-size: 10px;
                    color: #64748b;
                }

                .print-doc-filters {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 6px 16px;
                    margin-bottom: 12px;
                    padding: 8px 12px;
                    background: #f8fafc;
                    border-radius: 6px;
                    border: 1px solid #e2e8f0;
                    font-size: 10px;
                    align-items: center;
                }

                .pdf-label-text {
                    font-weight: 700;
                    color: #3b82f6;
                    font-size: 10px;
                    margin-right: 6px;
                }

                .pdf-item .pdf-key {
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: .03em;
                    color: #94a3b8;
                    font-size: 8px;
                }

                .pdf-item .pdf-val {
                    font-weight: 600;
                    color: #0f172a;
                    font-size: 10px;
                }

                .print-doc-table {
                    width: 100%;
                    border-collapse: collapse;
                    font-size: 10px;
                }

                .print-doc-table thead th {
                    background: #3b82f6 !important;
                    color: #fff !important;
                    font-size: 8.5px;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: .04em;
                    padding: 7px 6px;
                    border: 1px solid #2563eb;
                    white-space: nowrap;
                }

                .print-doc-table tbody td {
                    padding: 5px 6px;
                    border: 1px solid #e2e8f0;
                    color: #0f172a;
                    vertical-align: middle;
                }

                .print-doc-table tbody tr:nth-child(even) {
                    background: #f8fafc;
                }

                .print-doc-table tbody tr:nth-child(odd) {
                    background: #fff;
                }

                .pd-num {
                    text-align: center;
                    font-weight: 700;
                    color: #64748b;
                }

                .pd-formno {
                    font-weight: 700;
                    color: #2563eb;
                }

                .pd-name {
                    font-weight: 700;
                }

                .pd-tag {
                    display: inline-block;
                    padding: 1px 6px;
                    border-radius: 3px;
                    font-size: 8px;
                    font-weight: 600;
                }

                .pd-tag.session { background: #fffbeb; color: #92400e; }
                .pd-tag.year { background: #f5f3ff; color: #6d28d9; }
                .pd-tag.class { background: #fce7f3; color: #be185d; }
                .pd-tag.course { background: #ecfdf5; color: #047857; }

                .print-doc-footer {
                    margin-top: 14px;
                    padding-top: 10px;
                    border-top: 1px solid #e2e8f0;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    font-size: 9px;
                    color: #94a3b8;
                }

                .pdf-total {
                    font-weight: 700;
                    color: #2563eb;
                    font-size: 11px;
                }
            `;
        }
    </script>
}