@model CRM.ModelsForView.StudentListView
@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    ViewData["Title"] = "Student List";
    var baseUrl = ViewBag.BaseUrl;
}

<style>
    :root {
        --clr-primary: #3b82f6;
        --clr-primary-dark: #2563eb;
        --clr-accent-teal: #14b8a6;
        --clr-accent-emerald: #10b981;
        --clr-accent-orange: #f97316;
        --clr-accent-rose: #f43f5e;
        --clr-accent-amber: #f59e0b;
        --clr-accent-violet: #8b5cf6;
        --clr-accent-sky: #0ea5e9;
        --clr-bg-start: #eff6ff;
        --clr-bg-mid: #f0fdfa;
        --clr-bg-end: #fdf4ff;
        --clr-card: #ffffff;
        --clr-text: #0f172a;
        --clr-text-muted: #64748b;
        --clr-border: #e2e8f0;
        --clr-input-bg: #f8fafc;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.05);
        --shadow-md: 0 4px 16px rgba(0,0,0,.07);
        --shadow-lg: 0 12px 36px rgba(0,0,0,.1);
        --radius: 16px;
        --radius-sm: 10px;
        --transition: .25s cubic-bezier(.4,0,.2,1);
    }

    .content-wrapper {
        background: linear-gradient(155deg, var(--clr-bg-start) 0%, var(--clr-bg-mid) 35%, #ede9fe 65%, var(--clr-bg-end) 100%);
        min-height: 100vh;
        padding-bottom: 60px;
    }

    .breadcrumb {
        background: none !important;
        padding: 0 !important;
        margin: 0 !important;
        font-size: .85rem;
    }

    .breadcrumb-item a {
        color: var(--clr-primary);
        text-decoration: none;
        font-weight: 600;
        transition: var(--transition);
    }

        .breadcrumb-item a:hover {
            color: var(--clr-accent-rose);
        }

    .breadcrumb-item.active {
        color: var(--clr-text-muted);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        color: #cbd5e1;
        content: "›";
    }

    .page-banner {
        background: linear-gradient(135deg, #1e40af 0%, var(--clr-primary) 35%, var(--clr-accent-teal) 100%);
        border-radius: var(--radius);
        padding: 28px 32px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 36px rgba(59,130,246,.3);
    }

        .page-banner::before {
            content: '';
            position: absolute;
            top: -45%;
            right: -5%;
            width: 280px;
            height: 280px;
            background: rgba(255,255,255,.08);
            border-radius: 50%;
        }

        .page-banner::after {
            content: '';
            position: absolute;
            bottom: -55%;
            left: 8%;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,.06);
            border-radius: 50%;
        }

        .page-banner h1 {
            color: #fff;
            font-size: 1.55rem;
            font-weight: 800;
            margin: 0;
            position: relative;
            z-index: 1;
            letter-spacing: -.02em;
        }

        .page-banner p {
            color: rgba(255,255,255,.75);
            margin: 5px 0 0;
            font-size: .88rem;
            position: relative;
            z-index: 1;
        }

        .page-banner .banner-icon {
            position: absolute;
            right: 30px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 3.4rem;
            color: rgba(255,255,255,.14);
            z-index: 1;
        }

    .stat-row {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 14px;
        margin-bottom: 22px;
    }

    @@media (max-width: 1400px) {
        .stat-row {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    @@media (max-width: 992px) {
        .stat-row {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stat-row {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 480px) {
        .stat-row {
            grid-template-columns: 1fr;
        }
    }

    .stat-card {
        background: var(--clr-card);
        border-radius: var(--radius);
        padding: 16px 18px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--clr-border);
        display: flex;
        align-items: center;
        gap: 12px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            width: 4px;
            border-radius: var(--radius) 0 0 var(--radius);
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
        }

        .stat-card.total::before {
            background: linear-gradient(180deg, var(--clr-primary), var(--clr-accent-sky));
        }

        .stat-card.total .stat-icon {
            background: linear-gradient(135deg, #eff6ff, #dbeafe);
            color: var(--clr-primary);
        }

        .stat-card.total .stat-value {
            color: var(--clr-primary-dark);
        }

        .stat-card.session::before {
            background: linear-gradient(180deg, var(--clr-accent-amber), #fbbf24);
        }

        .stat-card.session .stat-icon {
            background: linear-gradient(135deg, #fffbeb, #fef3c7);
            color: #b45309;
        }

        .stat-card.session .stat-value {
            color: #92400e;
        }

        .stat-card.year::before {
            background: linear-gradient(180deg, var(--clr-accent-violet), #a78bfa);
        }

        .stat-card.year .stat-icon {
            background: linear-gradient(135deg, #f5f3ff, #ede9fe);
            color: var(--clr-accent-violet);
        }

        .stat-card.year .stat-value {
            color: #6d28d9;
        }

        .stat-card.course::before {
            background: linear-gradient(180deg, var(--clr-accent-emerald), #34d399);
        }

        .stat-card.course .stat-icon {
            background: linear-gradient(135deg, #ecfdf5, #d1fae5);
            color: var(--clr-accent-emerald);
        }

        .stat-card.course .stat-value {
            color: #047857;
        }

        .stat-card.selected::before {
            background: linear-gradient(180deg, var(--clr-accent-rose), #fb7185);
        }

        .stat-card.selected .stat-icon {
            background: linear-gradient(135deg, #fff1f2, #ffe4e6);
            color: var(--clr-accent-rose);
        }

        .stat-card.selected .stat-value {
            color: #be123c;
        }

        /* ===== EXAM FORM SUBMITTED STAT ===== */
        .stat-card.exam-submitted::before {
            background: linear-gradient(180deg, #10b981, #6ee7b7);
        }

        .stat-card.exam-submitted .stat-icon {
            background: linear-gradient(135deg, #ecfdf5, #d1fae5);
            color: #059669;
        }

        .stat-card.exam-submitted .stat-value {
            color: #047857;
        }

        /* ===== EXAM FORM NOT SUBMITTED STAT ===== */
        .stat-card.exam-not-submitted::before {
            background: linear-gradient(180deg, #ef4444, #fca5a5);
        }

        .stat-card.exam-not-submitted .stat-icon {
            background: linear-gradient(135deg, #fef2f2, #fee2e2);
            color: #dc2626;
        }

        .stat-card.exam-not-submitted .stat-value {
            color: #b91c1c;
        }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.05rem;
        flex-shrink: 0;
    }

    .stat-info {
        flex: 1;
        min-width: 0;
    }

    .stat-label {
        font-size: .66rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--clr-text-muted);
        margin-bottom: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .stat-value {
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .filter-panel {
        background: var(--clr-card);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        border: 1px solid var(--clr-border);
        margin-bottom: 22px;
        overflow: hidden;
        transition: var(--transition);
    }

        .filter-panel:hover {
            box-shadow: var(--shadow-lg);
        }

    .filter-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 13px 22px;
        background: linear-gradient(90deg, #f8fafc, #f1f5f9);
        border-bottom: 1px solid var(--clr-border);
    }

        .filter-header .fh-icon {
            color: var(--clr-accent-sky);
            font-size: .9rem;
        }

        .filter-header .fh-title {
            font-size: .88rem;
            font-weight: 700;
            color: var(--clr-text);
            margin: 0;
        }

        .filter-header .fh-badge {
            font-size: .66rem;
            font-weight: 700;
            padding: 2px 10px;
            background: #dbeafe;
            color: var(--clr-primary-dark);
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

    .filter-body {
        padding: 18px 22px 12px;
    }

        .filter-body label {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: var(--clr-text-muted);
            margin-bottom: 5px;
            display: block;
        }

        .filter-body .form-control,
        .filter-body select.form-control {
            border: 2px solid var(--clr-border);
            border-radius: var(--radius-sm);
            padding: 9px 12px;
            font-size: .87rem;
            color: var(--clr-text);
            background: var(--clr-input-bg);
            transition: var(--transition);
            height: auto;
            box-shadow: none !important;
        }

            .filter-body .form-control:focus,
            .filter-body select.form-control:focus {
                border-color: var(--clr-primary);
                background: #fff;
                box-shadow: 0 0 0 4px rgba(59,130,246,.1) !important;
                outline: none;
            }

    .filter-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 22px 18px;
        flex-wrap: wrap;
    }

    .btn-search {
        background: linear-gradient(135deg, var(--clr-primary) 0%, var(--clr-primary-dark) 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 9px 22px;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 14px rgba(59,130,246,.3);
        transition: var(--transition);
    }

        .btn-search:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 22px rgba(59,130,246,.4);
        }

    .btn-reset {
        background: #f1f5f9;
        color: var(--clr-text-muted);
        border: 2px solid var(--clr-border);
        border-radius: var(--radius-sm);
        padding: 9px 16px;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition);
    }

        .btn-reset:hover {
            background: #fee2e2;
            color: var(--clr-accent-rose);
            border-color: #fda4af;
        }

    .btn-action-group {
        display: inline-flex;
        align-items: center;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 2px solid var(--clr-accent-violet);
    }

    .btn-action-main {
        background: var(--clr-accent-violet);
        color: #fff;
        border: none;
        padding: 9px 16px;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition);
    }

        .btn-action-main:hover {
            background: #7c3aed;
        }

    .btn-action-toggle {
        background: var(--clr-accent-violet);
        color: #fff;
        border: none;
        border-left: 1px solid rgba(255,255,255,.3);
        padding: 9px 11px;
        font-size: .82rem;
        cursor: pointer;
        transition: var(--transition);
    }

        .btn-action-toggle:hover {
            background: #7c3aed;
        }

    .btn-excel {
        background: linear-gradient(135deg, var(--clr-accent-emerald) 0%, #059669 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 9px 16px;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 14px rgba(16,185,129,.3);
        transition: var(--transition);
    }

        .btn-excel:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 22px rgba(16,185,129,.4);
        }

    .btn-print {
        background: linear-gradient(135deg, var(--clr-accent-sky) 0%, #0284c7 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 9px 16px;
        font-size: .84rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 14px rgba(14,165,233,.3);
        transition: var(--transition);
    }

        .btn-print:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 22px rgba(14,165,233,.4);
        }

        .btn-print i {
            font-size: .9rem;
        }

    .print-dropdown-wrapper {
        position: relative;
        display: inline-block;
    }

    .print-dropdown-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        background: #fff;
        border: 1px solid var(--clr-border);
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-lg);
        padding: 6px;
        z-index: 1050;
        min-width: 220px;
        display: none;
        animation: printDropIn .2s ease;
    }

        .print-dropdown-menu.show {
            display: block;
        }

    @@keyframes printDropIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .print-option {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        padding: 11px 14px;
        border-radius: 8px;
        font-size: .84rem;
        font-weight: 600;
        color: var(--clr-text);
        background: none;
        border: none;
        cursor: pointer;
        transition: var(--transition);
        text-align: left;
    }

        .print-option:hover {
            background: #eff6ff;
            color: var(--clr-primary);
        }

        .print-option i {
            color: var(--clr-accent-sky);
            font-size: .95rem;
            width: 20px;
            text-align: center;
            flex-shrink: 0;
        }

        .print-option .po-desc {
            font-size: .72rem;
            color: var(--clr-text-muted);
            font-weight: 500;
            margin-top: 1px;
        }

    .print-preview-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.55);
        backdrop-filter: blur(4px);
        z-index: 9999;
        justify-content: center;
        align-items: flex-start;
        padding: 30px 20px;
        overflow-y: auto;
    }

        .print-preview-overlay.active {
            display: flex;
        }

    .print-preview-container {
        background: #fff;
        width: 100%;
        max-width: 960px;
        border-radius: var(--radius);
        box-shadow: 0 25px 60px rgba(0,0,0,.25);
        overflow: hidden;
        animation: slideUp .3s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .print-preview-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        background: linear-gradient(135deg, #1e40af 0%, var(--clr-primary) 50%, var(--clr-accent-teal) 100%);
        color: #fff;
    }

        .print-preview-toolbar .ppt-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .print-preview-toolbar .ppt-icon {
            font-size: 1.15rem;
        }

        .print-preview-toolbar .ppt-title {
            font-size: .95rem;
            font-weight: 700;
        }

        .print-preview-toolbar .ppt-subtitle {
            font-size: .75rem;
            opacity: .75;
        }

        .print-preview-toolbar .ppt-actions {
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .ppt-btn {
        border: none;
        border-radius: 8px;
        padding: 8px 20px;
        font-size: .82rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition);
    }

    .ppt-btn-print {
        background: #fff;
        color: var(--clr-primary-dark);
    }

        .ppt-btn-print:hover {
            background: #eff6ff;
            transform: translateY(-1px);
        }

    .ppt-btn-close {
        background: rgba(255,255,255,.15);
        color: #fff;
    }

        .ppt-btn-close:hover {
            background: rgba(255,255,255,.25);
        }

    .print-preview-body {
        padding: 32px 40px;
        max-height: 72vh;
        overflow-y: auto;
    }

    .print-doc-header {
        text-align: center;
        margin-bottom: 22px;
        padding-bottom: 16px;
        border-bottom: 3px double #e2e8f0;
    }

        .print-doc-header .pdh-icon {
            font-size: 2rem;
            color: var(--clr-primary);
            margin-bottom: 6px;
        }

        .print-doc-header .pdh-title {
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--clr-text);
            margin: 0 0 3px;
            letter-spacing: -.01em;
        }

        .print-doc-header .pdh-subtitle {
            font-size: .82rem;
            color: var(--clr-text-muted);
            font-weight: 500;
        }

    .print-doc-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 6px 18px;
        margin-bottom: 16px;
        padding: 10px 16px;
        background: #f8fafc;
        border-radius: 8px;
        border: 1px solid var(--clr-border);
        align-items: center;
    }

        .print-doc-filters .pdf-label-text {
            font-weight: 700;
            color: var(--clr-primary);
            font-size: .82rem;
            margin-right: 8px;
        }

        .print-doc-filters .pdf-item .pdf-key {
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .03em;
            color: #94a3b8;
        }

        .print-doc-filters .pdf-item .pdf-val {
            font-size: .82rem;
            font-weight: 600;
            color: var(--clr-text);
        }

    .print-doc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

        .print-doc-table thead th {
            background: var(--clr-primary);
            color: #fff;
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            padding: 10px 8px;
            border: 1px solid var(--clr-primary-dark);
            white-space: nowrap;
        }

        .print-doc-table tbody td {
            padding: 7px 8px;
            border: 1px solid var(--clr-border);
            color: var(--clr-text);
            vertical-align: middle;
        }

        .print-doc-table tbody tr:nth-child(even) {
            background: #f8fafc;
        }

        .print-doc-table tbody tr:nth-child(odd) {
            background: #fff;
        }

        .print-doc-table .pd-num {
            text-align: center;
            font-weight: 700;
            color: var(--clr-text-muted);
        }

        .print-doc-table .pd-formno {
            font-weight: 700;
            color: var(--clr-primary-dark);
        }

        .print-doc-table .pd-name {
            font-weight: 700;
        }

        .print-doc-table .pd-tag {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: .72rem;
            font-weight: 600;
        }

            .print-doc-table .pd-tag.session {
                background: #fffbeb;
                color: #92400e;
            }

            .print-doc-table .pd-tag.year {
                background: #f5f3ff;
                color: #6d28d9;
            }

            .print-doc-table .pd-tag.class {
                background: #fce7f3;
                color: #be185d;
            }

            .print-doc-table .pd-tag.course {
                background: #ecfdf5;
                color: #047857;
            }

    .print-doc-footer {
        margin-top: 18px;
        padding-top: 12px;
        border-top: 1px solid var(--clr-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: .78rem;
        color: #94a3b8;
    }

        .print-doc-footer .pdf-total {
            font-weight: 700;
            color: var(--clr-primary-dark);
            font-size: .88rem;
        }

    .action-sep {
        width: 1px;
        height: 28px;
        background: var(--clr-border);
        margin: 0 2px;
    }

    .dropdown-menu {
        border-radius: var(--radius-sm) !important;
        box-shadow: var(--shadow-lg) !important;
        border: 1px solid var(--clr-border) !important;
        padding: 5px !important;
    }

        .dropdown-menu .btn-default {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: .84rem;
            font-weight: 600;
            color: var(--clr-text);
            transition: var(--transition);
            border: none;
            background: none;
        }

            .dropdown-menu .btn-default:hover {
                background: #f5f3ff;
                color: var(--clr-accent-violet);
            }

            .dropdown-menu .btn-default i {
                color: var(--clr-accent-violet);
            }

    .search-with-icon {
        position: relative;
