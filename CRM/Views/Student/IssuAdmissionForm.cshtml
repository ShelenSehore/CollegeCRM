@model CRM.ModelsForView.StudentListView
@{ Layout = "~/Views/Shared/_MasterLayout.cshtml";
                ViewData["Title"] = "Payment";
                var baseUrl = ViewBag.BaseUrl; }

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap');

    :root {
        --bg-primary: #f0f4ff;
        --bg-secondary: #e8ecf8;
        --bg-card: #ffffff;
        --bg-card-solid: #ffffff;
        --glass: rgba(0, 0, 0, 0.025);
        --glass-border: rgba(0, 0, 0, 0.07);
        --accent-teal: #00b386;
        --accent-teal-dim: rgba(0, 179, 134, 0.1);
        --accent-coral: #e74c5e;
        --accent-coral-dim: rgba(231, 76, 94, 0.08);
        --accent-amber: #e6a817;
        --accent-amber-dim: rgba(230, 168, 23, 0.1);
        --accent-sky: #2b8fd4;
        --accent-sky-dim: rgba(43, 143, 212, 0.09);
        --accent-violet: #9356e0;
        --accent-violet-dim: rgba(147, 86, 224, 0.09);
        --accent-rose: #e0468a;
        --accent-rose-dim: rgba(224, 70, 138, 0.09);
        --text-primary: #1a1d2e;
        --text-secondary: #555a72;
        --text-muted: #9ca3af;
        --border: rgba(0, 0, 0, 0.06);
        --shadow-card: 0 2px 16px rgba(30, 40, 80, 0.06);
        --shadow-card-hover: 0 8px 30px rgba(30, 40, 80, 0.1);
        --shadow-glow-teal: 0 0 24px rgba(0, 179, 134, 0.12);
        --shadow-glow-coral: 0 0 24px rgba(231, 76, 94, 0.10);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --radius-xl: 20px;
    }

    .content-wrapper {
        background: var(--bg-primary) !important;
        min-height: 100vh;
        position: relative;
        overflow: hidden;
    }

        .content-wrapper::before {
            content: '';
            position: fixed;
            top: -180px;
            right: -180px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(0, 179, 134, 0.07) 0%, transparent 70%);
            border-radius: 50%;
            animation: floatBlob1 20s ease-in-out infinite;
            pointer-events: none;
            z-index: 0;
        }

        .content-wrapper::after {
            content: '';
            position: fixed;
            bottom: -120px;
            left: -120px;
            width: 420px;
            height: 420px;
            background: radial-gradient(circle, rgba(231, 76, 94, 0.05) 0%, transparent 70%);
            border-radius: 50%;
            animation: floatBlob2 18s ease-in-out infinite;
            pointer-events: none;
            z-index: 0;
        }

    @@keyframes floatBlob1 {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }

        33% {
            transform: translate(-80px, 60px) scale(1.1);
        }

        66% {
            transform: translate(40px, -40px) scale(0.95);
        }
    }

    @@keyframes floatBlob2 {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }

        33% {
            transform: translate(60px, -50px) scale(1.05);
        }

        66% {
            transform: translate(-30px, 30px) scale(0.9);
        }
    }

    .content-header, .content {
        position: relative;
        z-index: 1;
    }

    /* ===== Breadcrumb ===== */
    .breadcrumb {
        background: transparent !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .breadcrumb-item a {
        color: var(--text-secondary) !important;
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        text-decoration: none;
        transition: color 0.3s;
    }

        .breadcrumb-item a:hover {
            color: var(--accent-teal) !important;
        }

    .breadcrumb-item.active a {
        color: var(--accent-teal) !important;
        font-weight: 600;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        color: var(--text-muted) !important;
        content: '\203A' !important;
        font-size: 1rem;
    }

    /* ===== Page Title Bar ===== */
    .page-title-bar {
        background: linear-gradient(135deg, rgba(0,179,134,0.08) 0%, rgba(43,143,212,0.06) 50%, rgba(147,86,224,0.05) 100%);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-xl);
        padding: 28px 32px;
        margin-bottom: 24px;
        backdrop-filter: blur(20px);
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-card);
    }

        .page-title-bar::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-teal), var(--accent-sky), var(--accent-violet));
            border-radius: 3px;
        }

        .page-title-bar h1 {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 1.8rem;
            color: var(--text-primary);
            margin: 0;
            letter-spacing: -0.5px;
        }

            .page-title-bar h1 span {
                background: linear-gradient(135deg, var(--accent-teal), var(--accent-sky));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

        .page-title-bar .subtitle {
            color: var(--text-secondary);
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.85rem;
            margin-top: 4px;
        }

    .total-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-teal-dim);
        border: 1px solid rgba(0,179,134,0.2);
        color: var(--accent-teal);
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        padding: 6px 16px;
        border-radius: 50px;
    }

        .total-badge .count {
            font-size: 1.1rem;
        }

    /* ===== Stat Cards ===== */
    .stat-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        padding: 20px 22px;
        box-shadow: var(--shadow-card);
        transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            border-radius: 4px 0 0 4px;
        }

        .stat-card:nth-child(1)::before {
            background: var(--accent-teal);
        }

        .stat-card:nth-child(2)::before {
            background: var(--accent-sky);
        }

        .stat-card:nth-child(3)::before {
            background: var(--accent-amber);
        }

        .stat-card:nth-child(4)::before {
            background: var(--accent-coral);
        }

        .stat-card:hover {
            transform: translateY(-4px);
            border-color: rgba(0,0,0,0.1);
            box-shadow: var(--shadow-card-hover);
        }

        .stat-card:nth-child(1):hover {
            box-shadow: var(--shadow-glow-teal), var(--shadow-card-hover);
        }

        .stat-card:nth-child(2):hover {
            box-shadow: 0 0 24px rgba(43,143,212,0.1), var(--shadow-card-hover);
        }

        .stat-card:nth-child(3):hover {
            box-shadow: 0 0 24px rgba(230,168,23,0.1), var(--shadow-card-hover);
        }

        .stat-card:nth-child(4):hover {
            box-shadow: var(--shadow-glow-coral), var(--shadow-card-hover);
        }

        .stat-card .stat-icon {
            width: 42px;
            height: 42px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-bottom: 14px;
        }

        .stat-card:nth-child(1) .stat-icon {
            background: var(--accent-teal-dim);
            color: var(--accent-teal);
        }

        .stat-card:nth-child(2) .stat-icon {
            background: var(--accent-sky-dim);
            color: var(--accent-sky);
        }

        .stat-card:nth-child(3) .stat-icon {
            background: var(--accent-amber-dim);
            color: var(--accent-amber);
        }

        .stat-card:nth-child(4) .stat-icon {
            background: var(--accent-coral-dim);
            color: var(--accent-coral);
        }

        .stat-card .stat-label {
            font-family: 'Space Grotesk', sans-serif;
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }

        .stat-card .stat-value {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 1.6rem;
            color: var(--text-primary);
        }

    /* ===== Main Card ===== */
    .main-card {
        background: var(--bg-card);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-card);
        overflow: hidden;
    }

        .main-card .card-body {
            padding: 0 !important;
        }

    /* ===== Filter Section ===== */
    .filter-section {
        padding: 24px 28px;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(0,0,0,0.01) 0%, transparent 100%);
    }

    .filter-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

        .filter-header .filter-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent-teal);
            animation: pulse-dot 2s ease-in-out infinite;
        }

    @@keyframes pulse-dot {
        0%, 100% {
            opacity: 1;
            box-shadow: 0 0 0 0 rgba(0,179,134,0.4);
        }

        50% {
            opacity: 0.7;
            box-shadow: 0 0 0 6px rgba(0,179,134,0);
        }
    }

    .filter-header h3 {
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-primary);
        margin: 0;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 16px;
        margin-bottom: 20px;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .filter-group label {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: var(--text-secondary);
            margin: 0;
        }

        .filter-group select, .filter-group input {
            background: #f7f8fc !important;
            border: 1.5px solid #dde1ed !important;
            border-radius: var(--radius-sm) !important;
            color: var(--text-primary) !important;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.85rem;
            padding: 10px 14px !important;
            height: auto !important;
            transition: all 0.3s;
            outline: none !important;
        }

            .filter-group select:focus, .filter-group input:focus {
                border-color: var(--accent-teal) !important;
                box-shadow: 0 0 0 3px rgba(0,179,134,0.1) !important;
                background: #fff !important;
            }

            .filter-group select option {
                background: #fff;
                color: var(--text-primary);
            }

    .filter-actions {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    /* ===== Buttons ===== */
    .btn-search {
        background: linear-gradient(135deg, var(--accent-teal), #00a076) !important;
        color: #fff !important;
        border: none !important;
        border-radius: var(--radius-sm) !important;
        font-family: 'Outfit', sans-serif !important;
        font-weight: 700 !important;
        font-size: 0.85rem !important;
        padding: 10px 24px !important;
        letter-spacing: 0.3px;
        transition: all 0.3s !important;
        box-shadow: 0 4px 15px rgba(0,179,134,0.2);
    }

        .btn-search:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(0,179,134,0.3) !important;
            color: #fff !important;
        }

    .btn-reset {
        background: #fff !important;
        color: var(--text-secondary) !important;
        border: 1.5px solid #dde1ed !important;
        border-radius: var(--radius-sm) !important;
        font-family: 'Outfit', sans-serif !important;
        font-weight: 600 !important;
        font-size: 0.85rem !important;
        padding: 10px 20px !important;
        transition: all 0.3s !important;
    }

        .btn-reset:hover {
            background: #f7f8fc !important;
            color: var(--accent-coral) !important;
            border-color: var(--accent-coral) !important;
        }

    .btn-excel {
        background: linear-gradient(135deg, #10b981, #059669) !important;
        color: #fff !important;
        border: none !important;
        border-radius: var(--radius-sm) !important;
        font-family: 'Outfit', sans-serif !important;
        font-weight: 700 !important;
        font-size: 0.85rem !important;
        padding: 10px 18px !important;
        transition: all 0.3s !important;
        box-shadow: 0 4px 15px rgba(16,185,129,0.2);
    }

        .btn-excel:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(16,185,129,0.3) !important;
            color: #fff !important;
        }

    .btn-print {
        background: linear-gradient(135deg, var(--accent-sky), #1a6faa) !important;
        color: #fff !important;
        border: none !important;
        border-radius: var(--radius-sm) !important;
        font-family: 'Outfit', sans-serif !important;
        font-weight: 700 !important;
        font-size: 0.85rem !important;
        padding: 10px 18px !important;
        transition: all 0.3s !important;
        box-shadow: 0 4px 15px rgba(43,143,212,0.2);
    }

        .btn-print:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(43,143,212,0.3) !important;
            color: #fff !important;
        }

    /* ===== Table Section ===== */
    .table-section {
        padding: 0;
    }

    .table-top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 28px;
        border-bottom: 1px solid var(--border);
        background: #fafbff;
    }

        .table-top-bar .table-info {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

            .table-top-bar .table-info strong {
                color: var(--accent-teal);
            }

    .table-wrapper {
        overflow-x: auto;
    }

    #tblStudentList {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin: 0 !important;
    }

        #tblStudentList thead tr {
            background: linear-gradient(135deg, #2b3a67, #3b4f8a, #4c63a8);
        }

        #tblStudentList thead th {
            font-family: 'Space Grotesk', sans-serif !important;
            font-size: 0.7rem !important;
            font-weight: 600 !important;
            text-transform: uppercase !important;
            letter-spacing: 1.2px !important;
            color: rgba(255,255,255,0.92) !important;
            padding: 14px 18px !important;
            border: none !important;
            white-space: nowrap;
        }

        #tblStudentList tbody tr {
            transition: all 0.3s;
            border: none;
        }

            #tblStudentList tbody tr:hover {
                background: rgba(0,179,134,0.04) !important;
            }

        #tblStudentList tbody td {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.85rem;
            color: var(--text-primary);
            padding: 14px 18px !important;
            border: none !important;
            border-bottom: 1px solid var(--border) !important;
            vertical-align: middle;
        }

        #tblStudentList tbody tr:last-child td {
            border-bottom: none !important;
        }

        #tblStudentList tbody tr:nth-child(even) {
            background: #fafbff;
        }

            #tblStudentList tbody tr:nth-child(even):hover {
                background: rgba(0,179,134,0.04) !important;
            }

    .row-index {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: linear-gradient(135deg, var(--accent-teal), #00a076);
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        font-size: 0.75rem;
        color: #fff;
    }

    .form-no {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-sky-dim);
        color: var(--accent-sky);
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .student-name {
        font-weight: 600;
        color: var(--text-primary);
    }

    .father-name {
        color: var(--text-secondary);
    }

    .course-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.3px;
    }

        .course-badge.science {
            background: var(--accent-teal-dim);
            color: var(--accent-teal);
        }

        .course-badge.arts {
            background: var(--accent-amber-dim);
            color: var(--accent-amber);
        }

        .course-badge.commerce {
            background: var(--accent-violet-dim);
            color: var(--accent-violet);
        }

        .course-badge.default {
            background: var(--accent-sky-dim);
            color: var(--accent-sky);
        }

    .mobile-no {
        font-family: 'Space Grotesk', sans-serif;
        color: var(--text-secondary);
        font-size: 0.83rem;
    }

    /* ===== Action Buttons ===== */
    .action-group {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .action-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: var(--radius-sm);
        border: 1px solid #dde1ed;
        background: #f7f8fc;
        color: var(--text-secondary);
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.3s;
        text-decoration: none !important;
    }

        .action-btn:hover {
            transform: translateY(-2px);
        }

        .action-btn.pay:hover {
            background: var(--accent-teal-dim);
            color: var(--accent-teal);
            border-color: rgba(0,179,134,0.3);
            box-shadow: 0 4px 12px rgba(0,179,134,0.12);
        }

        .action-btn.view:hover {
            background: var(--accent-sky-dim);
            color: var(--accent-sky);
            border-color: rgba(43,143,212,0.3);
            box-shadow: 0 4px 12px rgba(43,143,212,0.12);
        }

        .action-btn.edit:hover {
            background: var(--accent-amber-dim);
            color: var(--accent-amber);
            border-color: rgba(230,168,23,0.3);
            box-shadow: 0 4px 12px rgba(230,168,23,0.12);
        }

    /* ===== Empty State ===== */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

        .empty-state i {
            font-size: 3rem;
            color: var(--text-muted);
            margin-bottom: 16px;
        }

        .empty-state h4 {
            font-family: 'Outfit', sans-serif;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 4px;
        }

        .empty-state p {
            color: var(--text-muted);
            font-size: 0.85rem;
        }

    /* ═══════════════════════════════════════════════════ */
    /* PAGINATION                                         */
    /* ═══════════════════════════════════════════════════ */
    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 28px;
        border-top: 1px solid var(--border);
        background: #fafbff;
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

        .pagination-info strong {
            color: var(--accent-teal);
        }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
    }

    .page-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        border-radius: var(--radius-sm);
        border: 1.5px solid #dde1ed;
        background: #fff;
        font-family: 'Outfit', sans-serif;
        font-weight: 600;
        font-size: 0.82rem;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.3s;
        padding: 0 6px;
        text-decoration: none !important;
    }

        .page-btn:hover:not(.disabled):not(.active) {
            border-color: var(--accent-teal);
            color: var(--accent-teal);
            background: var(--accent-teal-dim);
            transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(0,179,134,0.1);
        }

        .page-btn.active {
            background: linear-gradient(135deg, var(--accent-teal), #00a076);
            color: #fff;
            border-color: var(--accent-teal);
            box-shadow: 0 4px 12px rgba(0,179,134,0.25);
        }

        .page-btn.disabled {
            opacity: 0.4;
            cursor: not-allowed;
            pointer-events: none;
        }

        .page-btn.nav-btn {
            padding: 0 12px;
            gap: 4px;
            font-size: 0.78rem;
            letter-spacing: 0.3px;
        }

    .page-ellipsis {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        font-family: 'Outfit', sans-serif;
        font-weight: 700;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .page-size-selector {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .page-size-selector label {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.78rem;
            color: var(--text-secondary);
            white-space: nowrap;
        }

        .page-size-selector select {
            background: #f7f8fc !important;
            border: 1.5px solid #dde1ed !important;
