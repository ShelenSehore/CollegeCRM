@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var Toast;
        // ═══════════════════════════════════════════════════
        // Pagination State
        // ═══════════════════════════════════════════════════
        var allStudentData = [];   // Full dataset from server
        var currentPage = 1;
        var pageSize = 50;         // Default 50 per page
        var totalRecords = 0;

        // ═══════════════════════════════════════════════════
        // Initialization
        // ═══════════════════════════════════════════════════
        window.onload = function () {

            Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2500,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer);
                    toast.addEventListener('mouseleave', Swal.resumeTimer);
                }
            });

            $("#ddlClass, #ddlCourse, #ddlYear, #ddlSession").change(function () {
                currentPage = 1;
                SearchStudent();
            });

            $("#txtSearch").on('keypress', function (e) {
                if (e.which === 13) {
                    e.preventDefault();
                    currentPage = 1;
                    SearchStudent();
                }
            });

            SearchStudent();
        };

        function Alert(icon, title) {
            Toast.fire({
                icon: icon,
                title: title,
                background: icon === 'success' ? '#ecfdf5' : icon === 'warning' ? '#fffbeb' : icon === 'error' ? '#fef2f2' : '#fff',
                color: icon === 'success' ? '#065f46' : icon === 'warning' ? '#92400e' : icon === 'error' ? '#991b1b' : '#0f172a'
            });
        }


        // ═══════════════════════════════════════════════════
        // Reset Filters
        // ═══════════════════════════════════════════════════
        function Reset() {
            $("#txtSearch").val('');
            $('#ddlSession option:first').prop("selected", true);
            $('#ddlClass option:first').prop("selected", true);
            $('#ddlCourse option:first').prop("selected", true);
            $('#ddlYear option:first').prop("selected", true);
            currentPage = 1;
            SearchStudent();
        }

        // ═══════════════════════════════════════════════════
        // Search Students (fetch all data, paginate client-side)
        // ═══════════════════════════════════════════════════
        function SearchStudent() {
            var name = $("#txtSearch").val();
            var varClass = $('#ddlClass option:selected').text();
            var varCourse = $('#ddlCourse option:selected').text();
            var varYear = $('#ddlYear option:selected').text();
            var varSession = $('#ddlSession option:selected').text();

            $.post(BASE_URL + "/Student/IssueAdmissionFormList", {
                name: name,
                classes: varClass,
                course: varCourse,
                year: varYear,
                session: varSession
            }, function (res) {
                allStudentData = res.data || [];
                totalRecords = allStudentData.length;

                // Update stats
                updateStats();

                // Reset to page 1 if current page exceeds total pages
                var totalPages = Math.ceil(totalRecords / pageSize);
                if (currentPage > totalPages) currentPage = 1;
                if (currentPage < 1) currentPage = 1;

                renderPage();
            });
        }

        // ═══════════════════════════════════════════════════
        // Update Stat Cards
        // ═══════════════════════════════════════════════════
        function updateStats() {
            $('#totalCount').text(totalRecords);
            $('#statTotal').text(totalRecords);

            // If your data has payment status, count them. Otherwise show 0.
            var paid = 0, partial = 0, unpaid = 0;
            $.each(allStudentData, function (i, s) {
                var status = (s.paymentStatus || '').toLowerCase();
                if (status === 'paid' || status === 'fully paid') paid++;
                else if (status === 'partial' || status === 'partially paid') partial++;
                else unpaid++;
            });
            // If no paymentStatus field, estimate from counts
            if (paid === 0 && partial === 0 && unpaid === 0) {
                unpaid = totalRecords;
            }
            $('#statPaid').text(paid);
            $('#statPartial').text(partial);
            $('#statUnpaid').text(unpaid);
        }

        // ═══════════════════════════════════════════════════
        // Render Current Page
        // ═══════════════════════════════════════════════════
        function renderPage() {
            var startIndex = (currentPage - 1) * pageSize;
            var endIndex = Math.min(startIndex + pageSize, totalRecords);
            var pageData = allStudentData.slice(startIndex, endIndex);

            // Update showing counts
            var fromNum = totalRecords === 0 ? 0 : startIndex + 1;
            var toNum = endIndex;

            $('#showingFrom').text(fromNum);
            $('#showingTo').text(toNum);
            $('#showingTotal').text(totalRecords);
            $('#pgFrom').text(fromNum);
            $('#pgTo').text(toNum);
            $('#pgTotal').text(totalRecords);

            renderTable(pageData, startIndex);
            renderPagination();
        }

        // ═══════════════════════════════════════════════════
        // Render Table Rows
        // ═══════════════════════════════════════════════════
        function getCourseBadgeClass(course) {
            var c = (course || '').toLowerCase();
            if (c.includes('sci')) return 'science';
            if (c.includes('art')) return 'arts';
            if (c.includes('com') || c.includes('comm')) return 'commerce';
            return 'default';
        }

        function renderTable(data, startIndex) {
            $("#tblStudentList tbody").empty();

            if (data.length === 0) {
                $("#tblStudentList tbody").append(
                    '<tr><td colspan="9" style="text-align:center;padding:60px 20px;">' +
                    '<div class="empty-state">' +
                    '<i class="fas fa-search"></i>' +
                    '<h4>No students found</h4>' +
                    '<p>Try adjusting your filters or search criteria</p>' +
                    '</div></td></tr>'
                );
                return;
            }

            $.each(data, function (index, element) {
                var badgeClass = getCourseBadgeClass(element.course);
                var rowNum = startIndex + index + 1;  // Global row number across pages

                $("#tblStudentList tbody").append(
                    '<tr style="animation:fadeInUp 0.3s ease forwards;animation-delay:' + (index * 0.02) + 's;opacity:0;">' +
                    '<td><span class="row-index">' + rowNum + '</span></td>' +
                    '<td><span class="form-no"><i class="fas fa-hashtag" style="font-size:0.65rem;"></i> ' + (element.admissionFormNo || '-') + '</span></td>' +
                    '<td><span class="student-name">' + (element.studentName || '-') + '</span></td>' +
                    '<td><span class="father-name">' + (element.fatherName || '-') + '</span></td>' +
                    '<td>' + (element.year || '-') + '</td>' +
                    '<td>' + (element.class || '-') + '</td>' +
                    '<td><span class="course-badge ' + badgeClass + '">' + (element.course || '-') + '</span></td>' +
                    '<td><span class="mobile-no"><i class="fas fa-phone" style="font-size:0.65rem;margin-right:4px;color:var(--text-muted);"></i>' + (element.mobileNoOne || '-') + '</span></td>' +
                    '<td class="no-print">' +
                        '<div class="action-group">' +
                            '<a class="action-btn issue" data-toggle="modal" data-target="#modal-View" onclick="StudentDetail(' + element.id + ')" title="View"><i class="fas fa-eye"></i></a>' +
                        '</div>' +
                    '</td></tr>'
                );
            });
        }

        // ═══════════════════════════════════════════════════
        // Render Pagination Controls
        // ═══════════════════════════════════════════════════
        function renderPagination() {
            var totalPages = Math.ceil(totalRecords / pageSize);
            if (totalPages <= 0) totalPages = 1;
            var container = $('#paginationControls');
            container.empty();

            // Hide pagination if only 1 page
            if (totalPages <= 1 && totalRecords <= pageSize) {
                $('#paginationWrapper').css('display', totalRecords === 0 ? 'none' : 'flex');
                if (totalRecords === 0) return;
            }
            $('#paginationWrapper').show();

            // Previous Button
            container.append(
                '<button class="page-btn nav-btn ' + (currentPage === 1 ? 'disabled' : '') + '" ' +
                'onclick="goToPage(' + (currentPage - 1) + ')" ' +
                (currentPage === 1 ? 'disabled' : '') + '>' +
                '<i class="fas fa-chevron-left"></i> Prev</button>'
            );

            // Page Number Buttons with smart ellipsis
            var pages = generatePageNumbers(currentPage, totalPages);
            $.each(pages, function (i, p) {
                if (p === '...') {
                    container.append('<span class="page-ellipsis">...</span>');
                } else {
                    container.append(
                        '<button class="page-btn ' + (p === currentPage ? 'active' : '') + '" ' +
                        'onclick="goToPage(' + p + ')">' + p + '</button>'
                    );
                }
            });

            // Next Button
            container.append(
                '<button class="page-btn nav-btn ' + (currentPage === totalPages ? 'disabled' : '') + '" ' +
                'onclick="goToPage(' + (currentPage + 1) + ')" ' +
                (currentPage === totalPages ? 'disabled' : '') + '>' +
                'Next <i class="fas fa-chevron-right"></i></button>'
            );
        }

        // Generate smart page number array with ellipsis
        function generatePageNumbers(current, total) {
            var pages = [];

            if (total <= 7) {
                // Show all pages if 7 or fewer
                for (var i = 1; i <= total; i++) pages.push(i);
            } else {
                // Always show first page
                pages.push(1);

                if (current > 4) {
                    pages.push('...');
                }

                // Calculate range around current page
                var start = Math.max(2, current - 1);
                var end = Math.min(total - 1, current + 1);

                // Adjust if near the beginning
                if (current <= 4) {
                    end = Math.min(5, total - 1);
                }

                // Adjust if near the end
                if (current >= total - 3) {
                    start = Math.max(2, total - 4);
                }

                for (var j = start; j <= end; j++) {
                    pages.push(j);
                }

                if (current < total - 3) {
                    pages.push('...');
                }

                // Always show last page
                pages.push(total);
            }

            return pages;
        }

        // Navigate to a specific page
        function goToPage(page) {
            var totalPages = Math.ceil(totalRecords / pageSize);
            if (page < 1 || page > totalPages) return;
            currentPage = page;
            renderPage();

            // Scroll to table top smoothly
            $('.table-wrapper').animate({ scrollTop: 0 }, 300);
            $('html, body').animate({
                scrollTop: $('.table-section').offset().top - 80
            }, 300);
        }

        // Change page size from dropdown
        function changePageSize() {
            pageSize = parseInt($('#ddlPageSize').val()) || 50;
            currentPage = 1;
            renderPage();
        }

        // ═══════════════════════════════════════════════════
        // PRINT FUNCTIONALITY
        // ═══════════════════════════════════════════════════
        function printStudentList() {
            // Build filter info for print header
            var session = $('#ddlSession option:selected').text();
            var year = $('#ddlYear option:selected').text();
            var cls = $('#ddlClass option:selected').text();
            var course = $('#ddlCourse option:selected').text();
            var search = $("#txtSearch").val();

            var filterParts = [];
            if (session && session !== 'Select') filterParts.push('Session: ' + session);
            if (year && year !== 'Select') filterParts.push('Year: ' + year);
            if (cls && cls !== 'Select') filterParts.push('Class: ' + cls);
            if (course && course !== 'Select') filterParts.push('Course: ' + course);
            if (search) filterParts.push('Name: ' + search);

            var filterInfo = filterParts.length > 0 ? filterParts.join(' | ') : 'All Students';
            $('#printFilterInfo').text(filterInfo);

            // Set print date
            var now = new Date();
            var dateStr = now.toLocaleDateString('en-IN', {
                day: '2-digit', month: 'short', year: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
            $('#printDate').text(dateStr);

            // Temporarily show ALL data for printing (not just current page)
            var savedHtml = $("#tblStudentList tbody").html();
            var startIndex = 0;

            $("#tblStudentList tbody").empty();

            if (allStudentData.length === 0) {
                $("#tblStudentList tbody").append(
                    '<tr><td colspan="9" style="text-align:center;padding:40px;">No data to print</td></tr>'
                );
            } else {
                $.each(allStudentData, function (index, element) {
                    var badgeClass = getCourseBadgeClass(element.course);
                    var rowNum = index + 1;

                    $("#tblStudentList tbody").append(
                        '<tr>' +
                        '<td><span class="row-index">' + rowNum + '</span></td>' +
                        '<td><span class="form-no"><i class="fas fa-hashtag" style="font-size:0.65rem;"></i> ' + (element.admissionFormNo || '-') + '</span></td>' +
                        '<td><span class="student-name">' + (element.studentName || '-') + '</span></td>' +
                        '<td><span class="father-name">' + (element.fatherName || '-') + '</span></td>' +
                        '<td>' + (element.year || '-') + '</td>' +
                        '<td>' + (element.class || '-') + '</td>' +
                        '<td><span class="course-badge ' + badgeClass + '">' + (element.course || '-') + '</span></td>' +
                        '<td><span class="mobile-no">' + (element.mobileNoOne || '-') + '</span></td>' +
                        '</tr>'   // No action column in print
                    );
                });
            }

            // Trigger print
            window.print();

            // Restore the paginated view after printing
            setTimeout(function () {
                renderPage();
            }, 500);
        }


       
        // ═══════════════════════════════════════════════════
