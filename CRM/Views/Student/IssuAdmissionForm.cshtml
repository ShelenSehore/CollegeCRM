            if (!validateField("#ddlFormSession", "Select gender", "dropdown")) ok = false;
            if (!validateField("#ddlFormClass", "Select minority", "dropdown")) ok = false;
            if (!validateField("#ddlFormCourse", "Select caste", "dropdown")) ok = false;
            if (!validateField("#ddlFormYear", "Select TC", "dropdown")) ok = false;
            
            if (!ok) return;

            $.post(BASE_URL + "/Student/SaveFormDetail", {
                id: $("#hdnStudentID").val(),
                varFormNo: $("#txtFormNumber").val(),
                varSession: $("#ddlFormSession").val(),
                varClass: $("#ddlFormClass").val(),
                varCourse: $("#ddlFormCourse").val(),
                varYear: $("#ddlFormYear").val()
                
            }, function (res) {
                $("#modal-Promod").modal("hide");
                Alert('success', 'Personal detail saved successfully!');
               
            });
        }


