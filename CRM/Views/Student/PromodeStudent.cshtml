@model CRM.ModelsForView.StudentViewModel

@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    ViewData["Title"] = "Registration";
    var baseUrl = ViewBag.BaseUrl;
}
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<style>
    :root {
        --violet-50: #f5f3ff;
        --violet-100: #ede9fe;
        --violet-200: #ddd6fe;
        --violet-400: #a78bfa;
        --violet-500: #8b5cf6;
        --violet-600: #7c3aed;
        --violet-700: #6d28d9;
        --blue-500: #3b82f6;
        --blue-600: #2563eb;
        --cyan-500: #06b6d4;
        --emerald-500: #10b981;
        --emerald-600: #059669;
        --amber-500: #f59e0b;
        --amber-100: #fef3c7;
        --rose-500: #f43f5e;
        --rose-100: #ffe4e6;
        --rose-600: #e11d48;
        --orange-500: #f97316;
        --pink-500: #ec4899;
        --surface: #ffffff;
        --surface-alt: #f8fafc;
        --border: #e2e8f0;
        --border-light: #f1f5f9;
        --text-dark: #0f172a;
        --text-mid: #475569;
        --text-light: #94a3b8;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
        --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
        --shadow-lg: 0 12px 40px rgba(0,0,0,0.12);
        --shadow-xl: 0 20px 60px rgba(0,0,0,0.15);
        --radius: 14px;
        --radius-sm: 10px;
        --radius-xs: 8px;
    }

    * { font-family: 'Inter', sans-serif; box-sizing: border-box; }

    body { background: var(--surface-alt); }

    /* ─── Breadcrumb ─── */
    .breadcrumb {
        background: transparent !important;
        padding: 0 !important;
        margin: 0 !important;
        font-size: 0.82rem;
    }
    .breadcrumb-item a {
        color: var(--text-light);
        text-decoration: none;
        transition: color 0.2s;
    }
    .breadcrumb-item a:hover { color: var(--violet-500); }
    .breadcrumb-item.active { color: var(--text-mid); font-weight: 500; }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--text-light); content: "›"; }

    /* ─── Page Title ─── */
    .page-title-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }
    .page-title-bar h1 {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0;
        letter-spacing: -0.03em;
        background: linear-gradient(135deg, var(--violet-600), var(--blue-600));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .page-title-bar .subtitle {
        font-size: 0.85rem;
        color: var(--text-light);
        margin: 2px 0 0 0;
    }

    /* ─── Profile Sidebar ─── */
    .profile-card {
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: none;
        position: relative;
    }
    .profile-banner {
        height: 100px;
        background: linear-gradient(135deg, var(--violet-600), var(--blue-500), var(--cyan-500));
        position: relative;
    }
    .profile-banner::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 40px;
        background: linear-gradient(to top, var(--surface), transparent);
    }
    @if (Model.TC == "ISSUE")
    {
        <text>.tc-badge-override .profile-banner::before {
            content: 'TC Issued';
            position: absolute;
            top: 12px;
            right: 12px;
            background: var(--rose-500);
            color: #fff;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 20px;
            z-index: 2;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }</text>
    }
    .profile-photo-wrap {
        text-align: center;
        margin-top: -48px;
        position: relative;
        z-index: 2;
    }
    .profile-photo {
        width: 96px;
        height: 96px;
        border-radius: 16px;
        border: 4px solid var(--surface);
        box-shadow: var(--shadow-md);
        object-fit: cover;
        display: inline-block;
    }
    .profile-info {
        text-align: center;
        padding: 0.75rem 1.25rem 0;
    }
    .profile-info h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 2px 0;
    }
    .profile-info .father-name {
        font-size: 0.85rem;
        color: var(--text-mid);
        margin: 0 0 8px 0;
    }
    .profile-contact {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 4px;
    }
    .profile-contact i {
        color: var(--violet-500);
        font-size: 0.8rem;
    }
    .profile-contact span {
        font-size: 0.85rem;
        color: var(--text-mid);
        font-weight: 500;
    }
    .exam-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-top: 8px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .exam-badge.filled {
        background: #ecfdf5;
        color: var(--emerald-600);
    }
    .exam-badge.not-filled {
        background: var(--rose-100);
        color: var(--rose-500);
    }

    /* ─── Education Card ─── */
    .education-card {
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        overflow: hidden;
        margin-top: 1.25rem;
    }
    .edu-header {
        background: linear-gradient(135deg, var(--emerald-500), var(--cyan-500));
        padding: 0.85rem 1.15rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }
    .edu-header i {
        color: #fff;
        font-size: 0.9rem;
    }
    .edu-header span {
        color: #fff;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: -0.01em;
    }
    .edu-body { padding: 0; }
    .edu-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.7rem 1.15rem;
        border-bottom: 1px solid var(--border-light);
        transition: background 0.15s;
    }
    .edu-item:last-child { border-bottom: none; }
    .edu-item:hover { background: var(--surface-alt); }
    .edu-item .label {
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--text-light);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .edu-item .value {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-dark);
    }

    /* ─── Tab Navigation ─── */
    .main-card {
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        border: none;
        overflow: hidden;
    }
    .tab-nav {
        display: flex;
        gap: 4px;
        padding: 1rem 1.25rem 0;
        background: var(--surface);
        overflow-x: auto;
    }
    .tab-nav::-webkit-scrollbar { height: 0; }
    .tab-btn {
        padding: 0.6rem 1.1rem;
        border: none;
        background: transparent;
        border-radius: var(--radius-xs) var(--radius-xs) 0 0;
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--text-light);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.45rem;
        transition: all 0.2s;
        white-space: nowrap;
        position: relative;
    }
    .tab-btn i { font-size: 0.78rem; }
    .tab-btn:hover { color: var(--text-mid); background: var(--surface-alt); }
    .tab-btn.active {
        color: var(--violet-600);
        font-weight: 600;
        background: var(--violet-50);
    }
    .tab-btn.active::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 2.5px;
        border-radius: 3px 3px 0 0;
    }
    .tab-btn.active[data-tab="Personal"]::after { background: var(--violet-500); }
    .tab-btn.active[data-tab="College"]::after { background: var(--blue-500); }
    .tab-btn.active[data-tab="Academic"]::after { background: var(--emerald-500); }
    .tab-btn.active[data-tab="Document"]::after { background: var(--amber-500); }
    .tab-btn.active[data-tab="Promosion"]::after { background: var(--orange-500); }
    .tab-btn.active[data-tab="History"]::after { background: var(--pink-500); }

    .tab-content-area {
        padding: 1.5rem;
        min-height: 350px;
        background: var(--surface);
    }

    /* ─── Detail Grid ─── */
    .detail-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
    }
    @@media (max-width: 992px) {
        .detail-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 768px) {
        .detail-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 480px) {
        .detail-grid { grid-template-columns: 1fr; }
    }
    .detail-field {
        background: var(--surface-alt);
        border: 1px solid var(--border-light);
        border-radius: var(--radius-xs);
        padding: 0.65rem 0.85rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .detail-field:hover {
        border-color: var(--violet-200);
        box-shadow: 0 0 0 3px var(--violet-50);
    }
    .detail-field.span-2 { grid-column: span 2; }
    .detail-field.span-3 { grid-column: span 3; }
    .detail-field.span-4 { grid-column: span 4; }
    @@media (max-width: 768px) {
        .detail-field.span-2,
        .detail-field.span-3,
        .detail-field.span-4 { grid-column: span 2; }
    }
    @@media (max-width: 480px) {
        .detail-field.span-2,
        .detail-field.span-3,
        .detail-field.span-4 { grid-column: span 1; }
    }
    .detail-field label {
        display: block;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--text-light);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 3px;
    }
    .detail-field input,
    .detail-field textarea,
    .detail-field select {
        width: 100%;
        border: none;
        background: transparent;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-dark);
        padding: 0;
        outline: none;
        font-family: 'Inter', sans-serif;
    }
    .detail-field input[readonly],
    .detail-field textarea[readonly] {
        color: var(--violet-700);
    }
    .detail-field textarea { resize: none; min-height: 40px; }

    /* ─── Color Tags ─── */
    .tag {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.02em;
    }
    .tag-violet { background: var(--violet-100); color: var(--violet-600); }
    .tag-blue { background: #dbeafe; color: var(--blue-600); }
    .tag-emerald { background: #ecfdf5; color: var(--emerald-600); }
    .tag-amber { background: var(--amber-100); color: #b45309; }
    .tag-rose { background: var(--rose-100); color: var(--rose-600); }
    .tag-orange { background: #fff7ed; color: var(--orange-500); }
    .tag-cyan { background: #ecfeff; color: #0e7490; }
    .tag-pink { background: #fdf2f8; color: var(--pink-500); }

    /* ─── Action Button ─── */
    .btn-edit-float {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.55rem 1.1rem;
        background: linear-gradient(135deg, var(--violet-500), var(--blue-500));
        color: #fff;
        border: none;
        border-radius: var(--radius-xs);
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 8px rgba(139,92,246,0.3);
        text-decoration: none;
    }
    .btn-edit-float:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(139,92,246,0.4);
        color: #fff;
    }
    .btn-edit-float.green {
        background: linear-gradient(135deg, var(--emerald-500), var(--cyan-500));
        box-shadow: 0 2px 8px rgba(16,185,129,0.3);
    }
    .btn-edit-float.green:hover {
        box-shadow: 0 4px 16px rgba(16,185,129,0.4);
    }
    .btn-edit-float.orange {
        background: linear-gradient(135deg, var(--orange-500), var(--amber-500));
        box-shadow: 0 2px 8px rgba(249,115,22,0.3);
    }
    .btn-edit-float.orange:hover {
        box-shadow: 0 4px 16px rgba(249,115,22,0.4);
    }

    /* ─── Tables ─── */
    .modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 1px solid var(--border);
    }
    .modern-table thead th {
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
        padding: 0.75rem 1rem;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--text-light);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        text-align: left;
        border-bottom: 2px solid var(--border);
    }
    .modern-table tbody td {
        padding: 0.7rem 1rem;
        font-size: 0.85rem;
        color: var(--text-mid);
        border-bottom: 1px solid var(--border-light);
    }
    .modern-table tbody tr { transition: background 0.15s; }
    .modern-table tbody tr:hover { background: var(--violet-50); }
    .modern-table tbody tr:last-child td { border-bottom: none; }
    .modern-table .row-num {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        background: var(--violet-100);
        color: var(--violet-600);
        font-weight: 700;
        font-size: 0.75rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .modern-table .marks-highlight {
        font-weight: 700;
        color: var(--text-dark);
    }
    .btn-icon-sm {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text-light);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        transition: all 0.2s;
    }
    .btn-icon-sm.delete:hover {
        background: var(--rose-100);
        color: var(--rose-500);
        border-color: var(--rose-500);
    }
    .btn-icon-sm.view:hover {
        background: var(--violet-100);
        color: var(--violet-600);
        border-color: var(--violet-500);
    }

    /* ─── Doc Table ─── */
    .doc-thumb {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        object-fit: cover;
        cursor: pointer;
        border: 2px solid var(--border);
        transition: all 0.2s;
    }
    .doc-thumb:hover {
        border-color: var(--violet-400);
        transform: scale(1.08);
        box-shadow: 0 4px 12px rgba(139,92,246,0.2);
    }
    .doc-name {
        font-weight: 600;
        color: var(--text-dark);
        font-size: 0.85rem;
    }
    .doc-label {
        font-size: 0.72rem;
        color: var(--text-light);
    }

    /* ─── Promotion Section ─── */
    .promo-section {
        position: relative;
    }
    .promo-arrow-wrap {
        text-align: center;
        padding: 1rem 0;
    }
    .promo-arrow {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--emerald-500), var(--cyan-500));
        color: #fff;
        font-size: 1.3rem;
        box-shadow: 0 4px 20px rgba(16,185,129,0.35);
        animation: pulseArrow 2s infinite;
    }
    @@keyframes pulseArrow {
        0%, 100% { box-shadow: 0 4px 20px rgba(16,185,129,0.35); }
        50% { box-shadow: 0 4px 30px rgba(16,185,129,0.55); transform: translateY(-3px); }
    }
    .promo-arrow-wrap span {
        display: block;
        margin-top: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--emerald-600);
    }
    .promo-current {
        background: linear-gradient(135deg, var(--violet-50), #ede9fe);
        border: 1px solid var(--violet-200);
        border-radius: var(--radius-sm);
        padding: 1rem 1.25rem;
    }
    .promo-current .section-label {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--violet-500);
        margin-bottom: 0.75rem;
    }

    /* ─── Promotion Form Fields ─── */
    .promo-form-field label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-light);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 4px;
    }
    .promo-form-field select,
    .promo-form-field input {
        width: 100%;
        padding: 0.55rem 0.85rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-xs);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-dark);
        background: var(--surface);
        outline: none;
        font-family: 'Inter', sans-serif;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .promo-form-field select:focus,
    .promo-form-field input:focus {
        border-color: var(--emerald-500);
        box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
    }
    .btn-promote {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.5rem;
        background: linear-gradient(135deg, var(--emerald-500), var(--cyan-500));
        color: #fff;
        border: none;
        border-radius: var(--radius-xs);
        font-size: 0.88rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 10px rgba(16,185,129,0.3);
        width: 100%;
        justify-content: center;
        margin-top: 1.5rem;
    }
    .btn-promote:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 20px rgba(16,185,129,0.45);
    }

    /* ─── Modals ─── */
    .modal-backdrop.show {
        opacity: 0.5;
        backdrop-filter: blur(4px);
    }
    .modal.fade .modal-dialog {
        transform: translateY(20px) scale(0.98);
        transition: transform 0.3s ease;
    }
    .modal.show .modal-dialog {
        transform: translateY(0) scale(1);
    }
    .modal-content {
        border: none;
        border-radius: 18px;
        box-shadow: var(--shadow-xl);
        overflow: hidden;
    }
    .modal-header-bar {
        padding: 1.15rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .modal-header-bar.violet { background: linear-gradient(135deg, var(--violet-600), var(--blue-600)); }
    .modal-header-bar.green { background: linear-gradient(135deg, var(--emerald-500), var(--cyan-500)); }
    .modal-header-bar.orange { background: linear-gradient(135deg, var(--orange-500), var(--amber-500)); }
    .modal-header-bar.amber { background: linear-gradient(135deg, var(--amber-500), var(--orange-500)); }
    .modal-header-bar h4 {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }
    .modal-header-bar .icon-circle {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
    }
    .modal-header-bar .close {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: none;
        background: rgba(255,255,255,0.2);
        color: #fff;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s;
        padding: 0;
        line-height: 1;
        opacity: 1;
        text-shadow: none;
    }
    .modal-header-bar .close:hover { background: rgba(255,255,255,0.35); }
    .modal-body { padding: 1.5rem; }
    .modal-footer-bar {
        padding: 1rem 1.5rem;
        background: var(--surface-alt);
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.6rem;
    }

    /* ─── Modal Form ─── */
    .modal-form-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
    }
    @@media (max-width: 768px) {
        .modal-form-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 480px) {
        .modal-form-grid { grid-template-columns: 1fr; }
    }
    .modal-form-grid.span-2 { grid-column: span 2; }
    @@media (max-width: 480px) {
        .modal-form-grid.span-2 { grid-column: span 1; }
    }
    .mf-group label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-mid);
        margin-bottom: 4px;
    }
    .mf-group input,
    .mf-group select,
    .mf-group textarea {
        width: 100%;
        padding: 0.55rem 0.8rem;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-xs);
        font-size: 0.85rem;
        color: var(--text-dark);
        background: var(--surface);
        outline: none;
        font-family: 'Inter', sans-serif;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .mf-group input:focus,
    .mf-group select:focus,
    .mf-group textarea:focus {
        border-color: var(--violet-400);
        box-shadow: 0 0 0 3px var(--violet-50);
    }
    .mf-group input.is-invalid,
    .mf-group select.is-invalid {
        border-color: var(--rose-500);
        box-shadow: 0 0 0 3px var(--rose-100);
    }
    .mf-group textarea { resize: vertical; min-height: 50px; }
    .mf-group .invalid-feedback {
        font-size: 0.72rem;
        color: var(--rose-500);
        margin-top: 3px;
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    .btn-modal-cancel {
        padding: 0.55rem 1.15rem;
        background: var(--surface);
        color: var(--text-mid);
        border: 1px solid var(--border);
        border-radius: var(--radius-xs);
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-modal-cancel:hover { background: var(--surface-alt); }
    .btn-modal-save {
        padding: 0.55rem 1.35rem;
        background: linear-gradient(135deg, var(--violet-500), var(--blue-500));
        color: #fff;
        border: none;
        border-radius: var(--radius-xs);
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s;
        box-shadow: 0 2px 8px rgba(139,92,246,0.25);
    }
    .btn-modal-save:hover {
        box-shadow: 0 4px 16px rgba(139,92,246,0.4);
        transform: translateY(-1px);
    }
    .btn-modal-save.green {
        background: linear-gradient(135deg, var(--emerald-500), var(--cyan-500));
        box-shadow: 0 2px 8px rgba(16,185,129,0.25);
    }
    .btn-modal-save.green:hover {
        box-shadow: 0 4px 16px rgba(16,185,129,0.4);
    }

    /* ─── Empty state ─── */
    .empty-state {
        padding: 3rem 2rem;
        text-align: center;
    }
    .empty-state i { font-size: 2rem; color: var(--border); margin-bottom: 0.75rem; }
    .empty-state h4 { font-size: 0.95rem; font-weight: 600; color: var(--text-mid); margin: 0 0 4px 0; }
    .empty-state p { font-size: 0.82rem; color: var(--text-light); margin: 0; }

    /* ─── Animations ─── */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .anim-in { animation: fadeInUp 0.45s ease forwards; }
    .anim-d1 { animation-delay: 0.05s; opacity: 0; }
    .anim-d2 { animation-delay: 0.1s; opacity: 0; }
    .anim-d3 { animation-delay: 0.15s; opacity: 0; }

    /* ─── Doc viewer modal img ─── */
    #imgViewDocument {
        max-width: 100%;
        max-height: 70vh;
        border-radius: var(--radius-sm);
        display: block;
        margin: 0 auto;
    }

    /* ─── Override AdminLTE ─── */
    .content-wrapper > .content-header { padding-bottom: 0; }
    .card { border: none; box-shadow: none; }
</style>

<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-12">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item"><a href="~/Student/List">Students</a></li>
                        <li class="breadcrumb-item active">Student Detail</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">

                <!-- ═══════ LEFT SIDEBAR ═══════ -->
                <div class="col-md-3">
                    <div class="anim-in">
                        <!-- Profile Card -->
                        <div class="profile-card @(Model.TC == "ISSUE" ? "tc-badge-override" : "")">
                            <div class="profile-banner"></div>
                            <div class="profile-photo-wrap">
                                <img class="profile-photo" src="@Model.Photo" alt="Profile">
                            </div>
                            <div class="profile-info">
                                <h3>@Model.StudentName</h3>
                                <p class="father-name">@Model.FatherName</p>
                                <div class="profile-contact">
                                    <i class="fas fa-phone-alt"></i>
                                    <span>@Model.MobileNoOne</span>
                                </div>
                                <div>
                                    <span class="exam-badge @(Model.ExamFormSubmited == "Yes" ? "filled" : "not-filled")">
                                        <i class="fas @(Model.ExamFormSubmited == "Yes" ? "fa-check-circle" : "fa-times-circle")"></i>
                                        Exam Form @(Model.ExamFormSubmited == "Yes" ? "Filled" : "Not Filled")
                                    </span>
                                </div>
                            </div>
                            <div style="padding: 0.75rem 1.25rem 1.25rem;">
                                <input type="hidden" value="@Model.Id" id="hdnStudentID" />
                            </div>
                        </div>

                        <!-- Education Card -->
                        <div class="education-card">
                            <div class="edu-header">
                                <i class="fas fa-graduation-cap"></i>
                                <span>Education</span>
                            </div>
                            <div class="edu-body">
                                <div class="edu-item">
                                    <span class="label">Session</span>
                                    <span class="value"><span class="tag tag-violet">@Model.Session</span></span>
                                </div>
                                <div class="edu-item">
                                    <span class="label">Class</span>
                                    <span class="value"><span class="tag tag-blue">@Model.Class</span></span>
                                </div>
                                <div class="edu-item">
                                    <span class="label">Course</span>
                                    <span class="value"><span class="tag tag-cyan">@Model.Course</span></span>
                                </div>
                                <div class="edu-item">
                                    <span class="label">Year</span>
                                    <span class="value"><span class="tag tag-emerald">@Model.Year</span></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ═══════ RIGHT MAIN AREA ═══════ -->
                <div class="col-md-9">
                    <div class="main-card anim-in anim-d1">
                        <!-- Tab Navigation -->
                        <div class="tab-nav" role="tablist">
                            <button class="tab-btn active" data-tab="Personal" onclick="switchTab('Personal', this)">
                                <i class="fas fa-user"></i> Personal
                            </button>
                            <button class="tab-btn" data-tab="College" onclick="switchTab('College', this)">
                                <i class="fas fa-university"></i> College
                            </button>
                            <button class="tab-btn" data-tab="Academic" onclick="switchTab('Academic', this)">
                                <i class="fas fa-book-open"></i> Academic
                            </button>
                            <button class="tab-btn" data-tab="Document" onclick="switchTab('Document', this)">
                                <i class="fas fa-file-alt"></i> Document
                            </button>
                            <button class="tab-btn" data-tab="Promosion" onclick="switchTab('Promosion', this)">
                                <i class="fas fa-arrow-up"></i> Promotion
                            </button>
                            <button class="tab-btn" data-tab="History" onclick="switchTab('History', this)">
                                <i class="fas fa-history"></i> History
                            </button>
                        </div>

                        <!-- Tab Content -->
                        <div class="tab-content-area">

                            <!-- ── Personal ── -->
                            <div class="tab-pane active" id="Personal">
                                <div class="detail-grid">
                                    <div class="detail-field">
                                        <label>Name</label>
                                        <input asp-for="StudentName" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Father Name</label>
                                        <input asp-for="FatherName" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Mother Name</label>
                                        <input asp-for="MotherName" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Mobile No</label>
                                        <input asp-for="MobileNoOne" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Date of Birth</label>
                                        <input asp-for="DOB" type="date" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Father Mobile</label>
                                        <input asp-for="FatherMobileNo" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Gender</label>
                                        <input asp-for="Gender" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Minority</label>
                                        <input asp-for="Minority" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Caste</label>
                                        <input asp-for="Caste" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>TC Status</label>
                                        <input asp-for="TC" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>PH</label>
                                        <input asp-for="PH" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Aadhaar No</label>
                                        <input asp-for="AadhaarNo" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>ABC No</label>
                                        <input asp-for="AbcNo" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Samagra ID</label>
                                        <input asp-for="SamagraID" readonly>
                                    </div>
                                    <div class="detail-field span-3">
                                        <label>Address</label>
                                        <textarea asp-for="Address" readonly rows="1"></textarea>
                                    </div>
                                    <div class="detail-field" style="display:flex;align-items:flex-end;">
                                        <a data-toggle="modal" data-target="#modal-Personal" class="btn-edit-float" href="#" style="text-decoration:none;">
                                            <i class="fas fa-pen"></i> Edit
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- ── College ── -->
                            <div class="tab-pane" id="College" style="display:none;">
                                <div class="detail-grid">
                                    <div class="detail-field">
                                        <label>Session</label>
                                        <input asp-for="Session" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Class</label>
                                        <input asp-for="Class" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Course</label>
                                        <input asp-for="Course" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Year</label>
                                        <input asp-for="Year" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>New / Old</label>
                                        <input asp-for="NewOld" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Regular / Ex</label>
                                        <input asp-for="RegEx" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Admission Form No</label>
                                        <input asp-for="AdmissionFormNo" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Enroll No</label>
                                        <input asp-for="EnRollNo" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Admission Date</label>
                                        <input asp-for="AdmissionDate" type="date" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Roll No</label>
                                        <input asp-for="RollNo" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Scholar No</label>
                                        <input asp-for="SchoolarNo" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Sub Code</label>
                                        <input asp-for="SubCode" readonly>
                                    </div>
                                    <div class="detail-field">
                                        <label>Exam Form Submited</label>
                                        <input asp-for="ExamFormSubmited" readonly>
                                    </div>
                                    <div class="detail-field span-4" style="display:flex;justify-content:flex-end;align-items:flex-end;padding-bottom:0.5rem;">
                                        <a data-toggle="modal" data-target="#modal-College" class="btn-edit-float green" href="#" style="text-decoration:none;">
                                            <i class="fas fa-pen"></i> Edit College
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <!-- ── Academic ── -->
                            <div class="tab-pane" id="Academic" style="display:none;">
                                <table class="modern-table">
                                    <thead>
                                        <tr>
                                            <th style="width:50px">#</th>
                                            <th>Session</th>
                                            <th>School / College</th>
                                            <th>Board</th>
                                            <th>Year</th>
                                            <th>Result</th>
                                            <th>Marks</th>
                                            <th style="width:60px"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.AcadmicList != null)
                                        {
                                            int seNo = 1;
                                            foreach (var AcadmicRow in Model.AcadmicList)
                                            {
                                                <tr>
                                                    <td><span class="row-num">@seNo</span></td>
                                                    <td><span class="tag tag-violet">@AcadmicRow.Session</span></td>
                                                    <td>@AcadmicRow.SchoolName</td>
                                                    <td>@AcadmicRow.Board</td>
                                                    <td>@AcadmicRow.PassingYear</td>
                                                    <td>
                                                        <span class="tag @(AcadmicRow.Result == "PASS" ? "tag-emerald" : AcadmicRow.Result == "FAIL" ? "tag-rose" : "tag-amber")">
                                                            @AcadmicRow.Result
                                                        </span>
                                                    </td>
                                                    <td><span class="marks-highlight">@AcadmicRow.ObtMark</span> / @AcadmicRow.MaxMark</td>
                                                    <td>
                                                        <button class="btn-icon-sm delete" title="Delete" onclick="deleteAcadmicDetail(@AcadmicRow.Id)">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                                seNo++;
                                            }
                                        }
                                        @if (Model.AcadmicList == null || !Model.AcadmicList.Any())
                                        {
                                            <tr>
                                                <td colspan="8">
                                                    <div class="empty-state">
                                                        <i class="fas fa-book-open"></i>
                                                        <h4>No academic records</h4>
                                                        <p>Add the first academic detail below.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                <div style="margin-top:1rem;">
                                    <a data-toggle="modal" data-target="#modal-Academic" class="btn-edit-float green" href="#" style="text-decoration:none;">
                                        <i class="fas fa-plus"></i> Add Academic
                                    </a>
                                </div>
                            </div>

                            <!-- ── Document ── -->
                            <div class="tab-pane" id="Document" style="display:none;">
                                <table class="modern-table">
                                    <thead>
                                        <tr>
                                            <th style="width:50px">#</th>
                                            <th>Document</th>
                                            <th>Preview</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><span class="row-num" style="background:var(--violet-100);color:var(--violet-600);">1</span></td>
                                            <td>
                                                <span class="doc-name">Photo</span>
                                                <br><span class="doc-label">Profile photograph</span>
                                            </td>
                                            <td>
                                                <img alt="Photo" onclick="ViewDocument(this)" class="doc-thumb" src="@Model.Photo" style="cursor:pointer">
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><span class="row-num" style="background:var(--amber-100);color:#b45309;">2</span></td>
                                            <td>
                                                <span class="doc-name">Transfer Certificate</span>
                                                <br><span class="doc-label">TC document</span>
                                            </td>
                                            <td>
                                                <img alt="TC" onclick="ViewDocument(this)" class="doc-thumb" src="@Model.TCPhoto" style="cursor:pointer">
                                            </td>
                                        </tr>
                                        @if (Model.DocumentList != null)
                                        {
                                            int docIdx = 3;
                                            string[] docColors = { "var(--emerald-500)", "var(--blue-500)", "var(--pink-500)", "var(--orange-500)" };
                                            string[] docBgs = { "var(--emerald-600)", "var(--blue-600)", "var(--pink-500)", "var(--orange-500)" };
                                            foreach (var row in Model.DocumentList)
                                            {
                                                var cIdx = (docIdx - 3) % docColors.Length;
                                                <tr>
                                                    <td><span class="row-num" style="background:@docColors[cIdx];color:#fff;">@docIdx</span></td>
                                                    <td>
                                                        <span class="doc-name">@row.Key</span>
                                                    </td>
                                                    <td>
                                                        <span class="tag tag-rose" style="font-size:0.75rem;">
                                                            <i class="fas fa-eye"></i> View
                                                        </span>
                                                    </td>
                                                </tr>
                                                docIdx++;
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- ── Promotion ── -->
                            <div class="tab-pane promo-section" id="Promosion" style="display:none;">
                                <div class="detail-grid" style="margin-bottom:0.5rem;">
                                    <div class="promo-form-field">
                                        <label>New Session</label>
                                        <select id="ddlPromotSession" asp-for="Session" asp-items="Model.SessionList">
                                            <option value="">Select</option>
                                        </select>
                                    </div>
                                    <div class="promo-form-field">
                                        <label>New Year</label>
                                        <select id="ddlPromoYear" asp-for="Year" asp-items="Model.YearList">
                                            <option value="">Select</option>
                                        </select>
                                    </div>
                                    <div class="promo-form-field">
                                        <label>New Admission Form No</label>
                                        <input id="txtPromoAdmiFormNo" type="number" placeholder="Form No">
                                    </div>
                                    <div class="promo-form-field">
                                        <label>New Admission Date</label>
                                        <input id="txtPromoAdmiDate" type="date">
                                    </div>
                                </div>
                                <div style="max-width:280px;margin:0 auto;">
                                    <button onclick="SavePromotion()" class="btn-promote">
                                        <i class="fas fa-arrow-up"></i> Promote Student
                                    </button>
                                </div>

                                <div class="promo-arrow-wrap">
                                    <div class="promo-arrow"><i class="fas fa-arrow-up"></i></div>
                                    <span>Promote Up</span>
                                </div>

                                <div class="promo-current">
                                    <div class="section-label"><i class="fas fa-info-circle"></i> Current Status</div>
                                    <div class="detail-grid" style="gap:0.75rem;">
                                        <div class="detail-field" style="background:transparent;border-color:var(--violet-200);">
                                            <label>Session</label>
                                            <input id="txtCurrentSession" asp-for="Session" readonly style="color:var(--violet-700);">
                                        </div>
                                        <div class="detail-field" style="background:transparent;border-color:var(--blue-200);">
                                            <label>Class</label>
                                            <input id="txtPromotClass" asp-for="Class" readonly style="color:var(--blue-600);">
                                        </div>
                                        <div class="detail-field" style="background:transparent;border-color:var(--cyan-200);">
                                            <label>Course</label>
                                            <input id="txtPromotCourse" asp-for="Course" readonly style="color:#0e7490;">
                                        </div>
                                        <div class="detail-field" style="background:transparent;border-color:var(--emerald-200);">
                                            <label>Year</label>
                                            <input id="txtCurrentYear" asp-for="Year" readonly style="color:var(--emerald-600);">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ── History ── -->
                            <div class="tab-pane" id="History" style="display:none;">
                                <table class="modern-table">
                                    <thead>
                                        <tr>
                                            <th style="width:50px">#</th>
                                            <th>Form No</th>
                                            <th>Student</th>
                                            <th>Session</th>
                                            <th>Year</th>
                                            <th>Subject</th>
                                            <th>Mobile</th>
                                            <th style="width:60px"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.StudentHistoryList != null)
                                        {
                                            int hi = 1;
                                            foreach (var hisRow in Model.StudentHistoryList)
                                            {
                                                <tr>
                                                    <td><span class="row-num" style="background:#fdf2f8;color:var(--pink-500);">@hi</span></td>
                                                    <td class="marks-highlight">@hisRow.AdmissionForm</td>
                                                    <td>@hisRow.StudentName</td>
                                                    <td><span class="tag tag-violet">@hisRow.Session</span></td>
                                                    <td><span class="tag tag-emerald">@hisRow.Year</span></td>
                                                    <td>@hisRow.Classs</td>
                                                    <td>@hisRow.MobileNo</td>
                                                    <td>
                                                        <button class="btn-icon-sm view" title="View">
                                                            <i class="fas fa-eye"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                                hi++;
                                            }
                                        }
                                        @if (Model.StudentHistoryList == null || !Model.StudentHistoryList.Any())
                                        {
                                            <tr>
                                                <td colspan="8">
                                                    <div class="empty-state">
                                                        <i class="fas fa-history"></i>
                                                        <h4>No history yet</h4>
                                                        <p>History will appear after promotions.</p>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</div>


<!-- ═══════ MODAL: Personal ═══════ -->
<div class="modal fade" id="modal-Personal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" style="max-width:850px;" role="document">
        <div class="modal-content">
            <div class="modal-header-bar violet">
                <h4><span class="icon-circle"><i class="fas fa-user"></i></span> Edit Personal Detail</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="modal-form-grid">
                    <div class="mf-group">
                        <label>Student Name *</label>
                        <input id="txtStudentName" asp-for="StudentName">
                    </div>
                    <div class="mf-group">
                        <label>Father Name *</label>
                        <input id="txtFatherName" asp-for="FatherName">
                    </div>
                    <div class="mf-group">
                        <label>Mother Name *</label>
                        <input id="txtMotherName" asp-for="MotherName">
                    </div>
                    <div class="mf-group">
                        <label>Mobile No *</label>
                        <input id="txtMobileNo" asp-for="MobileNoOne">
                    </div>
                    <div class="mf-group">
                        <label>Date of Birth *</label>
                        <input id="txtDOB" asp-for="DOB" type="date">
                    </div>
                    <div class="mf-group">
                        <label>Father Mobile *</label>
                        <input id="txtFatherMobileNo" asp-for="FatherMobileNo">
                    </div>
                    <div class="mf-group">
                        <label>Gender *</label>
                        <select id="ddlGender" asp-for="Gender">
                            <option value="">Select</option>
                            <option>Male</option>
                            <option>Female</option>
                        </select>
                    </div>
                    <div class="mf-group">
                        <label>Minority *</label>
