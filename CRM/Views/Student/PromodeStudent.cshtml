                varChangeClass: $('#ddlChangeClass option:selected').text(),
                varChangeCourse: $('#ddlChangeCourse option:selected').text(),
                varChangeYear: $('#ddlChangeYear option:selected').text()
               
            }, function (res) {
                $("#modal-Personal").modal("hide");
                Alert('success', 'Class changed successfully!');
                setTimeout(function () { location.reload(true); }, 600);
            });
        }


        // ── Save College ──
