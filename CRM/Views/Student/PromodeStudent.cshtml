                        <div class="form-group">
                            <label>Passsing Year</label>
                            <select id="ddlAcademicYear" class="form-control">
                                <option>Select</option>
                                <option>2023</option>
                                <option>2024</option>
                                <option>2025</option>
                                <option>2026</option>
                                <option>2027</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-2">
