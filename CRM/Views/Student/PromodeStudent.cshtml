@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var Toast;

        window.onload = function () {
            Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2500,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer);
                    toast.addEventListener('mouseleave', Swal.resumeTimer);
                }
            });
        };

        function Alert(icon, title) {
            Toast.fire({
                icon: icon,
                title: title,
                background: icon === 'success' ? '#ecfdf5' : icon === 'warning' ? '#fffbeb' : icon === 'error' ? '#fef2f2' : '#fff',
                color: icon === 'success' ? '#065f46' : icon === 'warning' ? '#92400e' : icon === 'error' ? '#991b1b' : '#0f172a'
            });
        }

        // ── Tab Switching ──
        function switchTab(tabName, btn) {
            document.querySelectorAll('.tab-pane').forEach(p => p.style.display = 'none');
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(tabName).style.display = 'block';
            btn.classList.add('active');
        }

        // ── Validation ──
        function validateField(selector, message, type) {
            var value = $(selector).val();
            var errorId = selector.replace('#', '') + "Error";

            if (type === "dropdown") {
                if (value === "" || value === "0" || value === null || value === "Select") {
                    $(selector).addClass("is-invalid");
                    if ($("#" + errorId).length === 0) {
                        $(selector).after('<span id="' + errorId + '" class="invalid-feedback"><i class="fas fa-exclamation-circle"></i> ' + message + '</span>');
                    }
                    return false;
                }
            } else {
                if (value === "" || value === undefined || value === null) {
                    $(selector).addClass("is-invalid");
                    if ($("#" + errorId).length === 0) {
                        $(selector).after('<span id="' + errorId + '" class="invalid-feedback"><i class="fas fa-exclamation-circle"></i> ' + message + '</span>');
                    }
                    return false;
                }
                if (type === "mobile") {
                    if (!/^[0-9]{10}$/.test(value)) {
                        $(selector).addClass("is-invalid");
                        if ($("#" + errorId).length === 0) {
                            $(selector).after('<span id="' + errorId + '" class="invalid-feedback"><i class="fas fa-exclamation-circle"></i> Enter valid 10 digit number</span>');
                        }
                        return false;
                    }
                }
            }
            $(selector).removeClass("is-invalid");
            $("#" + errorId).remove();
            return true;
        }

        // ── Save Personal ──
        function SavePersonalDetail() {
            var ok = true;
            if (!validateField("#txtStudentName", "Student name required")) ok = false;
            if (!validateField("#txtFatherName", "Father name required")) ok = false;
            if (!validateField("#txtMotherName", "Mother name required")) ok = false;
            if (!validateField("#txtMobileNo", "Mobile number required", "mobile")) ok = false;
            if (!validateField("#txtFatherMobileNo", "Father mobile required", "mobile")) ok = false;
            if (!validateField("#txtDOB", "Date of birth required")) ok = false;
            if (!validateField("#txtAadhaarNo", "Aadhaar number required")) ok = false;
            if (!validateField("#txtAddress", "Address required")) ok = false;
            if (!validateField("#ddlGender", "Select gender", "dropdown")) ok = false;
            if (!validateField("#ddlMinority", "Select minority", "dropdown")) ok = false;
            if (!validateField("#ddlCaset", "Select caste", "dropdown")) ok = false;
            if (!validateField("#ddlTC", "Select TC", "dropdown")) ok = false;
            if (!validateField("#ddlPH", "Select PH", "dropdown")) ok = false;
            if (!ok) return;

            $.post(BASE_URL + "/Student/SavePromossionDetail11", {
                id: $("#hdnStudentID").val(),
                varStudentName: $("#txtStudentName").val(),
                varFatherName: $("#txtFatherName").val(),
                varMotherName: $("#txtMotherName").val(),
                varMobileNo: $("#txtMobileNo").val(),
                varDOB: $("#txtDOB").val(),
                varFatherMobileNo: $("#txtFatherMobileNo").val(),
                varGender: $('#ddlGender option:selected').text(),
                varMinority: $('#ddlMinority option:selected').text(),
                varCaset: $('#ddlCaset option:selected').text(),
                varAbcNo: $('#txtAbcNo').val(),
                varSamagraID: $("#txtSamagraID").val(),
                varAddress: $("#txtAddress").val(),
                varTC: $('#ddlTC option:selected').text(),
                varPH: $('#ddlPH option:selected').text(),
                varAdhaarNo: $('#txtAadhaarNo').val()
            }, function (res) {
                $("#modal-Personal").modal("hide");
                Alert('success', 'Personal detail saved successfully!');
                setTimeout(function () { location.reload(true); }, 600);
            });
        }

        // ── Save College ──
        function SaveCollegeDetail() {
            var ok = true;
            if (!validateField("#txtAdmissionFormNo", "Admission form no required")) ok = false;
            if (!validateField("#txtEnRollNo", "Enroll no required")) ok = false;
            if (!validateField("#txtAdmissionDate", "Admission date required")) ok = false;
            if (!validateField("#txtRollNo", "Roll no required")) ok = false;
            if (!validateField("#txtSchoolarNo", "Scholar no required")) ok = false;
            if (!validateField("#txtSubCode", "Sub code required")) ok = false;
            if (!validateField("#ddlNewOld", "Select new/old", "dropdown")) ok = false;
            if (!validateField("#ddlMedium", "Select medium", "dropdown")) ok = false;
            if (!validateField("#ddlRegEx", "Select regular/ex", "dropdown")) ok = false;
            if (!ok) return;

            $.post(BASE_URL + "/Student/UpdateCollegeDetail", {
                id: $("#hdnStudentID").val(),
                varSession: "",
                varNewOld: $('#ddlNewOld option:selected').text(),
                varMedium: $('#ddlMedium option:selected').text(),
                varClass: "",
                varCourse: "",
                varYear: "",
                varAdmissionFormNo: $('#txtAdmissionFormNo').val(),
                varEnRollNo: $('#txtEnRollNo').val(),
                varAdmissionDate: $('#txtAdmissionDate').val(),
                varRollNo: $('#txtRollNo').val(),
                varSchoolarNo: $('#txtSchoolarNo').val(),
                varSubCode: $('#txtSubCode').val(),
                varRegEx: $('#ddlRegEx option:selected').text(),
                varExamFormSubmited: $('#ddlExamFormSubmited option:selected').text()
                
            }, function (res) {
                $("#modal-College").modal("hide");
                Alert('success', 'College detail saved successfully!');
                setTimeout(function () { location.reload(true); }, 600);
            });
        }

        // ── Save Academic ──
        function SaveAcadmicDetail() {
            var ok = true;
            if (!validateField("#txtAcademicYear", "Year required")) ok = false;
            if (!validateField("#txtSchoolName", "School name required")) ok = false;
            if (!validateField("#txtBoard", "Board required")) ok = false;
            if (!validateField("#txtMaxMark", "Max marks required")) ok = false;
            if (!validateField("#txtObtMark", "Obtained marks required")) ok = false;
            if (!validateField("#txtParcent", "Percentage required")) ok = false;
            if (!validateField("#txtAcademicAdmissionFormNo", "Form no required")) ok = false;
            if (!validateField("#ddlAcadmicSession", "Select session", "dropdown")) ok = false;
            if (!validateField("#ddlAcadmicClass", "Select class", "dropdown")) ok = false;
            if (!validateField("#ddlAcadmicCourse", "Select course", "dropdown")) ok = false;
            if (!validateField("#ddlResult", "Select result", "dropdown")) ok = false;
            if (!ok) return;

            $.post(BASE_URL + "/Student/UpdateAcadmicDetail", {
                id: $("#hdnStudentID").val(),
                varAcademicYear: $('#txtAcademicYear').val(),
                varAcadmicSession: $('#ddlAcadmicSession option:selected').text(),
                varAcadmicClass: $('#ddlAcadmicClass option:selected').text(),
                varAcadmicCourse: $('#ddlAcadmicCourse option:selected').text(),
                varSchoolName: $('#txtSchoolName').val(),
                varBoard: $('#txtBoard').val(),
                varMaxMark: $('#txtMaxMark').val(),
                varObtMark: $('#txtObtMark').val(),
                varResult: $('#ddlResult option:selected').text(),
                varParcent: $('#txtParcent').val(),
                varAdmissionFormNo: $('#txtAcademicAdmissionFormNo').val()
            }, function (res) {
                $("#modal-Academic").modal("hide");
                Alert('success', 'Academic detail saved successfully!');
                setTimeout(function () { location.reload(true); }, 600);
            });
        }

        // ── Save Promotion ──
        function SavePromotion() {
            var ok = true;
            if (!validateField("#txtPromoAdmiFormNo", "Form no required")) ok = false;
            if (!validateField("#txtPromoAdmiDate", "Date required")) ok = false;
            if (!validateField("#ddlPromoYear", "Select year", "dropdown")) ok = false;
            if (!validateField("#ddlPromotSession", "Select session", "dropdown")) ok = false;
            if (!ok) return;

            $.post(BASE_URL + "/Student/PromotStudent", {
                id: $("#hdnStudentID").val(),
                varPromotSession: $('#ddlPromotSession option:selected').text(),
                varPromotClass: $('#txtPromotClass').val(),
                varPromotCourse: $('#txtPromotCourse').val(),
                varPromoYear: $('#ddlPromoYear option:selected').text(),
                varCurrentYear: $('#txtCurrentYear').val(),
                varCurrentSession: $('#txtCurrentSession').val(),
                varPromotFormNo: $('#txtPromoAdmiFormNo').val(),
                varPromotDate: $('#txtPromoAdmiDate').val()
            }, function (res) {
                Alert('success', 'Student promoted successfully!');
                setTimeout(function () { location.reload(true); }, 600);
            });
        }

        // ── Delete Academic ──
        function deleteAcadmicDetail(id) {
            Swal.fire({
                title: 'Delete Record?',
                text: 'This action cannot be undone.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Yes, delete',
                cancelButtonText: 'Cancel',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post(BASE_URL + "/Student/Delete", { id: id }, function (res) {
                        Alert('success', 'Record deleted successfully!');
                        setTimeout(function () { location.reload(true); }, 600);
                    });
                }
            });
        }

        // ── View Document ──
        function ViewDocument(element) {
            var imgSrc = $(element).attr("src");
            $("#imgViewDocument").attr("src", imgSrc);
            $("#modal-ViewDocument").modal("show");
        }

        // ── Clear modal fields on close ──
        $('#modal-Personal, #modal-College, #modal-Academic').on('hidden.bs.modal', function () {
            $(this).find('.is-invalid').removeClass('is-invalid');
            $(this).find('.invalid-feedback').remove();
        });
    </script>
}