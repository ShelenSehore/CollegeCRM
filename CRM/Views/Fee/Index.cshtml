@model CRM.ModelsForView.FeeViewModel

@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    var baseUrl = ViewBag.BaseUrl;
}

<div class="content-wrapper">

    <!-- Header -->
    <section class="content-header">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Fee Management</h4>
            <a class="btn btn-primary" href="@Url.Action("AddFee", "Fee")">
                <i class="fas fa-plus"></i> Add Fee
            </a>
        </div>
    </section>

    <!-- Content -->
    <section class="content">
        <div class="container-fluid">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Fee Structure List</h5>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">

                        <table class="table table-hover table-striped mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th>#</th>
                                    <th>Type</th>
                                    <th>Session</th>
                                    <th>Year</th>
                                    <th>Class</th>
                                    <th>Course</th>
                                    <th class="text-center">Fee Details</th>
                                    <th class="text-center">Total</th>
                                    <th class="text-center">Action</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int i = 1;
                                }

                                @if (Model.FeeClassList != null && Model.FeeClassList.Any())
                                {
                                    foreach (var item in Model.FeeClassList)
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td>
                                                <span class="badge badge-info">
                                                    @item.NewOld
                                                </span>
                                            </td>
                                            <td>@item.Session</td>
                                            <td>@item.Year</td>
                                            <td>@item.Subject</td>
                                            <td>@item.Course</td>

                                            <!-- Fee Breakdown -->
                                            <td class="small">
                                                <div><strong>Admission:</strong> ₹@item.NewStudentFee</div>
                                                <div><strong>CMoney:</strong> ₹@item.CMoney</div>
                                                <div><strong>Tution:</strong> ₹@item.TutionFee</div>
                                                <div><strong>Other:</strong> ₹@item.OtherFee</div>
                                            </td>

                                            <!-- Total Highlight -->
                                            <td class="text-center">
                                                <span class="badge badge-success p-2">
                                                    ₹@item.TotalFee
                                                </span>
                                            </td>

                                            <!-- Action -->
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-danger"
                                                        onclick="deleteFee(@item.Id)">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        i++;
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="9" class="text-center text-muted p-4">
                                            No fee records found
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>

                    </div>
                </div>
            </div>

        </div>
    </section>
</div>

@section Scripts {
    <script>
    var BASE_URL = "@baseUrl";

    var Toast;

    $(document).ready(function () {
        Toast = Swal.mixin({
            toast: true,
            position: 'top-right',
            timer: 1500,
            showConfirmButton: false
        });
    });

    function Alert(icon, title) {
        Toast.fire({ icon: icon, title: title });
    }

    // DELETE
    function deleteFee(id) {
        Swal.fire({
            title: "Delete Fee?",
            text: "This action cannot be undone",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33"
        }).then((result) => {
            if (result.isConfirmed) {
                $.post(BASE_URL + "/Fee/DeleteFee", { id: id }, function () {
                    Alert('success', 'Deleted successfully');
                    location.reload();
                });
            }
        });
    }
    </script>
}