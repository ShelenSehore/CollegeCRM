@model CRM.ModelsForView.FeeViewModel

@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    var baseUrl = ViewBag.BaseUrl;
}

<!-- Custom Modern Styles -->
<style>
    .modern-card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

        .modern-card .card-header {
            background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
            padding: 1rem 1.5rem;
            border-bottom: none;
        }

            .modern-card .card-header h5 {
                font-weight: 600;
                letter-spacing: 0.5px;
            }

    .modern-table thead th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
        color: #495057;
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 1rem 0.75rem;
    }

    .modern-table tbody tr {
        transition: all 0.2s ease;
    }

        .modern-table tbody tr:hover {
            background-color: #f1f3f5;
            transform: translateY(-1px);
        }

    .modern-table td {
        vertical-align: middle;
        padding: 0.85rem 0.75rem;
        border-color: #f1f1f1;
    }

    .badge-pill-custom {
        padding: 0.5em 0.9em;
        border-radius: 50rem;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .fee-detail-box {
        background: #f8f9fa;
        padding: 8px 12px;
        border-radius: 8px;
        line-height: 1.6;
    }

        .fee-detail-box div {
            font-size: 0.85rem;
        }

    /* Pagination Styles */
    .pagination-footer {
        background: #ffffff;
        border-top: 1px solid #e9ecef;
        padding: 1rem 1.5rem;
        border-radius: 0 0 12px 12px;
    }

    .page-btn {
        border: 1px solid #dee2e6;
        background: #fff;
        color: #007bff;
        padding: 6px 14px;
        margin: 0 3px;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
        font-weight: 500;
    }

        .page-btn:hover:not(.disabled) {
            background: #e9ecef;
            border-color: #ced4da;
        }

        .page-btn.active {
            background: #007bff;
            color: #fff;
            border-color: #007bff;
            box-shadow: 0 2px 5px rgba(0,123,255,0.3);
        }

        .page-btn.disabled {
            color: #ced4da;
            cursor: not-allowed;
            opacity: 0.7;
        }

    .btn-action-delete {
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        transition: all 0.2s;
    }

        .btn-action-delete:hover {
            transform: scale(1.1);
        }
</style>

<div class="content-wrapper">

    <!-- Header -->
    <section class="content-header">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <h4 class="mb-0 font-weight-bold">Fee Management</h4>
            <a class="btn btn-primary btn-lg rounded-pill shadow-sm" href="@Url.Action("AddFee", "Fee")">
                <i class="fas fa-plus mr-1"></i> Add Fee
            </a>
        </div>
    </section>

    <!-- Content -->
    <section class="content">

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label><i class="fas fa-calendar-alt"></i> Session</label>
                    <select id="ddlSession" class="form-control modern-input" asp-items="Model.SessionList" asp-for="Session">
                        <option value="">Select Session</option>
                    </select>
                </div>
            </div>

            <div class="col-md-4">
                <div class="form-group">
                    <label><i class="fas fa-user-tag"></i> New / Old</label>
                    <select id="ddlNewOld" class="form-control modern-input" asp-for="NewOld">
                        <option value="">Select Type</option>
                        <option>New</option>
                        <option>Old</option>
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label><i class="fas fa-calendar-day"></i> Year</label>
                    <select id="ddlYear" asp-for="Year" asp-items="Model.YearList" class="form-control modern-input">
                        <option value="">Select Year</option>
                    </select>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label><i class="fas fa-chalkboard"></i> Class</label>
                    <select id="ddlClass" asp-for="Subject" asp-items="Model.ClassList" class="form-control modern-input">
                        <option value="">Select Class</option>
                    </select>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label><i class="fas fa-book-open"></i> Course</label>
                    <select id="ddlCourse" asp-for="Course" asp-items="Model.SubjectList" class="form-control modern-input">
                        <option value="">Select Course</option>
                    </select>
                </div>
            </div>

        </div>

        <div class="container-fluid">

            <div class="card modern-card">


                <div class="card-header text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-list-ul mr-2"></i>Fee Structure List</h5>                    
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">

                        <table class="table table-hover mb-0 modern-table" id="feeTable">
                            <thead>
                                <tr>
                                    <th width="60">#</th>
                                    <th>Type</th>
                                    <th>Session</th>
                                    <th>Year</th>
                                    <th>Class</th>
                                    <th>Course</th>
                                    <th class="text-center">Fee Details</th>
                                    <th class="text-center">Total</th>
                                    <th class="text-center" width="80">Action</th>
                                </tr>
                            </thead>

                            <tbody >
                                
                            </tbody>

                        </table>

                    </div>
                </div>

                <!-- Pagination Footer -->
                @if (Model.FeeClassList != null && Model.FeeClassList.Count() > 50)
                {
                    <div class="pagination-footer d-flex justify-content-between align-items-center">
                        <div id="pagingInfo" class="text-muted small font-weight-bold"></div>
                        <div id="paginationControls" class="d-flex align-items-center"></div>
                    </div>
                }
            </div>

        </div>
    </section>
</div>

@section Scripts {
    <script src="~/plugins/jquery/jquery.js"></script>
    <script src="~/plugins/jquery/jquery.min.js"></script>
    <script>
    var BASE_URL = "@baseUrl";
        var Toast;
        var allStudents = [];
        var currentPage = 1;
        var pageSize = 50;
        var selectedIds = new Set();
        var currentPrintMode = 'all';

    $(document).ready(function () {
        Toast = Swal.mixin({
            toast: true,
            position: 'top-right',
            timer: 1500,
            showConfirmButton: false
        });

        // Set total record count
        var totalRecords = $('.fee-row').length;
        $('#totalRecordBadge').text(totalRecords + ' Records');

        // Initialize Pagination if more than 50 records
        if (totalRecords > 50) {
            setupPagination();
        }

        //----------Dropdown change for Filters--------
        $("#ddlSession, #ddlNewOld, #ddlYear, #ddlClass, #ddlCourse").change(function () {
            SearchFee();
        });
        //----------Fill Table----
        SearchFee();
    });


        function SearchFee() {
            var varClass = $('#ddlClass option:selected').text();
            var varYear = $('#ddlYear option:selected').text();
            var varCourse = $('#ddlCourse option:selected').text();
            var varSession = $('#ddlSession option:selected').text();
            var varNewOld = $("#ddlNewOld option:selected").text();

            $.post(BASE_URL + "/Fee/SearchFee", {
                classes: varClass,
                course: varCourse,
                year: varYear,
                session: varSession,
                newOld: varNewOld
            }, function (res) {

                var tableData = res.data || [];
                allStudents = tableData;
                currentPage = 1;
               // selectedIds.clear();
                $('#statSelected').text(0);
               // updateStats(allStudents);
                RenderPage();
            });
        }


    function Alert(icon, title) {
        Toast.fire({ icon: icon, title: title });
    }

    // ── Pagination Logic (50 per page) ──
    function setupPagination() {
        var pageSize = 50;
        var $rows = $('#feeTableBody .fee-row');
        var totalRows = $rows.length;
        var totalPages = Math.ceil(totalRows / pageSize);
        var currentPage = 1;

        function displayPage(page) {
            currentPage = page;
            var start = (page - 1) * pageSize;
            var end = start + pageSize;

            $rows.hide().slice(start, end).show();

            var endIdx = Math.min(end, totalRows);
            $('#pagingInfo').text('Showing ' + (start + 1) + ' to ' + endIdx + ' of ' + totalRows + ' entries');

            renderPaginationButtons(page);
        }

        function renderPaginationButtons(page) {
            var $controls = $('#paginationControls');
            $controls.empty();

            // Previous Button
            $controls.append('<button class="page-btn ' + (page === 1 ? 'disabled' : '') + '" data-page="' + (page - 1) + '">« Prev</button>');

            // Page Numbers Logic (Show max 3 pages around current, with first/last always visible)
            var startPage = Math.max(1, page - 1);
            var endPage = Math.min(totalPages, page + 1);

            if (page === 1) endPage = Math.min(3, totalPages);
            if (page === totalPages) startPage = Math.max(1, totalPages - 2);

            if (startPage > 1) {
                $controls.append('<button class="page-btn" data-page="1">1</button>');
                if (startPage > 2) $controls.append('<span class="px-1 text-muted">...</span>');
            }

            for (var i = startPage; i <= endPage; i++) {
                $controls.append('<button class="page-btn ' + (i === page ? 'active' : '') + '" data-page="' + i + '">' + i + '</button>');
            }

            if (endPage < totalPages) {
                if (endPage < totalPages - 1) $controls.append('<span class="px-1 text-muted">...</span>');
                $controls.append('<button class="page-btn" data-page="' + totalPages + '">' + totalPages + '</button>');
            }

            // Next Button
            $controls.append('<button class="page-btn ' + (page === totalPages ? 'disabled' : '') + '" data-page="' + (page + 1) + '">Next »</button>');
        }

        // Event Delegation for Pagination Clicks
        $('#paginationControls').on('click', '.page-btn:not(.disabled)', function() {
            var targetPage = $(this).data('page');
            if (targetPage >= 1 && targetPage <= totalPages) {
                displayPage(targetPage);
                // Scroll to top of table smoothly
                $('html, body').animate({ scrollTop: $('#feeTable').offset().top - 100 }, 300);
            }
        });

        // Initialize first page
        displayPage(1);
    }

    // DELETE
    function deleteFee(id) {
        Swal.fire({
            title: "Delete Fee?",
            text: "This action cannot be undone",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            confirmButtonText: "Yes, delete it!",
            customClass: {
                confirmButton: 'btn btn-danger',
                cancelButton: 'btn btn-default'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                $.post(BASE_URL + "/Fee/DeleteFee", { id: id }, function () {
                    Alert('success', 'Deleted successfully');
                    location.reload();
                });
            }
        });
    }


        function RenderTable(pageData) {

            debugger;
            $("#feeTable tbody").empty();

            if (allStudents.length === 0) {
                $("#feeTable tbody").append(
                    '<tr><td colspan="14">' +
                    '<div class="empty-state">' +
                    '<div class="empty-icon"><i class="fas fa-inbox"></i></div>' +
                    '<div class="empty-title">No students found</div>' +
                    '<div class="empty-desc">Try adjusting your filters or search term</div>' +
                    '</div></td></tr>'
                );
                return;
            }

            var startIndex = (currentPage - 1) * pageSize;
            debugger;
            $.each(pageData, function (index, element) {
                var globalIndex = startIndex + index;
                var delay = Math.min(index * 0.03, 0.8);



                var row =
                    '<tr>'+
                    '<td> ' + globalIndex + '</td><td>' + element.newOld + '</td><td>' + element.session + '</td>' +
                    '<td> ' + element.year + '</td><td>' + element.subject + '</td><td>' + element.course + '</td>' +
                    '<td> <div class="fee-detail-box"><div><strong>Admission:</strong> ₹ ' + element.newStudentFee + ' </div><div><strong>CMoney:</strong> ₹' + element.cMoney + '</div> <div><strong>Tution:</strong> ₹' + element.totalFee + '</div><div><strong>Other:</strong> ₹' + element.otherFee+'</div></div></td>' +
                    '<td>' + element.totalFeeCM + '</td>' +
                    '<td><button class="btn btn-danger btn-action-delete" onclick="deleteFee(' + element.id + ')" title="Delete"><i class="fas fa-trash-alt"></i></button> </td>' +
                    '</tr>';

                $("#feeTable").append(row);
            });


        }


        function GetTotalPages() {
            if (allStudents.length === 0) return 1;
            return Math.ceil(allStudents.length / pageSize);
        }

        function GetPageData() {
            var start = (currentPage - 1) * pageSize;
            var end = start + pageSize;
            return allStudents.slice(start, end);
        }

        function GoToPage(page) {
            var total = GetTotalPages();
            if (page < 1 || page > total) return;
            currentPage = page;
            RenderPage();
            document.querySelector('.table-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function ChangePageSize(size) {
            pageSize = parseInt(size) || 50;
            currentPage = 1;
            RenderPage();
        }

        function RenderPage() {
            debugger;
            var pageData = GetPageData();
            RenderTable(pageData);
            RenderPagination();
        }


    </script>
}