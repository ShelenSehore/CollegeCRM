@section Scripts {
    <script src="~/ValidateJS/jquery-3.6.0.min.js"></script>
    <script src="~/ValidateJS/jquery.validate.min.js"></script>
    <script src="~/ValidateJS/jquery.validate.unobtrusive.min.js"></script>

    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var Toast;

        var varSession = "";
        var varYear = "";
        var varSubject = "";
        var varClass = "";

        /* ===== Helper: format number as Indian currency ===== */
        function formatCurrency(num) {
            var n = parseFloat(num) || 0;
            return '₹' + n.toLocaleString('en-IN');
        }

        /* ===== Sync all fee display elements ===== */
        function syncFeeDisplay() {
            var newFee  = parseFloat($('#txtNewStudentFee').val()) || 0;
            var cMoney  = parseFloat($('#txtCMondy').val()) || 0;
            var tFee    = parseFloat($('#txtTutionFee').val()) || 0;
            var oFee    = parseFloat($('#txtOtherFee').val()) || 0;
            var totalFee = parseFloat($('#txtTotalFee').val()) || 0;
            var afterDis = parseFloat($('#txtTotalFeeAfterDiscount').val()) || 0;

            /* Mini cards */
            $('#dispNewStudentFee').text(formatCurrency(newFee));
            $('#dispCMoney').text(formatCurrency(cMoney));
            $('#dispTutionFee').text(formatCurrency(tFee));
            $('#dispOtherFee').text(formatCurrency(oFee));

            /* Total boxes */
            $('#txtTotalFeeDisplay').text(formatCurrency(totalFee));
            $('#txtAfterDisDisplay').text(formatCurrency(afterDis));
        }

        /* ===== Animate fee value change ===== */
        function animateFeeChange(elementId) {
            var $el = $(elementId);
            $el.css({ transform: 'scale(1.15)', transition: '.3s' });
            setTimeout(function () {
                $el.css({ transform: 'scale(1)' });
            }, 300);
        }

        /* ===== Update banner info chips ===== */
        function updateBannerChips() {
            var regNo = $('#RegNo').val() || '—';
            var cls = $('#ddlClass').val() || '—';
            var course = $('#ddlSubject').val() || '—';
            $('#bannerRegNo').text(regNo);
            $('#bannerClass').text(cls);
            $('#bannerCourse').text(course);
        }

        window.onload = function () {

            /* SweetAlert2 Toast */
            Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2500,
                timerProgressBar: true,
                didOpen: function (toast) {
                    toast.onmouseenter = Swal.stopTimer;
                    toast.onmouseleave = Swal.resumeTimer;
                }
            });

            /* Scholarship change → recalculate discount (real-time) */
            $("#Scholership").on('input change', function () {
                var varScholership = this.value;
                if (varScholership !== "" && varScholership !== "0") {
                    var scholershipAmount = parseFloat(varScholership) || 0;
                    var totalFeeAmount   = parseFloat($('#txtTotalFee').val()) || 0;
                    var afterDiscount    = Math.max(0, totalFeeAmount - scholershipAmount);
                    $('#txtTotalFeeAfterDiscount').val(afterDiscount);
                } else {
                    var totalFeeAmount = parseFloat($('#txtTotalFee').val()) || 0;
                    $('#txtTotalFeeAfterDiscount').val(totalFeeAmount);
                }
                syncFeeDisplay();
                animateFeeChange('#txtAfterDisDisplay');
            });

            /* Dropdowns → trigger fee fetch when all 4 are selected */
            $("#ddlSession").change(function () {
                varSession = this.value;
                updateBannerChips();
                if (varSession && varYear && varSubject && varClass) FillFeeeDetail();
            });
            $("#ddlYear").change(function () {
                varYear = this.value;
                if (varSession && varYear && varSubject && varClass) FillFeeeDetail();
            });
            $("#ddlSubject").change(function () {
                varSubject = this.value;
                updateBannerChips();
                if (varSession && varYear && varSubject && varClass) FillFeeeDetail();
            });
            $("#ddlClass").change(function () {
                varClass = this.value;
                updateBannerChips();
                if (varSession && varYear && varSubject && varClass) FillFeeeDetail();
            });

            /* Initial sync — display existing model values */
            syncFeeDisplay();
            updateBannerChips();
        };

        function Alert(icon, title) {
            Toast.fire({ icon: icon, title: title });
        }

        function FillFeeeDetail() {
            /* Show loading state */
            $('#feeMiniGrid').addClass('fee-loading');

            if (varSession && varYear && varSubject && varClass) {
                $.post(BASE_URL + "/Admission/StudentPaymentDetail", {
                    classname: varClass,
                    course: varSubject,
                    session: varSession,
                    year: varYear
                }, function (res) {
                    $('#feeMiniGrid').removeClass('fee-loading');

                    var Feedetail = res.data.feeMasterDetail;
                    if (Feedetail != null && Feedetail != '') {
                        $('#txtNewStudentFee').val(Feedetail.newStudentFee);
                        $('#txtCMondy').val(Feedetail.cMoney);
                        $('#txtTutionFee').val(Feedetail.tutionFee);
                        $('#txtOtherFee').val(Feedetail.otherFee);
                        $('#txtTotalFee').val(Feedetail.totalFee);
                        $('#txtTotalFeeAfterDiscount').val(Feedetail.totalFee);
                        syncFeeDisplay();

                        /* Animate total boxes */
                        animateFeeChange('#txtTotalFeeDisplay');
                        animateFeeChange('#txtAfterDisDisplay');

                        Alert('success', 'Fee details refreshed!');
                    } else {
                        Alert('warning', 'Fee not found for selected combination.');
                    }
                }).fail(function () {
                    $('#feeMiniGrid').removeClass('fee-loading');
                    Alert('error', 'Error fetching fee details.');
                });
            }
        }
    </script>
}