<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item"><a href="#">Admission</a></li>
                        <li class="breadcrumb-item active">Student List</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="content">
        <div class="container-fluid">

            <!-- PAGE BANNER -->
            <div class="page-banner">
                <h1>Student Admission List</h1>
                <p>Search, filter and manage all student admissions</p>
                <i class="fas fa-users banner-icon"></i>
            </div>

            <!-- STAT CARDS -->
            <div class="stat-row">
                <div class="stat-card total">
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Total Students</div>
                        <div class="stat-value" id="statTotal">0</div>
                    </div>
                </div>
                <div class="stat-card session">
                    <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Active Session</div>
                        <div class="stat-value" id="statSession">—</div>
                    </div>
                </div>
                <div class="stat-card course">
                    <div class="stat-icon"><i class="fas fa-book-open"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Courses</div>
                        <div class="stat-value" id="statCourse">—</div>
                    </div>
                </div>
                <div class="stat-card selected">
                    <div class="stat-icon"><i class="fas fa-check-double"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Selected</div>
                        <div class="stat-value" id="statSelected">0</div>
                    </div>
                </div>
            </div>

            <!-- FILTER PANEL -->
            <div class="filter-panel">
                <div class="filter-header">
                    <i class="fas fa-filter fh-icon"></i>
                    <h3 class="fh-title">Filters</h3>
                    <span class="fh-badge">Narrow Results</span>
                </div>
                <div class="filter-body">
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Session</label>
                                <select id="ddlSession" asp-items="Model.SessionList" class="form-control">
                                    <option value="">Select</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Year</label>
                                <select id="ddlYear" asp-items="Model.YearList" class="form-control">
                                    <option value="">Select</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Class</label>
                                <select id="ddlClass" asp-items="Model.ClassList" class="form-control">
                                    <option value="">Select</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label>Course</label>
                                <select id="ddlCourse" asp-items="Model.SubjectList" class="form-control">
                                    <option value="">Select</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Student Name</label>
                                <div style="position:relative">
                                    <i class="fas fa-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.82rem"></i>
                                    <input id="txtSearch" class="form-control" type="search" placeholder="Type to search..."
                                           aria-label="Search" style="padding-left:34px">
                                </div>
                            </div>
                        </div>
                        <input type="hidden" id="hdnSelected" />
                    </div>
                </div>
                <div class="filter-actions">
                    <button type="button" id="btnSearch" onclick="SearchStudent()" class="btn-search">
                        <i class="fas fa-search"></i> Search
                    </button>
                    <button type="reset" class="btn-reset" onclick="Reset()">
                        <i class="fas fa-rotate-left"></i> Reset
                    </button>
                    <div class="action-separator"></div>
                    <div style="position:relative;display:inline-block">
                        <div class="btn-action-group">
                            <button type="button" class="btn-action-main" onclick="AdmissionCompleted()">
                                <i class="fas fa-clipboard-check"></i> Action
                            </button>
                            <button type="button" class="btn-action-toggle" data-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-chevron-down"></i>
                            </button>
                        </div>
                        <div class="dropdown-menu" role="menu">
                            <a class="btn btn-default" onclick="AdmissionCompleted()">
                                <i class="fas fa-check-circle"></i> Admission Done
                            </a>
                        </div>
                    </div>
                    <div class="action-separator"></div>
                    <form id="frmDownloadExcel" method="post" action="DownloadExcel" style="display:inline">
                        <input type="hidden" name="hdnExcelSession" id="hdnExcelSession" />
                        <input type="hidden" name="hdnExcelClass" id="hdnExcelClass" />
                        <input type="hidden" name="hdnExcelCourse" id="hdnExcelCourse" />
                        <input type="hidden" name="hdnExcelYear" id="hdnExcelYear" />
                        <input type="hidden" name="hdnExcelName" id="hdnExcelName" />
                    </form>
                    <button type="button" id="btnDownloadExcel" onclick="DownloadExcel()" class="btn-excel">
                        <i class="fas fa-file-excel"></i> Excel
                    </button>
                    <div class="action-separator"></div>


                    <!-- ===== PRINT BUTTON WITH DROPDOWN ===== -->
                    <div class="print-dropdown-wrapper" id="printDropdownWrapper">
                        <button type="button" class="btn-print" onclick="togglePrintDropdown(event)">
                            <i class="fas fa-print"></i> Print
                        </button>
                        <div class="print-dropdown-menu" id="printDropdownMenu">
                            <button class="print-option" onclick="openPrintPreview('all')">
                                <i class="fas fa-list"></i>
                                <div>
                                    <div>All Records</div>
                                    <div class="po-desc">Print all filtered students</div>
                                </div>
                            </button>
                            <button class="print-option" onclick="openPrintPreview('page')">
                                <i class="fas fa-file-alt"></i>
                                <div>
                                    <div>Current Page</div>
                                    <div class="po-desc">Print only the visible page</div>
                                </div>
                            </button>
                            <button class="print-option" onclick="openPrintPreview('selected')">
                                <i class="fas fa-check-square"></i>
                                <div>
                                    <div>Selected Only</div>
                                    <div class="po-desc">Print checked students</div>
                                </div>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TABLE PANEL -->
            <div class="table-panel">
                <div class="table-top-strip"></div>
                <div class="table-header-bar">
                    <div class="thb-left">
                        <i class="fas fa-table-list thb-icon"></i>
                        <h3 class="thb-title">Students</h3>
                        <span class="thb-count" id="tableCount">0 records</span>
                    </div>
                    <div class="page-size-select">
                        <label for="ddlPageSize">Per page</label>
                        <select id="ddlPageSize">
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100" selected>100</option>
                            <option value="200">200</option>
                            <option value="300">300</option>
                            <option value="400">400</option>
                            <option value="500">500</option>
                        </select>
                    </div>
                </div>

                <div class="select-all-bar" id="selectAllBar">
                    <i class="fas fa-check-circle"></i>
                    <span><span class="sa-count" id="saCount">0</span> selected on this page</span>
                    <span class="sa-link" id="saSelectAll" onclick="selectAllAcrossPages()">Select all <strong id="saTotalLabel">0</strong> records</span>
                    <span class="sa-clear" onclick="clearAllSelections()"><i class="fas fa-times"></i> Clear selection</span>
                </div>

                <div class="table-scroll">
                    <table class="custom-table" id="tblStudentList">
                        <thead>
                            <tr>
                                <th style="width:50px;text-align:center">#</th>
                                <th>Reg No</th>
                                <th>Session</th>
                                <th>Student Name</th>
                                <th>Father Name</th>
                                <th>Mobile</th>
                                <th>Year</th>
                                <th>Subject</th>
                                <th>Course</th>
                                <th>Status</th>
                                <th style="width:60px;text-align:center">View</th>
                                <th style="width:55px;text-align:center">Select</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody"></tbody>
                    </table>
                </div>

                <div class="pagination-footer" id="paginationFooter">
                    <div class="page-info" id="pageInfo">
                        Showing <strong>0</strong> to <strong>0</strong> of <strong>0</strong> records
                    </div>
                    <div class="pagination-nav" id="paginationNav"></div>
                </div>
            </div>

        </div>
    </section>
</div>

<!-- ===== PRINT PREVIEW OVERLAY ===== -->
<div class="print-preview-overlay" id="printPreviewOverlay">
    <div class="print-preview-container">
        <div class="print-preview-toolbar">
            <div class="ppt-left">
                <i class="fas fa-print ppt-icon"></i>
                <div>
                    <div class="ppt-title">Print Preview</div>
                    <div class="ppt-subtitle" id="pptSubtitle">All Records</div>
                </div>
            </div>
            <div class="ppt-actions">
                <button type="button" class="ppt-btn ppt-btn-print" onclick="executePrint()">
                    <i class="fas fa-print"></i> Print
                </button>
                <button type="button" class="ppt-btn ppt-btn-close" onclick="closePrintPreview()">
                    <i class="fas fa-times"></i> Close
                </button>
            </div>
        </div>
        <div class="print-preview-body" id="printPreviewBody">
            <!-- Print content injected here -->
        </div>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="modal-default">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title"><i class="fas fa-exchange-alt"></i> Change Status</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Status</label>
                    <select id="ddlStatus" class="form-control">
                        <option value="">Select</option>
                        <option>Inquiry</option>
                        <option>Done</option>
                        <option>Follow</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveClass()">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var Toast;
        var allStudentData = [];

        var currentPage = 1;
        var pageSize = 100;
        var selectedIds = new Set();
        var allPagesSelected = false;

        /* Track which print mode was chosen */
        var currentPrintMode = 'all';

        window.onload = function () {

            Toast = Swal.mixin({
                toast: true, position: 'top-end',
                showConfirmButton: false, timer: 2000, timerProgressBar: true,
            });

            $("#ddlClass, #ddlYear, #ddlCourse, #ddlSession").change(function () {
                currentPage = 1;
                SearchStudent();
            });

            $("#ddlPageSize").change(function () {
                pageSize = parseInt($(this).val()) || 100;
                currentPage = 1;
                renderPage();
            });

            var searchTimer;
            $("#txtSearch").on('input', function () {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(function () {
                    currentPage = 1;
                    SearchStudent();
                }, 350);
            });

            $(document).on('change', 'input[name="chkStudent"]', function () {
                var id = this.id;
                if (this.checked) {
                    selectedIds.add(id);
                } else {
                    selectedIds.delete(id);
                    allPagesSelected = false;
                }
                updateSelectionBar();
            });

            /* Close print dropdown on outside click */
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#printDropdownWrapper').length) {
                    $('#printDropdownMenu').removeClass('show');
                }
            });

            /* Close print preview on Escape */
            $(document).on('keydown', function (e) {
                if (e.key === 'Escape') {
                    closePrintPreview();
                }
            });

            SearchStudent();
        };

        function Alert(icon, title, className) {
            Toast.fire({ icon: icon, title: title, class: className });
        }

        function SearchStudent() {
            var name = $("#txtSearch").val();
            var varClass = $('#ddlClass option:selected').text();
            var varYear = $('#ddlYear option:selected').text();
            var varCourse = $('#ddlCourse option:selected').text();
            var varSession = $('#ddlSession option:selected').text();

            $.post(BASE_URL + "/Admission/SearchList", {
                name: name, classes: varClass,
                year: varYear, course: varCourse, session: varSession
            }, function (res) {
                allStudentData = res.data || [];
                currentPage = 1;
                selectedIds.clear();
                allPagesSelected = false;
                updateStats(allStudentData);
                renderPage();
            });
        }

        function updateStats(data) {
            var sessions = new Set();
            var courses = new Set();
            $.each(data, function (i, el) {
                if (el.session) sessions.add(el.session);
                if (el.course) courses.add(el.course);
            });

            $('#statTotal').text(data.length);
            $('#tableCount').text(data.length + ' record' + (data.length !== 1 ? 's' : ''));

            if (sessions.size > 0) {
                $('#statSession').text(sessions.size);
                $('#statSession').css('font-size', sessions.size > 9 ? '1.3rem' : '1.65rem');
            } else {
                $('#statSession').text('—');
            }
            if (courses.size > 0) {
                $('#statCourse').text(courses.size);
                $('#statCourse').css('font-size', courses.size > 9 ? '1.3rem' : '1.65rem');
            } else {
                $('#statCourse').text('—');
            }
            $('#statSelected').text(selectedIds.size);
        }

        function renderPage() {
            var totalRecords = allStudentData.length;
            var totalPages = Math.ceil(totalRecords / pageSize) || 1;

            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            var startIndex = (currentPage - 1) * pageSize;
            var endIndex = Math.min(startIndex + pageSize, totalRecords);
            var pageData = allStudentData.slice(startIndex, endIndex);

            $("#tblStudentList tbody").empty();

            if (totalRecords === 0) {
                $("#tblStudentList tbody").append(
                    '<tr><td colspan="12">' +
                    '<div class="empty-state">' +
                    '<div class="empty-icon"><i class="fas fa-inbox"></i></div>' +
                    '<div class="empty-title">No students found</div>' +
                    '<div class="empty-desc">Try adjusting your filters or search term</div>' +
                    '</div></td></tr>'
                );
            } else {
                $.each(pageData, function (index, element) {
                    var globalIndex = startIndex + index + 1;
                    var statusClass = getStatusClass(element.status);
                    var statusText = element.status || 'N/A';
                    var isChecked = selectedIds.has(String(element.id)) ? 'checked' : '';
                    var rowDelay = Math.min(index * 0.02, 0.8);

                    var row = '<tr style="animation-delay:' + rowDelay + 's">' +
                        '<td class="col-num">' + globalIndex + '</td>' +
                        '<td><span class="reg-badge">' + esc(element.regNo) + '</span></td>' +
                        '<td><span class="info-tag session">' + esc(element.session) + '</span></td>' +
                        '<td><span class="student-name">' + esc(element.name) + '</span></td>' +
                        '<td><span class="father-name">' + esc(element.fatherName) + '</span></td>' +
                        '<td><span class="mobile-pill"><i class="fas fa-phone"></i> ' + esc(element.mobileNo) + '</span></td>' +
                        '<td><span class="info-tag year">' + esc(element.year) + '</span></td>' +
                        '<td><span class="info-tag subject">' + esc(element.subject) + '</span></td>' +
                        '<td><span class="info-tag course">' + esc(element.course) + '</span></td>' +
                        '<td><span class="status-badge ' + statusClass + '">' + esc(statusText) + '</span></td>' +
                        '<td style="text-align:center"><a class="btn-view" href="../Admission/ViewAdmission?id=' + esc(element.id) + '" title="View Details"><i class="fas fa-eye"></i></a></td>' +
                        '<td style="text-align:center"><label class="custom-check"><input id="' + esc(element.id) + '" name="chkStudent" type="checkbox" ' + isChecked + '><span class="checkmark"></span></label></td>' +
                        '</tr>';

                    $("#tblStudentList tbody").append(row);
                });
            }

            var showStart = totalRecords === 0 ? 0 : startIndex + 1;
            var showEnd = endIndex;
            $('#pageInfo').html(
                'Showing <strong>' + showStart + '</strong> to <strong>' + showEnd +
                '</strong> of <strong>' + totalRecords + '</strong> records'
            );

            buildPaginationNav(totalPages);
            updateSelectionBar();
        }

        function buildPaginationNav(totalPages) {
            var nav = $('#paginationNav');
            nav.empty();

            nav.append('<button class="pg-btn pg-nav" ' + (currentPage === 1 ? 'disabled' : '') +
                ' onclick="goToPage(1)" title="First"><i class="fas fa-angles-left"></i></button>');
            nav.append('<button class="pg-btn pg-nav" ' + (currentPage === 1 ? 'disabled' : '') +
                ' onclick="goToPage(' + (currentPage - 1) + ')" title="Previous"><i class="fas fa-angle-left"></i></button>');

            var pages = generatePageNumbers(currentPage, totalPages);
            $.each(pages, function (i, p) {
                if (p === '...') {
                    nav.append('<span class="pg-ellipsis">...</span>');
                } else {
                    nav.append('<button class="pg-btn ' + (p === currentPage ? 'active' : '') +
                        '" onclick="goToPage(' + p + ')">' + p + '</button>');
                }
            });

            nav.append('<button class="pg-btn pg-nav" ' + (currentPage === totalPages ? 'disabled' : '') +
                ' onclick="goToPage(' + (currentPage + 1) + ')" title="Next"><i class="fas fa-angle-right"></i></button>');
            nav.append('<button class="pg-btn pg-nav" ' + (currentPage === totalPages ? 'disabled' : '') +
                ' onclick="goToPage(' + totalPages + ')" title="Last"><i class="fas fa-angles-right"></i></button>');
        }

        function generatePageNumbers(current, total) {
            var pages = [];
            if (total <= 7) {
                for (var i = 1; i <= total; i++) pages.push(i);
                return pages;
            }
            pages.push(1);
            if (current > 4) pages.push('...');
            var rangeStart = Math.max(2, current - 1);
            var rangeEnd = Math.min(total - 1, current + 1);
            if (current <= 3) { rangeStart = 2; rangeEnd = Math.min(5, total - 1); }
            else if (current >= total - 2) { rangeStart = Math.max(2, total - 4); rangeEnd = total - 1; }
            for (var j = rangeStart; j <= rangeEnd; j++) pages.push(j);
            if (current < total - 3) pages.push('...');
            if (total > 1) pages.push(total);
            return pages;
        }

        function goToPage(page) {
            var totalPages = Math.ceil(allStudentData.length / pageSize) || 1;
            if (page < 1 || page > totalPages) return;
            currentPage = page;
            renderPage();
            $('.table-panel')[0].scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function updateSelectionBar() {
            var pageCheckedCount = $('input[name="chkStudent"]:checked').length;
            var bar = $('#selectAllBar');

            if (selectedIds.size > 0) {
                bar.addClass('visible');
                $('#saCount').text(selectedIds.size);
                $('#saTotalLabel').text(allStudentData.length);
                if (allPagesSelected) {
                    $('#saSelectAll').html('All <strong>' + allStudentData.length + '</strong> records selected');
                } else {
                    $('#saSelectAll').html('Select all <strong>' + allStudentData.length + '</strong> records');
                }
            } else {
                bar.removeClass('visible');
                allPagesSelected = false;
            }
            $('#statSelected').text(selectedIds.size);
        }

        function selectAllAcrossPages() {
            allPagesSelected = true;
            $.each(allStudentData, function (i, el) {
                selectedIds.add(String(el.id));
            });
            $('input[name="chkStudent"]').prop('checked', true);
            updateSelectionBar();
        }

        function clearAllSelections() {
            allPagesSelected = false;
            selectedIds.clear();
            $('input[name="chkStudent"]').prop('checked', false);
            updateSelectionBar();
        }

        function getStatusClass(status) {
            if (!status) return 'default';
            var s = status.toString().toLowerCase().trim();
            if (s === 'done') return 'done';
            if (s === 'inquiry') return 'inquiry';
            if (s === 'follow') return 'follow';
            return 'default';
        }

        function esc(str) {
            if (!str) return '';
            var div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        function Reset() {
            $("#txtSearch").val('');
            $('#ddlSession').val('');
            $('#ddlClass').val('');
            $('#ddlCourse').val('');
            $('#ddlYear').val('');
            selectedIds.clear();
            allPagesSelected = false;
            SearchStudent();
        }

        function AdmissionCompleted() {
            var idsArray = Array.from(selectedIds);
            if (idsArray.length > 0) {
                $('#hdnSelected').val(idsArray.join(','));
                AdmissionDone();
            } else {
                Alert('warning', 'Please select at least one student.', '');
            }
        }

        function AdmissionDone() {
            $.post(BASE_URL + "/Admission/AdmissionDone", {
                studentList: $("#hdnSelected").val()
            }, function (res) {
                if (res.success) {
                    Alert('success', 'Admission marked as Done!', '');
                    SearchStudent();
                } else {
                    Alert('error', 'Some error occurred. Try Again.', '');
                }
            });
        }

        function DownloadExcel() {
            $("#hdnExcelName").val($("#txtSearch").val());
            $("#hdnExcelClass").val($('#ddlClass option:selected').text());
            $("#hdnExcelYear").val($('#ddlYear option:selected').text());
            $("#hdnExcelCourse").val($('#ddlCourse option:selected').text());
            $("#hdnExcelSession").val($('#ddlSession option:selected').text());
            $('#frmDownloadExcel').submit();
        }

        function ChangStatus() {
            $("#modal-default").modal('show');
        }

        /* ========================================================
           PRINT FUNCTIONALITY
           ======================================================== */

        /* Toggle the print dropdown menu */
        function togglePrintDropdown(e) {
            e.stopPropagation();
            $('#printDropdownMenu').toggleClass('show');
        }

        /* Open the print preview overlay */
        function openPrintPreview(mode) {
            currentPrintMode = mode;
            $('#printDropdownMenu').removeClass('show');

            /* Determine which data to print */
            var printData = [];

            if (mode === 'all') {
                printData = allStudentData;
                $('#pptSubtitle').text('All Records (' + printData.length + ')');
            } else if (mode === 'page') {
                var startIndex = (currentPage - 1) * pageSize;
                var endIndex = Math.min(startIndex + pageSize, allStudentData.length);
                printData = allStudentData.slice(startIndex, endIndex);
                $('#pptSubtitle').text('Current Page (' + printData.length + ')');
            } else if (mode === 'selected') {
                if (selectedIds.size === 0) {
                    Alert('warning', 'No students selected. Please select at least one.', '');
                    return;
                }
                printData = allStudentData.filter(function (el) {
                    return selectedIds.has(String(el.id));
                });
                $('#pptSubtitle').text('Selected (' + printData.length + ')');
            }

            if (printData.length === 0) {
                Alert('warning', 'No data available to print.', '');
                return;
            }

            /* Build the print document HTML */
            var html = buildPrintDocument(printData);
            $('#printPreviewBody').html(html);
            $('#printPreviewOverlay').addClass('active');
            document.body.style.overflow = 'hidden';
        }

        /* Build the printable HTML document */
        function buildPrintDocument(data) {
            var now = new Date();
            var dateStr = now.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
            var timeStr = now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });

            /* Active filter labels */
            var filterParts = [];
            var sessionVal = $('#ddlSession option:selected').text();
            var yearVal = $('#ddlYear option:selected').text();
            var classVal = $('#ddlClass option:selected').text();
            var courseVal = $('#ddlCourse option:selected').text();
            var nameVal = $('#txtSearch').val();

            if (sessionVal && sessionVal !== 'Select') filterParts.push({ label: 'Session', value: sessionVal });
            if (yearVal && yearVal !== 'Select') filterParts.push({ label: 'Year', value: yearVal });
            if (classVal && classVal !== 'Select') filterParts.push({ label: 'Class', value: classVal });
            if (courseVal && courseVal !== 'Select') filterParts.push({ label: 'Course', value: courseVal });
            if (nameVal) filterParts.push({ label: 'Name', value: nameVal });

            var filterHtml = '';
            if (filterParts.length > 0) {
                filterHtml += '<div class="print-doc-filters">';
                filterHtml += '<span style="font-weight:700;color:#6366f1;font-size:.82rem;margin-right:8px"><i class="fas fa-filter" style="margin-right:4px"></i>Filters:</span>';
                $.each(filterParts, function (i, f) {
                    filterHtml += '<div><span class="pdf-label">' + f.label + ':</span> <span class="pdf-value">' + esc(f.value) + '</span></div>';
                });
                filterHtml += '</div>';
            }

            /* Table rows */
            var rowsHtml = '';
            $.each(data, function (index, el) {
                var statusClass = getStatusClass(el.status);
                var statusText = el.status || 'N/A';
                rowsHtml += '<tr>' +
                    '<td class="pd-num">' + (index + 1) + '</td>' +
                    '<td class="pd-reg">' + esc(el.regNo) + '</td>' +
                    '<td>' + esc(el.session) + '</td>' +
                    '<td class="pd-name">' + esc(el.name) + '</td>' +
                    '<td>' + esc(el.fatherName) + '</td>' +
                    '<td>' + esc(el.mobileNo) + '</td>' +
                    '<td>' + esc(el.year) + '</td>' +
                    '<td>' + esc(el.subject) + '</td>' +
                    '<td>' + esc(el.course) + '</td>' +
                    '<td><span class="pd-status ' + statusClass + '">' + esc(statusText) + '</span></td>' +
                    '</tr>';
            });

            var html =
                '<div class="print-doc-header">' +
                    '<div class="pdh-logo"><i class="fas fa-graduation-cap"></i></div>' +
                    '<h2 class="pdh-title">Student Admission List</h2>' +
                    '<p class="pdh-subtitle">Generated on ' + dateStr + ' at ' + timeStr + '</p>' +
                '</div>' +
                filterHtml +
                '<table class="print-doc-table">' +
                    '<thead>' +
                        '<tr>' +
                            '<th>#</th>' +
                            '<th>Reg No</th>' +
                            '<th>Session</th>' +
                            '<th>Student Name</th>' +
                            '<th>Father Name</th>' +
                            '<th>Mobile</th>' +
                            '<th>Year</th>' +
                            '<th>Subject</th>' +
                            '<th>Course</th>' +
                            '<th>Status</th>' +
                        '</tr>' +
                    '</thead>' +
                    '<tbody>' + rowsHtml + '</tbody>' +
                '</table>' +
                '<div class="print-doc-footer">' +
                    '<div class="pdf-total">Total: ' + data.length + ' student' + (data.length !== 1 ? 's' : '') + '</div>' +
                    '<div>Page 1 of 1 &bull; Printed from CRM System</div>' +
                '</div>';

            return html;
        }

        /* Close the print preview overlay */
        function closePrintPreview() {
            $('#printPreviewOverlay').removeClass('active');
            document.body.style.overflow = '';
        }

        /* Execute the actual browser print */
        function executePrint() {
            var printContent = document.getElementById('printPreviewBody').innerHTML;

            var printWindow = window.open('', '_blank', 'width=1000,height=700');

            printWindow.document.write('<!DOCTYPE html><html><head><title>Print - Student List</title>');
            printWindow.document.write('<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">');
            printWindow.document.write('<style>');
            printWindow.document.write(getPrintCSS());
            printWindow.document.write('</style>');
            printWindow.document.write('</head><body>');
            printWindow.document.write(printContent);
            printWindow.document.write('</body></html>');
            printWindow.document.close();

            /* Wait for fonts/styles then print */
            printWindow.onload = function () {
                setTimeout(function () {
                    printWindow.focus();
                    printWindow.print();
                    /* Don't auto-close so user can re-print if needed */
                }, 400);
            };
        }

        /* Return the CSS string used for the actual print window */
        function getPrintCSS() {
            return `
                @@page {
                    size: A4 landscape;
                    margin: 12mm 10mm;
                }

                * {
                    margin: 0;
                    padding: 0;
                    box-sizing: border-box;
                }

                body {
                    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                    color: #1e293b;
                    font-size: 11px;
                    line-height: 1.4;
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }

                .print-doc-header {
                    text-align: center;
                    margin-bottom: 16px;
                    padding-bottom: 12px;
                    border-bottom: 3px double #e2e8f0;
                }

                .pdh-logo {
                    font-size: 1.6rem;
                    color: #6366f1;
                    margin-bottom: 4px;
                }

                .pdh-title {
                    font-size: 16px;
                    font-weight: 800;
                    color: #1e293b;
                    margin: 0 0 2px;
                }

                .pdh-subtitle {
                    font-size: 10px;
                    color: #64748b;
                }

                .print-doc-filters {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 6px 16px;
                    margin-bottom: 12px;
                    padding: 8px 12px;
                    background: #f8fafc;
                    border-radius: 6px;
                    border: 1px solid #e2e8f0;
                    font-size: 10px;
                    align-items: center;
                }

                .pdf-label {
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: .03em;
                    color: #94a3b8;
                    font-size: 8px;
                }

                .pdf-value {
                    font-weight: 600;
                    color: #1e293b;
                    font-size: 10px;
                }

                .print-doc-table {
                    width: 100%;
                    border-collapse: collapse;
                    font-size: 10px;
                }

                .print-doc-table thead th {
                    background: #6366f1 !important;
                    color: #fff !important;
                    font-size: 8.5px;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: .04em;
                    padding: 7px 6px;
                    border: 1px solid #4f46e5;
                    white-space: nowrap;
                }

                .print-doc-table tbody td {
                    padding: 5px 6px;
                    border: 1px solid #e2e8f0;
                    color: #1e293b;
                    vertical-align: middle;
                }

                .print-doc-table tbody tr:nth-child(even) {
                    background: #f8fafc;
                }

                .print-doc-table tbody tr:nth-child(odd) {
                    background: #fff;
                }

                .pd-num {
                    text-align: center;
                    font-weight: 700;
                    color: #64748b;
                }

                .pd-reg {
                    font-weight: 700;
                    color: #6366f1;
                }

                .pd-name {
                    font-weight: 700;
                }

                .pd-status {
                    display: inline-block;
                    padding: 1px 6px;
                    border-radius: 3px;
                    font-size: 8px;
                    font-weight: 700;
                    text-transform: uppercase;
                }

                .pd-status.done { background: #dcfce7; color: #166534; }
                .pd-status.inquiry { background: #fef3c7; color: #92400e; }
                .pd-status.follow { background: #dbeafe; color: #1e40af; }
                .pd-status.default { background: #f1f5f9; color: #64748b; }

                .print-doc-footer {
                    margin-top: 14px;
                    padding-top: 10px;
                    border-top: 1px solid #e2e8f0;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    font-size: 9px;
                    color: #94a3b8;
                }

                .pdf-total {
                    font-weight: 700;
                    color: #6366f1;
                    font-size: 11px;
                }
            `;
        }
    </script>
}