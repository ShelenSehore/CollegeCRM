@model CRM.ModelsForView.StudentListView
@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    ViewData["Title"] = "Student List";
    var baseUrl = ViewBag.BaseUrl;
}

<style>
    :root {
        --clr-primary: #6366f1;
        --clr-primary-light: #818cf8;
        --clr-accent-teal: #14b8a6;
        --clr-accent-orange: #f97316;
        --clr-accent-pink: #ec4899;
        --clr-accent-sky: #0ea5e9;
        --clr-accent-lime: #84cc16;
        --clr-accent-red: #ef4444;
        --clr-bg-start: #f0f4ff;
        --clr-bg-end: #fdf2f8;
        --clr-card: #ffffff;
        --clr-text: #1e293b;
        --clr-text-muted: #64748b;
        --clr-border: #e2e8f0;
        --clr-input-bg: #f8fafc;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.06);
        --shadow-md: 0 4px 14px rgba(0,0,0,.07);
        --shadow-lg: 0 10px 30px rgba(0,0,0,.1);
        --radius: 14px;
        --radius-sm: 10px;
        --transition: .25s cubic-bezier(.4,0,.2,1);
    }

    .content-wrapper {
        background: linear-gradient(160deg, var(--clr-bg-start) 0%, #ede9fe 25%, #fce7f3 55%, var(--clr-bg-end) 100%);
        min-height: 100vh;
        padding-bottom: 60px;
    }

    .breadcrumb {
        background: none !important;
        padding: 0 !important;
        margin: 0 !important;
        font-size: .85rem;
    }

    .breadcrumb-item a {
        color: var(--clr-primary);
        text-decoration: none;
        font-weight: 600;
        transition: var(--transition);
    }

        .breadcrumb-item a:hover {
            color: var(--clr-accent-pink);
        }

    .breadcrumb-item.active {
        color: var(--clr-text-muted);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        color: #cbd5e1;
        content: "›";
    }

    .page-banner {
        background: linear-gradient(135deg, var(--clr-primary) 0%, #8b5cf6 50%, var(--clr-accent-pink) 100%);
        border-radius: var(--radius);
        padding: 26px 32px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(99,102,241,.28);
    }

        .page-banner::before {
            content: '';
            position: absolute;
            top: -40%;
            right: -6%;
            width: 240px;
            height: 240px;
            background: rgba(255,255,255,.1);
            border-radius: 50%;
        }

        .page-banner::after {
            content: '';
            position: absolute;
            bottom: -50%;
            left: 12%;
            width: 160px;
            height: 160px;
            background: rgba(255,255,255,.07);
            border-radius: 50%;
        }

        .page-banner h1 {
            color: #fff;
            font-size: 1.5rem;
            font-weight: 800;
            margin: 0;
            position: relative;
            z-index: 1;
            letter-spacing: -.02em;
        }

        .page-banner p {
            color: rgba(255,255,255,.75);
            margin: 5px 0 0;
            font-size: .88rem;
            position: relative;
            z-index: 1;
        }

        .page-banner .banner-icon {
            position: absolute;
            right: 28px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 3rem;
            color: rgba(255,255,255,.18);
            z-index: 1;
        }

    .stat-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 24px;
    }

    @@media (max-width: 992px) {
        .stat-row {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 576px) {
        .stat-row {
            grid-template-columns: 1fr;
        }
    }

    .stat-card {
        background: var(--clr-card);
        border-radius: var(--radius);
        padding: 20px 22px;
        box-shadow: var(--shadow-md);
        border: 1px solid var(--clr-border);
        display: flex;
        align-items: center;
        gap: 16px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            width: 4px;
            border-radius: var(--radius) 0 0 var(--radius);
        }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
        }

        .stat-card.total::before {
            background: linear-gradient(180deg, var(--clr-primary), var(--clr-accent-sky));
        }

        .stat-card.total .stat-icon {
            background: linear-gradient(135deg, #eef2ff, #e0e7ff);
            color: var(--clr-primary);
        }

        .stat-card.session::before {
            background: linear-gradient(180deg, var(--clr-accent-teal), var(--clr-accent-lime));
        }

        .stat-card.session .stat-icon {
            background: linear-gradient(135deg, #f0fdfa, #ccfbf1);
            color: var(--clr-accent-teal);
        }

        .stat-card.course::before {
            background: linear-gradient(180deg, var(--clr-accent-orange), #fbbf24);
        }

        .stat-card.course .stat-icon {
            background: linear-gradient(135deg, #fff7ed, #ffedd5);
            color: var(--clr-accent-orange);
        }

        .stat-card.selected::before {
            background: linear-gradient(180deg, var(--clr-accent-pink), #f472b6);
        }

        .stat-card.selected .stat-icon {
            background: linear-gradient(135deg, #fdf2f8, #fce7f3);
            color: var(--clr-accent-pink);
        }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .stat-info {
        flex: 1;
    }

    .stat-label {
        font-size: .75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--clr-text-muted);
        margin-bottom: 2px;
    }

    .stat-value {
        font-size: 1.65rem;
        font-weight: 800;
        color: var(--clr-text);
        line-height: 1.1;
    }

    .stat-card.total .stat-value {
        color: var(--clr-primary);
    }

    .stat-card.session .stat-value {
        color: #0d9488;
    }

    .stat-card.course .stat-value {
        color: #c2410c;
    }

    .stat-card.selected .stat-value {
        color: #be185d;
    }

    .filter-panel {
        background: var(--clr-card);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        border: 1px solid var(--clr-border);
        margin-bottom: 24px;
        overflow: hidden;
        transition: var(--transition);
    }

        .filter-panel:hover {
            box-shadow: var(--shadow-lg);
        }

    .filter-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 22px;
        background: linear-gradient(90deg, #f8fafc, #f1f5f9);
        border-bottom: 1px solid var(--clr-border);
    }

        .filter-header .fh-icon {
            color: var(--clr-accent-sky);
            font-size: .95rem;
        }

        .filter-header .fh-title {
            font-size: .9rem;
            font-weight: 700;
            color: var(--clr-text);
            margin: 0;
        }

        .filter-header .fh-badge {
            font-size: .68rem;
            font-weight: 700;
            padding: 2px 10px;
            background: #ede9fe;
            color: #7c3aed;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

    .filter-body {
        padding: 20px 22px 14px;
    }

        .filter-body label {
            font-size: .73rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: var(--clr-text-muted);
            margin-bottom: 5px;
            display: block;
        }

        .filter-body .form-control,
        .filter-body select.form-control {
            border: 2px solid var(--clr-border);
            border-radius: var(--radius-sm);
            padding: 9px 12px;
            font-size: .88rem;
            color: var(--clr-text);
            background: var(--clr-input-bg);
            transition: var(--transition);
            height: auto;
            box-shadow: none !important;
        }

            .filter-body .form-control:focus,
            .filter-body select.form-control:focus {
                border-color: var(--clr-primary);
                background: #fff;
                box-shadow: 0 0 0 4px rgba(99,102,241,.1) !important;
                outline: none;
            }

    .filter-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 22px 18px;
        flex-wrap: wrap;
    }

    .btn-search {
        background: linear-gradient(135deg, var(--clr-primary) 0%, #8b5cf6 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 9px 22px;
        font-size: .85rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 12px rgba(99,102,241,.3);
        transition: var(--transition);
    }

        .btn-search:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(99,102,241,.4);
        }

    .btn-reset {
        background: #f1f5f9;
        color: var(--clr-text-muted);
        border: 2px solid var(--clr-border);
        border-radius: var(--radius-sm);
        padding: 9px 18px;
        font-size: .85rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition);
    }

        .btn-reset:hover {
            background: #fee2e2;
            color: var(--clr-accent-red);
            border-color: #fca5a5;
        }

    .btn-action-group {
        display: inline-flex;
        align-items: center;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 2px solid var(--clr-accent-teal);
    }

    .btn-action-main {
        background: var(--clr-accent-teal);
        color: #fff;
        border: none;
        padding: 9px 16px;
        font-size: .85rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition);
    }

        .btn-action-main:hover {
            background: #0d9488;
        }

    .btn-action-toggle {
        background: var(--clr-accent-teal);
        color: #fff;
        border: none;
        border-left: 1px solid rgba(255,255,255,.3);
        padding: 9px 12px;
        font-size: .85rem;
        cursor: pointer;
        transition: var(--transition);
    }

        .btn-action-toggle:hover {
            background: #0d9488;
        }

    .btn-excel {
        background: linear-gradient(135deg, var(--clr-accent-lime) 0%, #65a30d 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 9px 16px;
        font-size: .85rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 12px rgba(132,204,22,.3);
        transition: var(--transition);
    }

        .btn-excel:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(132,204,22,.4);
        }

    /* ===== PRINT BUTTON ===== */
    .btn-print {
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 9px 16px;
        font-size: .85rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 12px rgba(99,102,241,.3);
        transition: var(--transition);
    }

        .btn-print:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(99,102,241,.4);
        }

        .btn-print i {
            font-size: .9rem;
        }

    /* ===== PRINT DROPDOWN ===== */
    .print-dropdown-wrapper {
        position: relative;
        display: inline-block;
    }

    .print-dropdown-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        background: #fff;
        border: 1px solid var(--clr-border);
        border-radius: var(--radius-sm);
        box-shadow: var(--shadow-lg);
        padding: 6px;
        z-index: 1050;
        min-width: 200px;
        display: none;
        animation: printDropIn .2s ease;
    }

        .print-dropdown-menu.show {
            display: block;
        }

    @@keyframes printDropIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .print-option {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: .85rem;
        font-weight: 600;
        color: var(--clr-text);
        background: none;
        border: none;
        cursor: pointer;
        transition: var(--transition);
        text-align: left;
    }

        .print-option:hover {
            background: #eef2ff;
            color: var(--clr-primary);
        }

        .print-option i {
            color: var(--clr-primary);
            font-size: .9rem;
            width: 18px;
            text-align: center;
        }

        .print-option .po-desc {
            font-size: .72rem;
            color: var(--clr-text-muted);
            font-weight: 500;
        }

    /* ===== PRINT PREVIEW MODAL ===== */
    .print-preview-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.55);
        backdrop-filter: blur(4px);
        z-index: 9999;
        justify-content: center;
        align-items: flex-start;
        padding: 30px 20px;
        overflow-y: auto;
    }

        .print-preview-overlay.active {
            display: flex;
        }

    .print-preview-container {
        background: #fff;
        width: 100%;
        max-width: 900px;
        border-radius: var(--radius);
        box-shadow: 0 25px 60px rgba(0,0,0,.25);
        overflow: hidden;
        animation: slideUp .3s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .print-preview-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 24px;
        background: linear-gradient(135deg, var(--clr-primary), #8b5cf6);
        color: #fff;
    }

        .print-preview-toolbar .ppt-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .print-preview-toolbar .ppt-icon {
            font-size: 1.1rem;
        }

        .print-preview-toolbar .ppt-title {
            font-size: .95rem;
            font-weight: 700;
        }

        .print-preview-toolbar .ppt-subtitle {
            font-size: .75rem;
            opacity: .75;
        }

        .print-preview-toolbar .ppt-actions {
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .ppt-btn {
        border: none;
        border-radius: 8px;
        padding: 8px 18px;
        font-size: .82rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition);
    }

    .ppt-btn-print {
        background: #fff;
        color: var(--clr-primary);
    }

        .ppt-btn-print:hover {
            background: #eef2ff;
            transform: translateY(-1px);
        }

    .ppt-btn-close {
        background: rgba(255,255,255,.15);
        color: #fff;
    }

        .ppt-btn-close:hover {
            background: rgba(255,255,255,.25);
        }

    .print-preview-body {
        padding: 30px 40px;
        max-height: 70vh;
        overflow-y: auto;
    }

    /* ===== PRINT DOCUMENT STYLES (inside preview & actual print) ===== */
    .print-doc-header {
        text-align: center;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 3px double #e2e8f0;
    }

        .print-doc-header .pdh-title {
            font-size: 1.35rem;
            font-weight: 800;
            color: #1e293b;
            margin: 0 0 4px;
            letter-spacing: -.01em;
        }

        .print-doc-header .pdh-subtitle {
            font-size: .85rem;
            color: #64748b;
            font-weight: 500;
        }

        .print-doc-header .pdh-logo {
            font-size: 2rem;
            color: var(--clr-primary);
            margin-bottom: 6px;
        }

    .print-doc-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 18px;
        margin-bottom: 18px;
        padding: 10px 16px;
        background: #f8fafc;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
    }

        .print-doc-filters .pdf-label {
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #94a3b8;
        }

        .print-doc-filters .pdf-value {
            font-size: .82rem;
            font-weight: 600;
            color: #1e293b;
        }

    .print-doc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

        .print-doc-table thead th {
            background: #6366f1;
            color: #fff;
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            padding: 10px 10px;
            border: 1px solid #4f46e5;
            white-space: nowrap;
        }

        .print-doc-table tbody td {
            padding: 8px 10px;
            border: 1px solid #e2e8f0;
            color: #1e293b;
            vertical-align: middle;
        }

        .print-doc-table tbody tr:nth-child(even) {
            background: #f8fafc;
        }

        .print-doc-table tbody tr:nth-child(odd) {
            background: #fff;
        }

        .print-doc-table .pd-num {
            text-align: center;
            font-weight: 700;
            color: #64748b;
        }

        .print-doc-table .pd-reg {
            font-weight: 700;
            color: #6366f1;
        }

        .print-doc-table .pd-name {
            font-weight: 700;
        }

        .print-doc-table .pd-status {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: .72rem;
            font-weight: 700;
            text-transform: uppercase;
        }

            .print-doc-table .pd-status.done {
                background: #dcfce7;
                color: #166534;
            }

            .print-doc-table .pd-status.inquiry {
                background: #fef3c7;
                color: #92400e;
            }

            .print-doc-table .pd-status.follow {
                background: #dbeafe;
                color: #1e40af;
            }

            .print-doc-table .pd-status.default {
                background: #f1f5f9;
                color: #64748b;
            }

    .print-doc-footer {
        margin-top: 20px;
        padding-top: 14px;
        border-top: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: .75rem;
        color: #94a3b8;
    }

        .print-doc-footer .pdf-total {
            font-weight: 700;
            color: #6366f1;
            font-size: .85rem;
        }

    /* ===== PRINT OPTION CARDS (inside modal) ===== */
    .print-opt-card {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 18px;
        border: 2px solid var(--clr-border);
        border-radius: var(--radius-sm);
        margin-bottom: 10px;
        cursor: pointer;
        transition: var(--transition);
    }

        .print-opt-card:hover {
            border-color: var(--clr-primary-light);
            background: #f5f3ff;
        }

        .print-opt-card.selected {
            border-color: var(--clr-primary);
            background: #eef2ff;
            box-shadow: 0 0 0 3px rgba(99,102,241,.12);
        }

        .print-opt-card .poc-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

            .print-opt-card .poc-icon.all {
                background: linear-gradient(135deg, #eef2ff, #e0e7ff);
                color: var(--clr-primary);
            }

            .print-opt-card .poc-icon.page {
                background: linear-gradient(135deg, #f0fdfa, #ccfbf1);
                color: var(--clr-accent-teal);
            }

            .print-opt-card .poc-icon.selected {
                background: linear-gradient(135deg, #fdf2f8, #fce7f3);
                color: var(--clr-accent-pink);
            }

        .print-opt-card .poc-text .poc-title {
            font-size: .88rem;
            font-weight: 700;
            color: var(--clr-text);
            margin-bottom: 2px;
        }

        .print-opt-card .poc-text .poc-desc {
            font-size: .75rem;
            color: var(--clr-text-muted);
        }

        .print-opt-card .poc-radio {
            margin-left: auto;
        }

            .print-opt-card .poc-radio input[type="radio"] {
                width: 18px;
                height: 18px;
                accent-color: var(--clr-primary);
                cursor: pointer;
            }

    .print-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding-top: 18px;
        border-top: 1px solid var(--clr-border);
        margin-top: 18px;
    }

    .action-separator {
        width: 1px;
        height: 28px;
        background: var(--clr-border);
        margin: 0 4px;
    }

    .dropdown-menu {
        border-radius: var(--radius-sm) !important;
        box-shadow: var(--shadow-lg) !important;
        border: 1px solid var(--clr-border) !important;
        padding: 6px !important;
    }

        .dropdown-menu .btn-default {
            display: flex;
            align-items: center;
            gap: 8px;
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: .85rem;
            font-weight: 600;
            color: var(--clr-text);
