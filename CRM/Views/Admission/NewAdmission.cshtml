@model CRM.ModelsForView.StudentRegistrationForView

@{
    Layout = "~/Views/Shared/_MasterLayout.cshtml";
    ViewData["Title"] = "New Admission";
    var baseUrl = ViewBag.BaseUrl;
}

<style>
    /* ========== ROOT VARIABLES ========== */
    :root {
        --clr-primary: #6366f1;
        --clr-primary-dark: #4f46e5;
        --clr-accent-teal: #14b8a6;
        --clr-accent-orange: #f97316;
        --clr-accent-pink: #ec4899;
        --clr-accent-sky: #0ea5e9;
        --clr-accent-lime: #84cc16;
        --clr-bg-start: #f0f4ff;
        --clr-bg-end: #fdf2f8;
        --clr-card: #ffffff;
        --clr-text: #1e293b;
        --clr-text-muted: #64748b;
        --clr-border: #e2e8f0;
        --clr-input-bg: #f8fafc;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
        --shadow-md: 0 4px 14px rgba(0,0,0,.08);
        --shadow-lg: 0 10px 30px rgba(0,0,0,.1);
        --radius: 14px;
        --radius-sm: 10px;
        --transition: .25s cubic-bezier(.4,0,.2,1);
    }

    /* ========== PAGE BACKGROUND ========== */
    .content-wrapper {
        background: linear-gradient(135deg, var(--clr-bg-start) 0%, #ede9fe 30%, #fce7f3 60%, var(--clr-bg-end) 100%);
        min-height: 100vh;
        padding-bottom: 60px;
    }

    /* ========== BREADCRUMB ========== */
    .breadcrumb {
        background: none !important;
        padding: 0 !important;
        margin: 0 !important;
        font-size: .85rem;
    }
    .breadcrumb-item a {
        color: var(--clr-primary);
        text-decoration: none;
        font-weight: 600;
        transition: var(--transition);
    }
    .breadcrumb-item a:hover { color: var(--clr-accent-pink); }
    .breadcrumb-item.active {
        color: var(--clr-text-muted);
        font-weight: 500;
    }
    .breadcrumb-item + .breadcrumb-item::before {
        color: #cbd5e1;
        content: "›";
    }

    /* ========== PAGE TITLE BANNER ========== */
    .page-banner {
        background: linear-gradient(135deg, var(--clr-primary) 0%, #8b5cf6 50%, var(--clr-accent-pink) 100%);
        border-radius: var(--radius);
        padding: 28px 32px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(99,102,241,.3);
    }
    .page-banner::before {
        content: '';
        position: absolute;
        top: -40%;
        right: -8%;
        width: 260px;
        height: 260px;
        background: rgba(255,255,255,.1);
        border-radius: 50%;
    }
    .page-banner::after {
        content: '';
        position: absolute;
        bottom: -50%;
        left: 15%;
        width: 180px;
        height: 180px;
        background: rgba(255,255,255,.07);
        border-radius: 50%;
    }
    .page-banner h1 {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0;
        position: relative;
        z-index: 1;
        letter-spacing: -.02em;
    }
    .page-banner p {
        color: rgba(255,255,255,.8);
        margin: 6px 0 0;
        font-size: .9rem;
        position: relative;
        z-index: 1;
    }
    .page-banner .banner-icon {
        position: absolute;
        right: 28px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 3.2rem;
        color: rgba(255,255,255,.2);
        z-index: 1;
    }

    /* ========== SECTION CARDS ========== */
    .section-card {
        background: var(--clr-card);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        margin-bottom: 24px;
        border: 1px solid var(--clr-border);
        overflow: hidden;
        transition: var(--transition);
    }
    .section-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-2px);
    }

    /* Section Header — colored stripe */
    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 18px 24px;
        position: relative;
        overflow: hidden;
    }
    .section-header::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 5px;
    }

    /* Color variants */
    .section-header.college::before { background: linear-gradient(180deg, var(--clr-primary), var(--clr-accent-sky)); }
    .section-header.college { background: linear-gradient(90deg, #eef2ff 0%, #f8fafc 100%); }
    .section-header.college .section-icon { color: var(--clr-primary); }

    .section-header.fee::before { background: linear-gradient(180deg, var(--clr-accent-teal), var(--clr-accent-lime)); }
    .section-header.fee { background: linear-gradient(90deg, #f0fdfa 0%, #f8fafc 100%); }
    .section-header.fee .section-icon { color: var(--clr-accent-teal); }

    .section-header.personal::before { background: linear-gradient(180deg, var(--clr-accent-orange), var(--clr-accent-pink)); }
    .section-header.personal { background: linear-gradient(90deg, #fff7ed 0%, #fdf2f8 40%, #f8fafc 100%); }
    .section-header.personal .section-icon { color: var(--clr-accent-orange); }

    .section-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }
    .section-header.college .section-icon { background: #eef2ff; }
    .section-header.fee .section-icon { background: #f0fdfa; }
    .section-header.personal .section-icon { background: #fff7ed; }

    .section-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--clr-text);
        margin: 0;
    }
    .section-subtitle {
        font-size: .78rem;
        color: var(--clr-text-muted);
        margin: 2px 0 0;
    }

    .section-body {
        padding: 24px;
    }

    /* ========== FORM CONTROLS ========== */
    .form-group label {
        font-size: .78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: var(--clr-text-muted);
        margin-bottom: 6px;
        display: block;
    }

    .form-control,
    select.form-control {
        border: 2px solid var(--clr-border);
        border-radius: var(--radius-sm);
        padding: 10px 14px;
        font-size: .9rem;
        color: var(--clr-text);
        background: var(--clr-input-bg);
        transition: var(--transition);
        height: auto;
        box-shadow: none !important;
    }
    .form-control:focus,
    select.form-control:focus {
        border-color: var(--clr-primary);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(99,102,241,.12) !important;
        outline: none;
    }
    .form-control[readonly] {
        background: linear-gradient(90deg, #f1f5f9, #e2e8f0);
        color: var(--clr-text);
        font-weight: 600;
        border-color: #cbd5e1;
        cursor: default;
    }

    /* Fee readonly — teal tint */
    .fee-readonly.form-control[readonly] {
        background: linear-gradient(90deg, #f0fdfa, #ccfbf1);
        border-color: #99f6e4;
        color: #0f766e;
        font-weight: 700;
        font-size: .95rem;
    }

    /* ========== FIELD BADGES (inline tags) ========== */
    .field-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 6px;
        font-size: .68rem;
        font-weight: 700;
        margin-left: 6px;
        vertical-align: middle;
        text-transform: uppercase;
        letter-spacing: .03em;
    }
    .badge-auto { background: #ede9fe; color: #7c3aed; }
    .badge-req  { background: #fee2e2; color: #dc2626; }
    .badge-calc { background: #ccfbf1; color: #0d9488; }

    /* ========== VALIDATION ========== */
    .text-danger {
        font-size: .78rem;
        font-weight: 600;
        margin-top: 4px;
    }
    .field-validation-error {
        animation: shake .35s ease;
    }
    @@keyframes shake {
        0%,100% { transform: translateX(0); }
        25% { transform: translateX(-4px); }
        75% { transform: translateX(4px); }
    }
    input.input-validation-error,
    select.input-validation-error {
        border-color: #f87171 !important;
        background: #fef2f2 !important;
        box-shadow: 0 0 0 4px rgba(248,113,113,.12) !important;
    }

    /* ========== BUTTON BAR ========== */
    .btn-bar {
        display: flex;
        justify-content: center;
        gap: 16px;
        padding: 10px 0 20px;
        flex-wrap: wrap;
    }

    .btn-save {
        background: linear-gradient(135deg, var(--clr-primary) 0%, #8b5cf6 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 13px 40px;
        font-size: .95rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 16px rgba(99,102,241,.35);
        transition: var(--transition);
        letter-spacing: .01em;
    }
    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(99,102,241,.45);
    }
    .btn-save:active { transform: translateY(0); }

    .btn-exit {
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        color: var(--clr-text-muted);
        border: 2px solid var(--clr-border);
        border-radius: var(--radius-sm);
        padding: 13px 40px;
        font-size: .95rem;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: var(--transition);
    }
    .btn-exit:hover {
        background: #fee2e2;
        color: #dc2626;
        border-color: #fca5a5;
        transform: translateY(-2px);
    }

    /* ========== ANIMATED TOP STRIP ========== */
    .top-strip {
        height: 4px;
        background: linear-gradient(90deg,
            var(--clr-primary),
            var(--clr-accent-sky),
            var(--clr-accent-teal),
            var(--clr-accent-lime),
            var(--clr-accent-orange),
            var(--clr-accent-pink),
            var(--clr-primary));
        background-size: 300% 100%;
        animation: stripMove 6s linear infinite;
        border-radius: var(--radius) var(--radius) 0 0;
    }
    @@keyframes stripMove {
        0% { background-position: 0% 0%; }
        100% { background-position: 300% 0%; }
    }

    /* ========== FEE HIGHLIGHT BOX ========== */
    .fee-total-box {
        background: linear-gradient(135deg, #f0fdfa 0%, #ecfdf5 50%, #d1fae5 100%);
        border: 2px solid #6ee7b7;
        border-radius: var(--radius-sm);
        padding: 14px 18px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }
    .fee-total-box::before {
        content: '';
        position: absolute;
        top: -30%;
        right: -20%;
        width: 100px;
        height: 100px;
        background: rgba(16,185,129,.08);
        border-radius: 50%;
    }
    .fee-total-box .fee-total-label {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #047857;
        margin-bottom: 4px;
    }
    .fee-total-box .fee-total-value {
        font-size: 1.5rem;
        font-weight: 800;
        color: #065f46;
        line-height: 1.1;
    }
    .fee-total-box.after-discount {
        background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 50%, #fed7aa 100%);
        border-color: #fdba74;
    }
    .fee-total-box.after-discount .fee-total-label { color: #c2410c; }
    .fee-total-box.after-discount .fee-total-value { color: #9a3412; }
    .fee-total-box.after-discount::before { background: rgba(249,115,22,.08); }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .page-banner { padding: 20px; }
        .page-banner h1 { font-size: 1.2rem; }
        .page-banner .banner-icon { display: none; }
        .section-body { padding: 16px; }
        .section-header { padding: 14px 16px; }
        .btn-save, .btn-exit { padding: 12px 28px; font-size: .88rem; }
    }

    /* ========== SWEETALERT TOAST OVERRIDE ========== */
    .swal2-popup.swal2-toast {
        border-radius: var(--radius-sm) !important;
        box-shadow: var(--shadow-lg) !important;
    }

    /* ========== CONTENT HEADER OVERRIDE ========== */
    .content-header { padding: 18px 0 0; }
</style>

<div class="content-wrapper">
    <!-- Content Header -->
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-left">
                        <li class="breadcrumb-item"><a href="#">Admission</a></li>
                        <li class="breadcrumb-item active">New Admission</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">

            <!-- ===== PAGE BANNER ===== -->
            <div class="page-banner">
                <h1>New Student Admission</h1>
                <p>Fill in the details below to register a new student</p>
                <i class="fas fa-graduation-cap banner-icon"></i>
            </div>

            <form asp-action="NewAdmissionPost" method="post" novalidate>

                <!-- ===== COLLEGE DETAILS ===== -->
                <div class="section-card">
                    <div class="top-strip"></div>
                    <div class="section-header college">
                        <div class="section-icon">
                            <i class="fas fa-university"></i>
                        </div>
                        <div>
                            <h3 class="section-title">College Detail</h3>
                            <p class="section-subtitle">Academic registration information</p>
                        </div>
                    </div>
                    <div class="section-body">
                        <div class="row">
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Registration No
                                        <span class="field-badge badge-auto">Auto</span>
                                    </label>
                                    <input asp-for="@Model.RegNo" type="number" readonly="readonly" class="form-control" placeholder="Reg No">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Session
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <select id="ddlSession" asp-for="Session" asp-items="Model.SessionList" class="form-control">
                                        <option value="">Select</option>
                                    </select>
                                    <span asp-validation-for="Session" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Year
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <select id="ddlYear" asp-for="Year" asp-items="Model.YearList" class="form-control">
                                        <option value="">Select</option>
                                    </select>
                                    <span asp-validation-for="Year" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Class
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <select id="ddlClass" asp-for="Class" asp-items="Model.ClassList" class="form-control">
                                        <option value="">Select</option>
                                    </select>
                                    <span asp-validation-for="Class" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Course
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <select id="ddlSubject" asp-for="Course" asp-items="Model.SubjectList" class="form-control">
                                        <option value="">Select</option>
                                    </select>
                                    <span asp-validation-for="Course" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Form No</label>
                                    <input asp-for="FormNo" type="number" class="form-control" placeholder="Form No">
                                    <span asp-validation-for="FormNo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>Scholarship No</label>
                                    <input asp-for="SchoNo" type="number" value="0" class="form-control">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Reg / Pvt
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <select id="ddlRegPvt" asp-for="RegPvt" class="form-control">
                                        <option value="">Select</option>
                                        <option>REGULER</option>
                                        <option>PRIVATE</option>
                                    </select>
                                    <span asp-validation-for="RegPvt" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Status
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <select id="ddlStatus" asp-for="Status" class="form-control">
                                        <option value="">Select</option>
                                        <option>Inquiry</option>
                                        <option>Done</option>
                                        <option>Follow</option>
                                    </select>
                                    <span asp-validation-for="Status" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== FEE DETAILS ===== -->
                <div class="section-card">
                    <div class="top-strip"></div>
                    <div class="section-header fee">
                        <div class="section-icon">
                            <i class="fas fa-rupee-sign"></i>
                        </div>
                        <div>
                            <h3 class="section-title">Fee Detail</h3>
                            <p class="section-subtitle">Auto-calculated from fee master</p>
                        </div>
                    </div>
                    <div class="section-body">
                        <div class="row">
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        New Student Fee
                                        <span class="field-badge badge-calc">Calc</span>
                                    </label>
                                    <input id="txtNewStudentFee" asp-for="NewStudentFee" type="number" readonly="readonly" class="form-control fee-readonly">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        C-Money
                                        <span class="field-badge badge-calc">Calc</span>
                                    </label>
                                    <input id="txtCMondy" asp-for="CMoney" type="number" readonly="readonly" class="form-control fee-readonly">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Tuition Fee
                                        <span class="field-badge badge-calc">Calc</span>
                                    </label>
                                    <input id="txtTutionFee" asp-for="TutionFee" type="number" readonly="readonly" class="form-control fee-readonly">
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Other Fee
                                        <span class="field-badge badge-calc">Calc</span>
                                    </label>
                                    <input id="txtOtherFee" asp-for="OtherFee" type="number" readonly="readonly" class="form-control fee-readonly">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="fee-total-box">
                                    <div class="fee-total-label">Total Fee</div>
                                    <div class="fee-total-value" id="txtTotalFeeDisplay">₹0</div>
                                    <input id="txtTotalFee" asp-for="TotalFee" type="hidden" value="0">
                                </div>
                            </div>
                        </div>

                        <!-- Discount Row -->
                        <div class="row mt-3">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Scholarship Amount</label>
                                    <input asp-for="Scholership" type="number" class="form-control" placeholder="Enter scholarship">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Discount By</label>
                                    <input asp-for="DisBy" class="form-control" placeholder="Authorized by">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Discount Reason</label>
                                    <input asp-for="DisResion" class="form-control" placeholder="Reason for discount">
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="fee-total-box after-discount">
                                    <div class="fee-total-label">After Discount</div>
                                    <div class="fee-total-value" id="txtAfterDisDisplay">₹0</div>
                                    <input id="txtTotalFeeAfterDiscount" asp-for="TotalFeeAfterDiscount" type="hidden" value="0">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== PERSONAL DETAILS ===== -->
                <div class="section-card">
                    <div class="top-strip"></div>
                    <div class="section-header personal">
                        <div class="section-icon">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <div>
                            <h3 class="section-title">Student Personal Detail</h3>
                            <p class="section-subtitle">Basic student information</p>
                        </div>
                    </div>
                    <div class="section-body">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>
                                        First Name
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <input asp-for="Name" class="form-control" placeholder="Enter first name">
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>
                                        Father Name
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <input asp-for="FatherName" class="form-control" placeholder="Enter father name">
                                    <span asp-validation-for="FatherName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>
                                        Mother Name
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <input asp-for="MotherName" class="form-control" placeholder="Enter mother name">
                                    <span asp-validation-for="MotherName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>
                                        Mobile No
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <input asp-for="MobileNo" class="form-control" placeholder="10-digit mobile">
                                    <span asp-validation-for="MobileNo" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>
                                        Date of Birth
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <input asp-for="DOB" type="date" class="form-control">
                                    <span asp-validation-for="DOB" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Gender
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <select asp-for="Gender" class="form-control">
                                        <option value="">Select</option>
                                        <option>MALE</option>
                                        <option>FEMALE</option>
                                    </select>
                                    <span asp-validation-for="Gender" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="form-group">
                                    <label>
                                        Caste
                                        <span class="field-badge badge-req">Req</span>
                                    </label>
                                    <select asp-for="Caste" class="form-control">
                                        <option value="">Select</option>
                                        <option>GEN</option>
                                        <option>OBC</option>
                                        <option>SC</option>
                                        <option>ST</option>
                                    </select>
                                    <span asp-validation-for="Caste" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== ACTION BUTTONS ===== -->
                <div class="btn-bar">
                    <button class="btn-save" type="submit">
                        <i class="fas fa-paper-plane"></i>
                        Submit Admission
                    </button>
                    <button type="button" class="btn-exit" onclick="window.history.back()">
                        <i class="fas fa-arrow-left"></i>
                        Go Back
                    </button>
                </div>

            </form>
        </div>
    </section>
</div>


@section Scripts {
    <script src="~/ValidateJS/jquery-3.6.0.min.js"></script>
    <script src="~/ValidateJS/jquery.validate.min.js"></script>
    <script src="~/ValidateJS/jquery.validate.unobtrusive.min.js"></script>

    <script type="text/javascript">
        var BASE_URL = "@baseUrl";
        var Toast;

        var varSession = "";
        var varYear = "";
        var varSubject = "";
        var varClass = "";

        /* ===== Helper: format number as Indian currency ===== */
        function formatCurrency(num) {
            var n = parseFloat(num) || 0;
            return '₹' + n.toLocaleString('en-IN');
        }

        /* ===== Sync display boxes with hidden inputs ===== */
        function syncFeeDisplay() {
            var totalFee = parseFloat($('#txtTotalFee').val()) || 0;
            var afterDis  = parseFloat($('#txtTotalFeeAfterDiscount').val()) || 0;
            $('#txtTotalFeeDisplay').text(formatCurrency(totalFee));
            $('#txtAfterDisDisplay').text(formatCurrency(afterDis));
        }

        window.onload = function () {

            /* Scholarship change → recalculate discount */
            $("#Scholership").change(function () {
                var varScholership = this.value;
                if (varScholership !== "" && varScholership !== "0") {
                    var scholershipAmount = parseFloat(varScholership) || 0;
                    var totalFeeAmount   = parseFloat($('#txtTotalFee').val()) || 0;
                    var afterDiscount    = Math.max(0, totalFeeAmount - scholershipAmount);
                    $('#txtTotalFeeAfterDiscount').val(afterDiscount);
                } else {
                    var totalFeeAmount = parseFloat($('#txtTotalFee').val()) || 0;
                    $('#txtTotalFeeAfterDiscount').val(totalFeeAmount);
                }
                syncFeeDisplay();
            });

            /* Dropdowns → trigger fee fetch when all 4 are selected */
            $("#ddlSession").change(function () {
                varSession = this.value;
                if (varSession && varYear && varSubject && varClass) FillFeeeDetail();
            });
            $("#ddlYear").change(function () {
                varYear = this.value;
                if (varSession && varYear && varSubject && varClass) FillFeeeDetail();
            });
            $("#ddlSubject").change(function () {
                varSubject = this.value;
                if (varSession && varYear && varSubject && varClass) FillFeeeDetail();
            });
            $("#ddlClass").change(function () {
                varClass = this.value;
                if (varSession && varYear && varSubject && varClass) FillFeeeDetail();
            });

            /* SweetAlert2 Toast */
            Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2000,
                timerProgressBar: true,
            });

            /* Initial sync */
            syncFeeDisplay();
        };

        function Alert(icon, title, className) {
            Toast.fire({
                icon: icon,
                title: title,
                class: className,
            });
        }

        function FillFeeeDetail() {
            /* Reset */
            $('#txtNewStudentFee').val("0");
            $('#txtCMondy').val("0");
            $('#txtTutionFee').val("0");
            $('#txtOtherFee').val("0");
            $('#txtTotalFee').val("0");
            $('#txtTotalFeeAfterDiscount').val("0");
            syncFeeDisplay();

            if (varSession && varYear && varSubject && varClass) {
                $.post(BASE_URL + "/Admission/StudentPaymentDetail", {
                    classname: varClass,
                    course: varSubject,
                    session: varSession,
                    year: varYear
                }, function (res) {
                    var Feedetail = res.data.feeMasterDetail;
                    if (Feedetail != null && Feedetail != '') {
                        $('#txtNewStudentFee').val(Feedetail.newStudentFee);
                        $('#txtCMondy').val(Feedetail.cMoney);
                        $('#txtTutionFee').val(Feedetail.tutionFee);
                        $('#txtOtherFee').val(Feedetail.otherFee);
                        $('#txtTotalFee').val(Feedetail.totalFee);
                        $('#txtTotalFeeAfterDiscount').val(Feedetail.totalFee);
                        syncFeeDisplay();
                        Alert('success', 'Fee details loaded!', 'bg-success');
                    } else {
                        Alert('warning', 'Fee not found in Fee Master.', '');
                    }
                }).fail(function () {
                    Alert('error', 'Error fetching fee details.', '');
                });
            }
        }
    </script>
}